          <div class="ai-avatar">🤖</div>
          <div>
            <div class="ai-header-title">Ton Coach IA</div>
            <div class="ai-header-subtitle">Analyse personnalisée</div>
          </div>
        </div>
        <button class="ai-close-btn" onclick="closeAiModal()">✕</button>
      </div>
      <div id="aiLevelBadge" class="ai-level-badge" style="display:none;">
        <div class="level-ring">
          <svg viewBox="0 0 36 36">
            <circle class="bg" cx="18" cy="18" r="15.5" fill="none" stroke-width="3"/>
            <circle id="levelProgress" class="progress" cx="18" cy="18" r="15.5" fill="none" stroke="white" stroke-width="3"
                    stroke-dasharray="97.4" stroke-dashoffset="97.4" stroke-linecap="round"/>
          </svg>
          <div id="levelScore" class="level-score"></div>
        </div>
        <div class="level-info">
          <div id="levelName" class="level-name"></div>
          <div id="levelDesc" class="level-desc">Moyenne de tes 3 scores</div>
        </div>
      </div>
    </div>

    <!-- Loading state -->
    <div id="aiLoading" class="ai-loading">
      <div class="ai-loading-spinner"></div>
      <div class="ai-loading-text">Le Coach IA analyse ta performance...</div>
      <div class="ai-loading-sub">Chargement de tes recommandations personnalisées</div>
    </div>

    <!-- Tabs (hidden until loaded) -->
    <div id="aiTabsWrap" style="display:none;">
      <div class="ai-tabs">
        <button class="ai-tab active" data-tab="analysis" onclick="switchTab('analysis', this)">
          <span class="ai-tab-icon">📊</span> Analyse
        </button>
        <button class="ai-tab" data-tab="exercises" onclick="switchTab('exercises', this)">
          <span class="ai-tab-icon">🏋️</span> Exercices
        </button>
        <button class="ai-tab" data-tab="nutrition" onclick="switchTab('nutrition', this)">
          <span class="ai-tab-icon">🥗</span> Nutrition
        </button>
        <button class="ai-tab" data-tab="tips" onclick="switchTab('tips', this)">
          <span class="ai-tab-icon">💡</span> Conseils
        </button>
      </div>

      <!-- Analysis Tab -->
      <div id="tab-analysis" class="ai-tab-content active">
        <div class="radar-container">
          <div class="radar-title">Profil de Performance</div>
          <canvas id="aiRadarChart"></canvas>
        </div>
        <div id="scoreCards" class="score-cards"></div>
      </div>

      <!-- Exercises Tab -->
      <div id="tab-exercises" class="ai-tab-content">
        <div id="exercisesGrid" class="exercises-grid"></div>
      </div>

      <!-- Nutrition Tab -->
      <div id="tab-nutrition" class="ai-tab-content">
        <div id="nutritionLoading" class="nutri-loading">
          <div class="nutri-loading-spinner"></div>
          <div style="font-size:14px; font-weight:600; color:#b45309;">Préparation de ton plan nutrition...</div>
        </div>
        <div id="nutritionContent" style="display:none;"></div>
      </div>

      <!-- Tips Tab -->
      <div id="tab-tips" class="ai-tab-content">
        <div id="tipsContent"></div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
let myChart = null;

const exerciseImages = {
  'cardio': '/images/exercises/cardio.png',
  'strength': '/images/exercises/strength.png',
  'flexibility': '/images/exercises/flexibility.png',
  'technique': '/images/exercises/technique.png',
  'tactics': '/images/exercises/tactics.png',
  'hiit': '/images/exercises/hiit.png',
};

function switchTab(tabId, btn) {
  document.querySelectorAll('.ai-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.ai-tab-content').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tab-' + tabId).classList.add('active');
}

// Track current scores for nutrition tab lazy loading
let currentScores = { p: 0, t: 0, ta: 0, type: '' };
let nutritionLoaded = false;

function getAiAdvice(p, t, ta, type) {
  // Store scores for nutrition
  currentScores = { p, t, ta, type };
  nutritionLoaded = false;

  // Show modal with loading
  document.getElementById('aiModal').classList.add('show');
  document.getElementById('aiLoading').style.display = '';
  document.getElementById('aiTabsWrap').style.display = 'none';
  document.getElementById('aiLevelBadge').style.display = 'none';

  // Reset nutrition tab
  document.getElementById('nutritionLoading').style.display = '';
  document.getElementById('nutritionContent').style.display = 'none';

  // Fetch structured data
  fetch(`/front/coach/api/advice?p=${p}&t=${t}&ta=${ta}&type=${encodeURIComponent(type)}`)
    .then(r => r.json())
    .then(data => {
      document.getElementById('aiLoading').style.display = 'none';
      document.getElementById('aiTabsWrap').style.display = '';

      switchTab('analysis', document.querySelector('.ai-tab[data-tab="analysis"]'));
      renderLevelBadge(data);
      renderRadar(data.scores);
      renderScoreCards(data);
      renderExercises(data.exercises);
      renderTips(data);
    })
    .catch(err => {
      document.getElementById('aiLoading').innerHTML =
        `<div style="color:#ef4444; font-size:14px;">❌ Erreur de connexion au Coach IA</div>
         <div style="color:#888; font-size:12px; margin-top:8px;">Veuillez réessayer dans quelques instants.</div>`;
    });
}

function renderLevelBadge(data) {
  const badge = document.getElementById('aiLevelBadge');
  badge.style.display = 'flex';

  const level = data.level;
  document.getElementById('levelScore').textContent = data.scores.moyenne + '/20';
  document.getElementById('levelName').innerHTML = `${level.icon} ${level.name}`;

  // Animate progress ring
  const circumference = 97.4;
  const offset = circumference - (level.progress / 100 * circumference);
  setTimeout(() => {
    document.getElementById('levelProgress').style.strokeDashoffset = offset;
  }, 300);
}

function renderRadar(scores) {
  const ctx = document.getElementById('aiRadarChart').getContext('2d');
  if (myChart) myChart.destroy();
  myChart = new Chart(ctx, {
    type: 'radar',
    data: {
      labels: ['Physique', 'Technique', 'Tactique'],
      datasets: [{
        label: 'Tes notes',
        data: [scores.physique, scores.technique, scores.tactique],
        backgroundColor: 'rgba(22, 163, 74, 0.15)',
        borderColor: '#16a34a',
        borderWidth: 2.5,
        pointBackgroundColor: '#16a34a',
        pointBorderColor: '#fff',
        pointBorderWidth: 2,
        pointRadius: 6,
      }]
    },
    options: {
      scales: { r: { min: 0, max: 20, ticks: { display: false, stepSize: 5 }, grid: { color: '#e5e7eb' }, pointLabels: { font: { size: 13, weight: '600', family: 'DM Sans' }, color: '#374151' } } },
      plugins: { legend: { display: false } },
      animation: { duration: 1000 }
    }
  });
}

function renderScoreCards(data) {
  const analyses = [
    { label: 'Physique', emoji: '💪', score: data.scores.physique, analysis: data.physique_analysis },
    { label: 'Technique', emoji: '🎯', score: data.scores.technique, analysis: data.technique_analysis },
    { label: 'Tactique', emoji: '🧠', score: data.scores.tactique, analysis: data.tactique_analysis },
  ];

  let html = '';
  analyses.forEach(a => {
    const pct = (a.score / 20 * 100);
    html += `
      <div class="score-card">
        <div class="score-card-header">
          <div class="score-card-label">
            <span class="emoji">${a.emoji}</span> ${a.label}
            <span style="font-size:11px; padding:2px 8px; border-radius:99px; background:${a.analysis.color}15; color:${a.analysis.color}; font-weight:600;">${a.analysis.status}</span>
          </div>
          <div class="score-card-value" style="color:${a.analysis.color}">${a.score}/20</div>
        </div>
        <div class="score-bar-track">
          <div class="score-bar-fill" style="background:${a.analysis.color};" data-width="${pct}%"></div>
        </div>
        <div class="score-card-message">
          ${a.analysis.emoji} ${a.analysis.message}
        </div>
      </div>
    `;
  });

  document.getElementById('scoreCards').innerHTML = html;

  // Animate bars after render
  setTimeout(() => {
    document.querySelectorAll('.score-bar-fill').forEach(bar => {
      bar.style.width = bar.dataset.width;
    });
  }, 100);
}

function renderExercises(exercises) {
  let html = '';
  exercises.forEach(ex => {
    const img = exerciseImages[ex.image] || exerciseImages['technique'];
    html += `
      <div class="exercise-card">
        <div class="exercise-card-img" style="background-image:url('${img}')">
          <div class="exercise-card-img-overlay"></div>
          <span class="exercise-category-badge" style="background:${ex.categoryColor}">${ex.category}</span>
          <span class="exercise-intensity-badge">⚡ ${ex.intensity}</span>
        </div>
        <div class="exercise-card-body">
          <div class="exercise-card-name">${ex.name}</div>
          <div class="exercise-card-desc">${ex.description}</div>
          <div class="exercise-card-meta">
            <span class="exercise-meta-item">⏱️ ${ex.duration}</span>
            <span class="exercise-meta-item">🔥 ${ex.intensity}</span>
          </div>
        </div>
      </div>
    `;
  });
  document.getElementById('exercisesGrid').innerHTML = html;
}

function renderTips(data) {
  let html = '';

  // Training tip
  html += `
    <div class="tip-card">
      <div class="tip-card-title">💡 Conseil d'entraînement</div>
      <div class="tip-card-text">${data.training_tip}</div>
    </div>
  `;

  // AI advice if available
  if (data.ai_advice) {
    html += `
      <div class="tip-card" style="background: linear-gradient(135deg, #eff6ff, #eef2ff); border-color: #c7d2fe;">
        <div class="tip-card-title" style="color: #3730a3;">🤖 Analyse Gemini AI</div>
        <div class="tip-card-text">${data.ai_advice.replace(/\n/g, '<br>')}</div>
      </div>
    `;
  }

  // Motivation
  html += `
    <div class="motivation-card">
      <span class="motivation-icon">🔥</span>
      <div class="motivation-quote">${data.motivation}</div>
    </div>
  `;

  // AI powered badge
  html += `
    <div style="text-align:center; margin-top:16px;">
      <span class="ai-powered-badge">
        <span class="dot"></span>
        Analyse générée par Sport Insight AI Coach
      </span>
    </div>
  `;

  document.getElementById('tipsContent').innerHTML = html;
}

// ─── NUTRITION TAB ─────────────────────────────────────────
// Load nutrition data when tab is clicked (lazy load)
const origSwitchTab = switchTab;
window.switchTab = function(tabId, btn) {
  origSwitchTab(tabId, btn);
  if (tabId === 'nutrition' && !nutritionLoaded) {
    loadNutritionData();
  }
};
// Reassign to keep reference
switchTab = window.switchTab;

function loadNutritionData() {
  const {p, t, ta, type} = currentScores;
  fetch(`/front/coach/api/nutrition?p=${p}&t=${t}&ta=${ta}&type=${encodeURIComponent(type)}`)
    .then(r => r.json())
    .then(data => {
      nutritionLoaded = true;
      document.getElementById('nutritionLoading').style.display = 'none';
      document.getElementById('nutritionContent').style.display = '';
      renderNutrition(data);
    })
    .catch(err => {
      document.getElementById('nutritionLoading').innerHTML =
        `<div style="color:#ef4444;">❌ Erreur de chargement des données nutrition</div>`;
    });
}

function renderNutrition(data) {
  let html = '';

  // ── Calories & Hydration overview ──
  html += `<div class="nutri-overview">`;
  html += `
    <div class="calorie-card">
      <div style="font-size:24px; margin-bottom:6px;">🔥</div>
      <div class="calorie-value">${data.calories_estimate.min} - ${data.calories_estimate.max}</div>
      <div class="calorie-label">Calories / jour</div>
      <div class="calorie-sub">Intensité : ${data.calories_estimate.intensity === 'light' ? '🟢 Légère' : data.calories_estimate.intensity === 'moderate' ? '🟡 Modérée' : '🔴 Intense'}</div>
    </div>
  `;
  html += `
    <div class="hydration-card">
      <div style="font-size:24px; margin-bottom:6px;">💧</div>
      <div class="hydration-value">${data.hydration.litres_min}L - ${data.hydration.litres_max}L</div>
      <div class="hydration-label">Hydratation / jour</div>
      <div class="hydration-tips">
        ${data.hydration.tips.map(t => `<div>${t}</div>`).join('')}
        ${data.hydration.electrolytes ? '<div style="margin-top:4px; font-weight:700;">⚡ Électrolytes recommandés</div>' : ''}
      </div>
    </div>
  `;
  html += `</div>`;

  // ── Macros ──
  html += `<div class="nutrition-section">`;
  html += `<div class="nutrition-section-title">📊 Répartition des Macronutriments</div>`;
  html += `<div class="macro-bars">`;
  ['protein', 'carbs', 'fat'].forEach(key => {
    const m = data.macros[key];
    html += `
      <div class="macro-bar-item">
        <div class="macro-icon" style="background:${m.color}15;">${m.icon}</div>
        <div class="macro-info">
          <div class="macro-name">${m.label}</div>
          <div class="macro-desc">${m.description}</div>
          <div class="macro-bar-track">
            <div class="macro-bar-fill" style="background:${m.color};" data-width="${m.percent}%"></div>
          </div>
        </div>
        <div class="macro-percent" style="color:${m.color};">${m.percent}%</div>
      </div>
    `;
  });
  html += `</div></div>`;

  // ── Pre/Post workout ──
  html += `<div class="nutrition-section">`;
  html += `<div class="nutrition-section-title">⚡ Nutrition Pré & Post Entraînement</div>`;
  html += `<div class="workout-nutrition">`;

  // Pre-workout
  html += `<div class="workout-card">`;
  html += `<div class="workout-card-header pre">🔜 Avant l'effort</div>`;
  html += `<div class="workout-card-body">`;
  html += `<div class="workout-timing">⏰ ${data.pre_workout.timing}</div>`;
  data.pre_workout.foods.forEach(f => {
    html += `
      <div class="workout-food-item">
        <span class="workout-food-emoji">${f.emoji}</span>
        <div class="workout-food-info">
          <div class="workout-food-name">${f.name}</div>
          <div class="workout-food-benefit">${f.benefit}</div>
        </div>
      </div>
    `;
  });
  if (data.pre_workout.avoid && data.pre_workout.avoid.length) {
    html += `<div style="margin-top:10px; padding:8px 12px; background:#fef2f2; border-radius:8px; font-size:11px; color:#991b1b;"><b>❌ Éviter :</b> ${data.pre_workout.avoid.join(', ')}</div>`;
  }
  html += `</div></div>`;

  // Post-workout
  html += `<div class="workout-card">`;
  html += `<div class="workout-card-header post">🔙 Après l'effort</div>`;
  html += `<div class="workout-card-body">`;
  html += `<div class="workout-timing">⏰ ${data.post_workout.timing}</div>`;
  data.post_workout.foods.forEach(f => {
    html += `
      <div class="workout-food-item">
        <span class="workout-food-emoji">${f.emoji}</span>
        <div class="workout-food-info">
          <div class="workout-food-name">${f.name}</div>
          <div class="workout-food-benefit">${f.benefit}</div>
        </div>
      </div>
    `;
  });
  if (data.post_workout.window) {
    html += `<div class="workout-window">⚠️ ${data.post_workout.window}</div>`;
  }
  html += `</div></div>`;
  html += `</div></div>`;

  // ── Meal plan ──
  html += `<div class="nutrition-section">`;
  html += `<div class="nutrition-section-title">🍽️ Plan Repas Recommandé</div>`;
  html += `<div class="meals-grid">`;
  data.meals.forEach(meal => {
    html += `
      <div class="meal-card">
        <div class="meal-card-img" style="background-image:url('${meal.image}')">
          <div class="meal-card-img-overlay"></div>
          <span class="meal-time-badge">⏰ ${meal.time}</span>
          <span class="meal-cal-badge">${meal.calories}</span>
        </div>
        <div class="meal-card-body">
          <div class="meal-card-name">${meal.icon} ${meal.name}</div>
          <ul class="meal-food-list">
            ${meal.foods.map(f => `<li>${f}</li>`).join('')}
          </ul>
        </div>
      </div>
    `;
  });
  html += `</div></div>`;

  // ── Supplements ──
  html += `<div class="nutrition-section">`;
  html += `<div class="nutrition-section-title">💊 Compléments Recommandés</div>`;
  html += `<div class="supplements-grid">`;
  data.supplements.forEach(s => {
    html += `
      <div class="supplement-card ${s.recommended ? 'recommended' : ''}">
        <div class="supplement-header">
          <span class="supplement-emoji">${s.emoji}</span>
          <span class="supplement-name">${s.name}</span>
          ${s.recommended ? '<span class="supplement-rec-badge">Recommandé</span>' : ''}
        </div>
        <div class="supplement-benefit">${s.benefit}</div>
        <div class="supplement-when">📅 ${s.when}</div>
      </div>
    `;
  });
  html += `</div></div>`;

  // ── API Foods (real data from API Ninjas) ──
  if (data.api_foods && data.api_foods.length > 0) {
    html += `<div class="nutrition-section">`;
    html += `<div class="nutrition-section-title">🔬 Données Nutritionnelles Réelles</div>`;
    html += `<p style="font-size:13px; color:#6b7280; margin-bottom:14px;">Valeurs nutritionnelles réelles pour les aliments recommandés, fournies par l'API Ninjas</p>`;
    html += `<div class="api-foods-grid">`;
    data.api_foods.forEach((food, i) => {
      const maxProtein = 50, maxCarbs = 80, maxFat = 40;
      const protein  = parseFloat(food.protein_g)            || 0;
      const carbs    = parseFloat(food.carbohydrates_total_g) || 0;
      const fat      = parseFloat(food.fat_total_g)          || 0;
      const fiber    = parseFloat(food.fiber_g)              || 0;
      const sugar    = parseFloat(food.sugar_g)              || 0;
      const sodium   = parseFloat(food.sodium_mg)            || 0;
      const calories = parseFloat(food.calories)             || 0;
      const serving  = parseFloat(food.serving_size_g)       || 100;
      html += `
        <div class="api-food-card" style="animation-delay:${i * 0.08}s">
          <div class="api-food-name">${food.name}</div>
          <div class="api-food-serving">Portion : ${serving}g</div>
          <div class="api-food-calories">
            <span style="font-size:18px;">🔥</span>
            <span class="cal-val">${Math.round(calories)}</span>
            <span class="cal-label">kcal</span>
          </div>
          <div class="api-nutrient-row">
            <span class="api-nutrient-name">🥩 Protéines</span>
            <span class="api-nutrient-value">${protein.toFixed(1)}g</span>
          </div>
          <div class="api-nutrient-bar"><div class="api-nutrient-bar-fill" style="background:#ef4444; width:${Math.min(protein / maxProtein * 100, 100)}%"></div></div>
          <div class="api-nutrient-row">
            <span class="api-nutrient-name">🌾 Glucides</span>
            <span class="api-nutrient-value">${carbs.toFixed(1)}g</span>
          </div>
          <div class="api-nutrient-bar"><div class="api-nutrient-bar-fill" style="background:#f59e0b; width:${Math.min(carbs / maxCarbs * 100, 100)}%"></div></div>
          <div class="api-nutrient-row">
            <span class="api-nutrient-name">🥑 Lipides</span>
            <span class="api-nutrient-value">${fat.toFixed(1)}g</span>
          </div>
          <div class="api-nutrient-bar"><div class="api-nutrient-bar-fill" style="background:#22c55e; width:${Math.min(fat / maxFat * 100, 100)}%"></div></div>
          ${fiber > 0 ? `<div class="api-nutrient-row"><span class="api-nutrient-name">🌿 Fibres</span><span class="api-nutrient-value">${fiber.toFixed(1)}g</span></div>` : ''}
          ${sugar > 0 ? `<div class="api-nutrient-row"><span class="api-nutrient-name">🍬 Sucres</span><span class="api-nutrient-value">${sugar.toFixed(1)}g</span></div>` : ''}
          ${sodium > 0 ? `<div class="api-nutrient-row"><span class="api-nutrient-name">🧂 Sodium</span><span class="api-nutrient-value">${Math.round(sodium)}mg</span></div>` : ''}
        </div>
      `;
    });
    html += `</div>`;
    html += `<div style="text-align:center;"><span class="api-badge"><span class="api-dot"></span> Données en temps réel — API Ninjas</span></div>`;
    html += `</div>`;
  }

  // ── Nutrition tip ──
  html += `
    <div class="nutri-tip-card">
      <div class="nutri-tip-title">🌿 Le Saviez-vous ?</div>
      <div class="nutri-tip-text">${data.nutrition_tip}</div>
    </div>
  `;

  document.getElementById('nutritionContent').innerHTML = html;

  // Animate macro bars
  setTimeout(() => {
    document.querySelectorAll('#nutritionContent .macro-bar-fill').forEach(bar => {
      bar.style.width = bar.dataset.width;
    });
  }, 100);
}

function closeAiModal() {
  document.getElementById('aiModal').classList.remove('show');
}
</script>
{% endblock %}
