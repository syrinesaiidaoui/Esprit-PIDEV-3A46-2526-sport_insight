{% extends 'equipe/base.html.twig' %}

{% block content %}
    <h1>Détails de l'Équipe : {{ equipe.nom }}</h1>

    {% if equipe.image %}
        <div class="mb-4">
            <img src="{{ asset('uploads/equipes/' ~ equipe.image) }}" alt="{{ equipe.nom }}" style="max-height: 200px; max-width: 300px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
        </div>
    {% endif %}

    <table class="table">
        <tbody>
            <tr>
                <th>Id Internal</th>
                <td>{{ equipe.id }}</td>
            </tr>
            <tr>
                <th>Id Équipe</th>
                <td>{{ equipe.idEquipe }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ equipe.nom }}</td>
            </tr>
            <tr>
                <th>Coach</th>
                <td>{{ equipe.coach }}</td>
            </tr>
            <tr>
                <th>Adresse</th>
                <td>{{ equipe.adresse|default('-') }}</td>
            </tr>
            <tr>
                <th>Téléphone</th>
                <td>{{ equipe.telephone|default('-') }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ equipe.email|default('-') }}</td>
            </tr>
        </tbody>
    </table>

    <div class="mt-4">
        <a href="{{ path('app_equipe_index') }}" class="btn btn-secondary">Back to list</a>
        <a href="{{ path('app_equipe_edit', {'id': equipe.id}) }}" class="btn btn-primary">Edit</a>
        {{ include('equipe/_delete_form.html.twig') }}
    </div>
{% endblock %}
