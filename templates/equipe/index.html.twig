{% extends 'equipe/base.html.twig' %}

{% block content %}
    <div class="data-table">
        <div class="data-table-header">
            <div class="toolbar">
                <div>
                    <h3>Equipes</h3>
                    <p class="muted">{{ equipes|length }} equipe(s)</p>
                </div>
                <a href="{{ path('app_equipe_new') }}" class="btn btn-primary btn-add-product">Creer</a>
            </div>
        </div>

        <div style="padding: 18px 24px; border-bottom: 1px solid var(--border-color);">
            <form method="GET" action="{{ path('app_equipe_index') }}" class="d-flex gap-2 align-items-end flex-wrap">
                <div style="min-width: 260px; flex: 1 1 auto;">
                    <label for="search" class="form-label">Recherche</label>
                    <input type="text" name="search" id="search" value="{{ search }}" placeholder="Rechercher par nom..." class="form-control">
                </div>
                <button type="submit" class="btn btn-primary">Rechercher</button>
                <a href="{{ path('app_equipe_index') }}" class="btn btn-secondary">Reinitialiser</a>
            </form>
        </div>

        <div style="overflow-x: auto;">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Logo</th>
                        <th>Id</th>
                        <th>Nom</th>
                        <th>Coach</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for equipe in equipes %}
                    <tr>
                        <td>
                            {% if equipe.image %}
                                <img src="{{ asset('uploads/equipes/' ~ equipe.image) }}" alt="{{ equipe.nom }}" style="max-height: 40px; max-width: 40px; border-radius: 8px;">
                            {% else %}
                                <span class="muted-soft">-</span>
                            {% endif %}
                        </td>
                        <td>#{{ equipe.id }}</td>
                        <td>{{ equipe.nom }}</td>
                        <td>{{ equipe.coach ?: '-' }}</td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <a href="{{ path('app_equipe_show', {'id': equipe.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                                <a href="{{ path('app_equipe_edit', {'id': equipe.id}) }}" class="btn btn-sm btn-outline-secondary">Editer</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center muted-soft">Aucune equipe trouvee</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        <div style="padding: 18px 24px; border-top: 1px solid var(--border-color);">
            <form method="get" action="{{ path('app_equipe_index') }}" class="d-flex gap-2 flex-wrap">
                <button type="submit" name="sort" value="id" class="btn btn-outline-secondary">Sort by Id</button>
                <button type="submit" name="sort" value="nom" class="btn btn-outline-secondary">Sort by Nom</button>
                <button type="submit" name="sort" value="coach" class="btn btn-outline-secondary">Sort by Coach</button>
                <input type="hidden" name="order" value="{{ currentOrder == 'asc' ? 'desc' : 'asc' }}">
            </form>
        </div>
    </div>
{% endblock %}
