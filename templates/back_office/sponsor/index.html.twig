{% extends 'back_office/base.html.twig' %}

{% block title %}Sponsors{% endblock %}

{% block body %}
    <div class="main-content">
        <div class="page-header">
            <h1>Gestion des Sponsors</h1>
            <a href="{{ path('app_sponsor_new') }}" class="btn btn-create">
                <i class="lucide-plus"></i> Nouveau sponsor
            </a>
        </div>

        <!-- Search Bar -->
        <div class="card search-card">
            <h3 style="margin: 0 0 15px 0; color: var(--text-dark);">
                <i class="lucide-search" style="font-size: 18px; vertical-align: middle; margin-right: 8px;"></i>
                Filtrer les sponsors
            </h3>
            <form method="get" class="search-form">
                <div class="search-fields">
                    <div class="search-field">
                        <label for="email">Email</label>
                        <input 
                            type="email" 
                            id="email" 
                            name="email" 
                            class="form-control"
                            placeholder="Rechercher par email..."
                            value="{{ email ?? '' }}"
                        >
                    </div>
                    <div class="search-field">
                        <label for="budget">Budget</label>
                        <input 
                            type="number" 
                            id="budget" 
                            name="budget" 
                            class="form-control"
                            placeholder="Rechercher par budget..."
                            value="{{ budget ?? '' }}"
                            step="0.01"
                            min="0"
                        >
                    </div>
                </div>
                <div class="search-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="lucide-search"></i> Rechercher
                    </button>
                    <a href="{{ path('app_sponsor_index') }}" class="btn btn-secondary">
                        <i class="lucide-x"></i> Réinitialiser
                    </a>
                </div>
            </form>
        </div>

        {% if sponsors %}
            <div class="card">
                <table class="table table-striped">
                    <thead class="table-light">
                        <tr>
                            <th>Logo</th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Budget</th>
                            <th>Contrats</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for sponsor in sponsors %}
                        <tr>
                            <td>
                                {% set logo = sponsor.logoName %}
                                {% if logo %}
                                    <img src="{{ asset('uploads/logos/' ~ logo) }}" alt="{{ sponsor.nom }}" height="40" style="border-radius: 4px; background: #fff; padding: 2px;" onerror="this.onerror=null;this.src='{{ asset('uploads/sponsors/' ~ logo) }}';">
                                {% else %}
                                    <span class="badge badge-secondary">Aucun</span>
                                {% endif %}
                            </td>
                            <td><strong>{{ sponsor.nom }}</strong></td>
                            <td>{{ sponsor.email }}</td>
                            <td><strong>{{ sponsor.budget }} DT</strong></td>
                            <td>
                                <span class="badge badge-info">{{ sponsor.contratSponsors|length }}</span>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a href="{{ path('app_sponsor_show', {'id': sponsor.id}) }}" class="btn btn-sm btn-info" title="Voir">
                                        <i class="lucide-eye"></i>
                                    </a>
                                    <a href="{{ path('app_sponsor_edit', {'id': sponsor.id}) }}" class="btn btn-sm btn-warning" title="Éditer">
                                        <i class="lucide-edit"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="alert alert-info" role="alert">
                <i class="lucide-info"></i> Aucun sponsor trouvé.
            </div>
        {% endif %}
    </div>

    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }
        .page-header h1 {
            margin: 0;
            color: var(--text-dark);
        }
        .btn-create {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.3s;
        }
        .btn-create:hover {
            background: var(--primary-hover);
            color: white;
        }
        .card {
            background: var(--card-bg);
            border-radius: 8px;
            padding: 20px;
            border: 1px solid var(--border-color);
        }
        .action-buttons {
            display: flex;
            gap: 8px;
            justify-content: flex-end;
        }
        .badge-info {
            background: #3b82f6;
            color: white;
            padding: 5px 10px;
            border-radius: 4px;
            display: inline-block;
            font-size: 13px;
            font-weight: 500;
        }
        .search-card {
            border: 2px solid var(--primary);
            margin-bottom: 30px;
            box-shadow: 0 2px 8px rgba(16, 185, 129, 0.1);
        }
        .search-fields {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
            margin-bottom: 15px;
        }
        .search-field {
            display: flex;
            flex-direction: column;
        }
        .search-field label {
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--text-dark);
        }
        .btn-primary, .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 18px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
        }
        .btn-primary { background: var(--primary); color: white; }
        .btn-secondary { background: #6b7280; color: white; }
    </style>
{% endblock %}
