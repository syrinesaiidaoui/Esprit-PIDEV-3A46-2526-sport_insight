{% set currentTheme = app.request.session.get('theme_mode', 'light') %}
<!DOCTYPE html>
<html lang="fr" data-theme="{{ currentTheme }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin - Sport Insight{% endblock %}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('images/logos/mini%20logo%20nuit.png') }}?v=20260304">
    <link rel="shortcut icon" href="{{ asset('images/logos/mini%20logo%20nuit.png') }}?v=20260304">
    <link rel="apple-touch-icon" href="{{ asset('images/logos/mini%20logo%20nuit.png') }}?v=20260304">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://unpkg.com/lucide-static@latest/font/lucide.css" rel="stylesheet">
    <script>
        (function () {
            function isValidMode(mode) {
                return mode === 'light' || mode === 'dark';
            }

            try {
                var savedTheme = localStorage.getItem('theme_mode')
                    || localStorage.getItem('admin_theme_mode')
                    || localStorage.getItem('front_theme_mode');

                if (isValidMode(savedTheme)) {
                    document.documentElement.setAttribute('data-theme', savedTheme);
                }
            } catch (e) {
                if (!isValidMode(document.documentElement.getAttribute('data-theme'))) {
                    document.documentElement.setAttribute('data-theme', 'light');
                }
            }
        })();
    </script>

    <style>
        :root {
            --sidebar-bg: linear-gradient(185deg, #0b1020 0%, #0b1636 45%, #081a40 100%);
            --sidebar-hover: rgba(148, 163, 184, 0.16);
            --sidebar-text: #b5c0d3;
            --sidebar-active: #34d399;
            --header-bg: #ffffff;
            --body-bg: #edf2f7;
            --card-bg: #ffffff;
            --text-dark: #111827;
            --text-muted: #6b7280;
            --border-color: #e5e7eb;
            --primary: #10b981;
            --primary-hover: #059669;
            --table-head-bg: #f9fafb;
            --table-row-hover: #f9fafb;
            --header-control-bg: #f8fafc;
            --header-control-text: #334155;
            --input-bg: #ffffff;
            --input-text: #111827;
            --input-border: #d1d5db;
            --link-color: #2563eb;
            --pagination-bg: #ffffff;
            --pagination-text: #334155;
            --surface-2: #f3f4f6;
        }

        [data-theme="dark"] {
            --sidebar-bg: linear-gradient(180deg, #020617 0%, #081028 50%, #0c1731 100%);
            --sidebar-hover: rgba(148, 163, 184, 0.14);
            --sidebar-text: #94a3b8;
            --sidebar-active: #34d399;
            --header-bg: #0b1220;
            --body-bg: #020617;
            --card-bg: #111827;
            --text-dark: #e2e8f0;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --primary: #10b981;
            --primary-hover: #059669;
            --table-head-bg: #0f172a;
            --table-row-hover: #1e293b;
            --header-control-bg: #0f172a;
            --header-control-text: #cbd5e1;
            --input-bg: #0b1220;
            --input-text: #e2e8f0;
            --input-border: #334155;
            --link-color: #93c5fd;
            --pagination-bg: #0b1220;
            --pagination-text: #cbd5e1;
            --surface-2: #0f172a;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Manrope', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--body-bg) !important;
            color: var(--text-dark);
            min-height: 100vh;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 274px;
            height: 100vh;
            background: var(--sidebar-bg);
            padding: 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(255,255,255,0.08);
            box-shadow: 20px 0 55px rgba(0, 0, 0, 0.22);
            transition: transform 0.24s ease;
        }

        .sidebar-brand {
            padding: 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sidebar-brand-icon {
            width: 40px;
            height: 40px;
            background: var(--primary);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 18px;
            color: #fff;
        }

        .sidebar-brand-text {
            color: #fff;
            font-size: 20px;
            font-family: 'Barlow Condensed', sans-serif;
            letter-spacing: 0.4px;
            font-weight: 700;
        }

        .sidebar-brand-sub {
            color: var(--sidebar-text);
            font-size: 12px;
        }

        .sidebar-nav {
            padding: 16px 12px;
            flex: 1;
            overflow-y: auto;
        }

        .sidebar-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--sidebar-text);
            padding: 12px 12px 8px;
            font-weight: 600;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            border-radius: 10px;
            color: var(--sidebar-text);
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            transition: all 0.15s;
            margin-bottom: 4px;
            border: 1px solid transparent;
        }

        .sidebar-link:hover {
            background: var(--sidebar-hover);
            color: #fff;
            border-color: rgba(148, 163, 184, 0.2);
        }

        .sidebar-link.active {
            background: rgba(52, 211, 153, 0.2);
            color: var(--sidebar-active);
            border-color: rgba(52, 211, 153, 0.25);
        }

        .sidebar-link i {
            font-size: 18px;
            width: 20px;
            text-align: center;
        }

        .sidebar-footer {
            padding: 16px 12px;
            border-top: 1px solid rgba(255,255,255,0.06);
        }

        /* ===== MAIN CONTENT ===== */
        .main-content {
            margin-left: 274px;
            min-height: 100vh;
            transition: margin-left 0.24s ease;
        }

        .top-header {
            background: var(--header-bg);
            border-bottom: 1px solid var(--border-color);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 900;
            backdrop-filter: blur(8px);
        }

        .top-header h1 {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-dark);
            margin: 0;
        }

        .top-header-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sidebar-toggle {
            display: none;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid var(--border-color);
            background: var(--header-control-bg);
            color: var(--header-control-text);
            cursor: pointer;
        }

        .page-content {
            padding: 32px;
        }

        .admin-kpis {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 16px;
            margin-bottom: 20px;
        }

        /* ===== CARDS ===== */
        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 18px;
            min-height: 132px;
        }

        .stat-card-label {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 500;
            margin-bottom: 8px;
        }

        .stat-card-value {
            font-size: 28px;
            font-weight: 700;
            color: var(--text-dark);
        }

        .stat-card-sub {
            font-size: 12px;
            color: var(--primary);
            margin-top: 4px;
        }

        /* ===== TABLE ===== */
        .data-table {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow: hidden;
        }

        .data-table-header {
            padding: 20px 24px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .data-table-header h3 {
            font-size: 16px;
            font-weight: 600;
        }

        .muted {
            color: var(--text-muted);
            font-size: 13px;
            margin: 0;
        }

        .toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .toolbar form {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .data-table table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table thead th {
            padding: 12px 24px;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            font-weight: 600;
            background: var(--table-head-bg);
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        .data-table tbody td {
            padding: 14px 24px;
            font-size: 14px;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            color: var(--text-dark);
        }

        .data-table tbody tr:last-child td {
            border-bottom: none;
        }

        .data-table tbody tr:hover {
            background: var(--table-row-hover);
        }

        /* ===== BADGES ===== */
        .badge-success {
            background: rgba(16, 185, 129, 0.1);
            color: #059669;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-warning {
            background: rgba(245, 158, 11, 0.1);
            color: #d97706;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-danger {
            background: rgba(239, 68, 68, 0.1);
            color: #dc2626;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-info {
            background: rgba(59, 130, 246, 0.1);
            color: #2563eb;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
        }

        /* ===== BUTTONS ===== */
        .btn-primary {
            background: var(--primary) !important;
            border-color: var(--primary) !important;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            padding: 8px 16px;
        }
        .btn-add-product {
            padding: 8px 14px;
            font-size: 13px;
            font-weight: 600;
        }

        .btn-primary:hover {
            background: var(--primary-hover) !important;
            border-color: var(--primary-hover) !important;
        }

        .btn-outline-secondary {
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            padding: 8px 16px;
            background: var(--header-control-bg) !important;
            color: var(--header-control-text) !important;
            border-color: var(--border-color) !important;
        }

        .data-table a {
            color: var(--link-color);
        }

        .data-table .form-control,
        .data-table .form-select,
        .page-content .form-control,
        .page-content .form-select {
            background: var(--input-bg) !important;
            color: var(--input-text) !important;
            border-color: var(--input-border) !important;
        }

        .data-table .form-control::placeholder {
            color: var(--text-muted);
            opacity: 1;
        }

        .page-content .pagination .page-link {
            background: var(--pagination-bg);
            color: var(--pagination-text);
            border-color: var(--border-color);
        }

        .page-content .pagination .page-item.active .page-link {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
        }

        [data-theme="dark"] .page-content .card,
        [data-theme="dark"] .data-table,
        [data-theme="dark"] .stat-card,
        [data-theme="dark"] .modal-content,
        [data-theme="dark"] .offcanvas,
        [data-theme="dark"] .dropdown-menu {
            background: var(--card-bg) !important;
            color: var(--text-dark) !important;
            border-color: var(--border-color) !important;
        }

        .btn-secondary {
            background: var(--surface-2) !important;
            color: var(--header-control-text) !important;
            border-color: var(--border-color) !important;
        }

        .btn-secondary:hover {
            filter: brightness(0.97);
        }

        .text-muted,
        .text-body-secondary {
            color: var(--text-muted) !important;
        }

        [data-theme="dark"] .page-content .table,
        [data-theme="dark"] .page-content .table thead th,
        [data-theme="dark"] .page-content .table tbody td {
            color: var(--text-dark) !important;
            border-color: var(--border-color) !important;
        }

        [data-theme="dark"] .page-content .table > :not(caption) > * > * {
            background-color: transparent !important;
            box-shadow: none !important;
        }

        [data-theme="dark"] .page-content .table-striped > tbody > tr:nth-of-type(odd) > * {
            background-color: rgba(148, 163, 184, 0.08) !important;
        }

        [data-theme="dark"] .page-content .form-control::placeholder,
        [data-theme="dark"] .page-content input::placeholder,
        [data-theme="dark"] .page-content textarea::placeholder {
            color: var(--text-muted) !important;
            opacity: 1;
        }

        [data-theme="dark"] .page-content [style*="background: #fff"],
        [data-theme="dark"] .page-content [style*="background:#fff"],
        [data-theme="dark"] .page-content [style*="background: #ffffff"],
        [data-theme="dark"] .page-content [style*="background:#ffffff"] {
            background: var(--card-bg) !important;
            border-color: var(--border-color) !important;
        }

        [data-theme="dark"] .page-content [style*="color: #111827"],
        [data-theme="dark"] .page-content [style*="color:#111827"] {
            color: var(--text-dark) !important;
        }

        [data-theme="dark"] .btn-outline-primary,
        [data-theme="dark"] .btn-outline-secondary,
        [data-theme="dark"] .btn-outline-success,
        [data-theme="dark"] .btn-outline-danger {
            color: var(--text-dark) !important;
            border-color: var(--border-color) !important;
            background: transparent !important;
        }

        [data-theme="dark"] .btn-outline-primary:hover,
        [data-theme="dark"] .btn-outline-secondary:hover,
        [data-theme="dark"] .btn-outline-success:hover,
        [data-theme="dark"] .btn-outline-danger:hover {
            background: var(--surface-2) !important;
        }

        .theme-controls {
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .theme-controls .btn.active {
            background: var(--primary) !important;
            color: #fff !important;
            border-color: var(--primary) !important;
        }

        .admin-form-shell {
            max-width: 1100px;
        }

        .page-content .form-label,
        .page-content label {
            color: var(--text-dark);
        }

        .muted-soft {
            color: var(--text-muted) !important;
        }

        /* ===== AVATAR ===== */
        .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--primary);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 14px;
        }

        .sidebar-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(2, 6, 23, 0.55);
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.2s ease, visibility 0.2s ease;
            z-index: 980;
        }

        .sidebar-backdrop.show {
            opacity: 1;
            visibility: visible;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 991px) {
            .sidebar {
                transform: translateX(-100%);
            }

            .sidebar.open {
                transform: translateX(0);
            }

            .main-content {
                margin-left: 0;
            }

            .sidebar-toggle {
                display: inline-flex;
            }
        }

        @media (max-width: 768px) {
            .page-content {
                padding: 16px;
            }

            .top-header {
                padding: 14px 16px;
            }
        }

        @media (max-width: 1100px) {
            .admin-kpis {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 640px) {
            .admin-kpis {
                grid-template-columns: 1fr;
            }
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <div class="sidebar-backdrop" id="js-sidebar-backdrop"></div>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">SI</div>
            <div>
                <div class="sidebar-brand-text">Sport Insight</div>
                <div class="sidebar-brand-sub">Administration</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="sidebar-label">Gestion</div>

            <a href="{{ path('admin_dashboard') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'admin_dashboard' ? 'active' : '' }}">
                <i class="lucide-layout-dashboard"></i>
                Dashboard
            </a>

            <a href="{{ path('back_entrainement_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'back_entrainement' ? 'active' : '' }}">
                <i class="lucide-dumbbell"></i>
                Entrainement
            </a>

            <a href="{{ path('app_equipe_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_equipe' ? 'active' : '' }}">
                <i class="lucide-users"></i>
                Equipes
            </a>

            <a href="{{ path('back_joueur_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'back_joueur' ? 'active' : '' }}">
                <i class="lucide-user"></i>
                Joueurs
            </a>

            <a href="{{ path('app_matchs_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_matchs' ? 'active' : '' }}">
                <i class="lucide-trophy"></i>
                Matchs
            </a>

            <a href="{{ path('app_product_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_product' ? 'active' : '' }}">
                <i class="lucide-shirt"></i>
                Equipement
            </a>

            <a href="{{ path('back_annonce_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'back_annonce' ? 'active' : '' }}">
                <i class="lucide-message-square"></i>
                Annonces
            </a>

            <a href="{{ path('admin_user_moderation_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'admin_user_moderation' ? 'active' : '' }}">
                <i class="lucide-shield"></i>
                Utilisateurs & moderation
            </a>

            <a href="{{ path('app_order_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_order' ? 'active' : '' }}">
                <i class="lucide-cart"></i>
                Commandes
            </a>

            <a href="{{ path('back_sponsoring_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'back_sponsoring' ? 'active' : '' }}">
                <i class="lucide-briefcase"></i>
                Sponsoring
            </a>
        </nav>

        <div class="sidebar-footer">
            <a href="{{ path('front_home') }}" class="sidebar-link">
                <i class="lucide-external-link"></i>
                Voir le site
            </a>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="main-content">
        <header class="top-header">
            <h1>{% block page_title %}Dashboard{% endblock %}</h1>
            <div class="top-header-actions">
                <button type="button" class="sidebar-toggle" id="js-sidebar-toggle" aria-label="Toggle sidebar">
                    <i class="lucide-menu"></i>
                </button>
                <div class="theme-controls">
                    <a href="{{ path('app_theme_set', {mode: 'light'}) }}" class="btn btn-sm btn-outline-secondary js-theme-switch {{ currentTheme == 'light' ? 'active' : '' }}" data-theme-mode="light">Light</a>
                    <a href="{{ path('app_theme_set', {mode: 'dark'}) }}" class="btn btn-sm btn-outline-secondary js-theme-switch {{ currentTheme == 'dark' ? 'active' : '' }}" data-theme-mode="dark">Dark</a>
                </div>
                {% block header_actions %}{% endblock %}
                <div class="avatar">{{ app.user and app.user.prenom ? app.user.prenom|first|upper : 'A' }}</div>
            </div>
        </header>

        <main class="page-content">
            {# Flash messages #}
            <div class="mb-16">
                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="stat-card js-flash-message" data-flash-type="{{ type }}" style="border-left:4px solid {% if type in ['danger','error'] %}#ef4444{% elseif type in ['success'] %}#16a34a{% else %}#f59e0b{% endif %}; margin-bottom:12px;">
                            <div style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
                                <div style="font-weight:600;">{{ message }}</div>
                            </div>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>

            {% block body %}{% endblock %}
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            var themeButtons = document.querySelectorAll('.js-theme-switch');
            if (!themeButtons.length) {
                return;
            }

            function isValidMode(mode) {
                return mode === 'light' || mode === 'dark';
            }

            function getStoredMode() {
                try {
                    var stored = localStorage.getItem('theme_mode')
                        || localStorage.getItem('admin_theme_mode')
                        || localStorage.getItem('front_theme_mode');
                    return isValidMode(stored) ? stored : null;
                } catch (e) {
                    return null;
                }
            }

            function preferredSystemMode() {
                return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }

            function resolveInitialMode() {
                var stored = getStoredMode();
                if (stored) {
                    return stored;
                }

                var htmlTheme = document.documentElement.getAttribute('data-theme');
                if (isValidMode(htmlTheme)) {
                    return htmlTheme;
                }

                return preferredSystemMode();
            }

            function persistMode(mode) {
                try {
                    localStorage.setItem('theme_mode', mode);
                    localStorage.setItem('admin_theme_mode', mode);
                    localStorage.setItem('front_theme_mode', mode);
                } catch (e) {}
            }

            function applyTheme(mode, persist) {
                document.documentElement.setAttribute('data-theme', mode);

                if (persist !== false) {
                    persistMode(mode);
                }

                themeButtons.forEach(function (btn) {
                    btn.classList.toggle('active', btn.dataset.themeMode === mode);
                });
            }

            applyTheme(resolveInitialMode(), false);

            themeButtons.forEach(function (btn) {
                btn.addEventListener('click', function (event) {
                    event.preventDefault();
                    var mode = btn.dataset.themeMode;
                    if (!isValidMode(mode)) {
                        return;
                    }

                    applyTheme(mode, true);

                    fetch(btn.href, { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                        .catch(function () {
                            window.location.href = btn.href;
                        });
                });
            });
        })();
    </script>
    <script>
        (function () {
            var sidebar = document.querySelector('.sidebar');
            var toggle = document.getElementById('js-sidebar-toggle');
            var backdrop = document.getElementById('js-sidebar-backdrop');

            if (!sidebar || !toggle || !backdrop) {
                return;
            }

            function setOpen(open) {
                sidebar.classList.toggle('open', open);
                backdrop.classList.toggle('show', open);
                document.body.style.overflow = open ? 'hidden' : '';
            }

            toggle.addEventListener('click', function () {
                setOpen(!sidebar.classList.contains('open'));
            });

            backdrop.addEventListener('click', function () {
                setOpen(false);
            });

            window.addEventListener('resize', function () {
                if (window.innerWidth > 991) {
                    setOpen(false);
                }
            });
        })();
    </script>
    {{ importmap('app') }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    {% include '_partials/global_form_ux.html.twig' %}
    {% if app.debug %}
        <script>
            (function () {
                var tries = 0;
                var timer = setInterval(function () {
                    tries++;
                    var toolbar = document.querySelector('.sf-toolbar.sf-display-none');
                    if (!toolbar) {
                        if (tries > 30) {
                            clearInterval(timer);
                        }
                        return;
                    }

                    toolbar.classList.remove('sf-display-none');
                    var main = toolbar.querySelector('[id^="sfToolbarMainContent-"]');
                    var clearer = toolbar.querySelector('[id^="sfToolbarClearer-"]');
                    var mini = toolbar.querySelector('[id^="sfMiniToolbar-"]');

                    if (main && !main.style.display) {
                        main.style.display = 'block';
                    }
                    if (clearer && !clearer.style.display) {
                        clearer.style.display = 'block';
                    }
                    if (mini && !mini.style.display) {
                        mini.style.display = 'none';
                    }

                    clearInterval(timer);
                }, 200);
            })();
        </script>
    {% endif %}
    {% block javascripts %}{% endblock %}
</body>
</html>
