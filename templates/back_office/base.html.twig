{% set currentTheme = app.request.session.get('theme_mode', 'light') %}
<!DOCTYPE html>
<html lang="fr" data-theme="{{ currentTheme }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin - sport insight{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://unpkg.com/lucide-static@latest/font/lucide.css" rel="stylesheet">
    <script>
        (function () {
            try {
                var savedTheme = localStorage.getItem('admin_theme_mode');
                if (savedTheme === 'light' || savedTheme === 'dark') {
                    document.documentElement.setAttribute('data-theme', savedTheme);
                }
            } catch (e) {}
        })();
    </script>

    <style>
        :root {
            --sidebar-bg: #111827;
            --sidebar-hover: #1f2937;
            --sidebar-text: #9ca3af;
            --sidebar-active: #10b981;
            --header-bg: #ffffff;
            --body-bg: #f3f4f6;
            --card-bg: #ffffff;
            --text-dark: #111827;
            --text-muted: #6b7280;
            --border-color: #e5e7eb;
            --primary: #10b981;
            --primary-hover: #059669;
            --table-head-bg: #f9fafb;
            --table-row-hover: #f9fafb;
            --header-control-bg: #f8fafc;
            --header-control-text: #334155;
            --input-bg: #ffffff;
            --input-text: #111827;
            --input-border: #d1d5db;
            --link-color: #2563eb;
            --pagination-bg: #ffffff;
            --pagination-text: #334155;
        }

        [data-theme="dark"] {
            --sidebar-bg: #020617;
            --sidebar-hover: #0f172a;
            --sidebar-text: #94a3b8;
            --sidebar-active: #34d399;
            --header-bg: #0b1220;
            --body-bg: #020617;
            --card-bg: #111827;
            --text-dark: #e2e8f0;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --primary: #10b981;
            --primary-hover: #059669;
            --table-head-bg: #0f172a;
            --table-row-hover: #1e293b;
            --header-control-bg: #0f172a;
            --header-control-text: #cbd5e1;
            --input-bg: #0b1220;
            --input-text: #e2e8f0;
            --input-border: #334155;
            --link-color: #93c5fd;
            --pagination-bg: #0b1220;
            --pagination-text: #cbd5e1;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--body-bg);
            color: var(--text-dark);
            min-height: 100vh;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 260px;
            height: 100vh;
            background: var(--sidebar-bg);
            padding: 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(255,255,255,0.06);
        }

        .sidebar-brand {
            padding: 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sidebar-brand-icon {
            width: 40px;
            height: 40px;
            background: var(--primary);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 18px;
            color: #fff;
        }

        .sidebar-brand-text {
            color: #fff;
            font-size: 16px;
            font-weight: 600;
        }

        .sidebar-brand-sub {
            color: var(--sidebar-text);
            font-size: 12px;
        }

        .sidebar-nav {
            padding: 16px 12px;
            flex: 1;
            overflow-y: auto;
        }

        .sidebar-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--sidebar-text);
            padding: 12px 12px 8px;
            font-weight: 600;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            border-radius: 8px;
            color: var(--sidebar-text);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.15s;
            margin-bottom: 2px;
        }

        .sidebar-link:hover {
            background: var(--sidebar-hover);
            color: #fff;
        }

        .sidebar-link.active {
            background: rgba(16, 185, 129, 0.12);
            color: var(--sidebar-active);
        }

        .sidebar-link i {
            font-size: 18px;
            width: 20px;
            text-align: center;
        }

        .sidebar-footer {
            padding: 16px 12px;
            border-top: 1px solid rgba(255,255,255,0.06);
        }

        /* ===== MAIN CONTENT ===== */
        .main-content {
            margin-left: 260px;
            min-height: 100vh;
        }

        .main-content.no-sidebar {
            margin-left: 0;
        }

        .top-header {
            background: var(--header-bg);
            border-bottom: 1px solid var(--border-color);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 900;
        }

        .top-header h1 {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-dark);
        }

        .top-header-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .page-content {
            padding: 32px;
        }

        .admin-kpis {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 16px;
            margin-bottom: 20px;
        }

        /* ===== CARDS ===== */
        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 18px;
            min-height: 132px;
        }

        .stat-card-label {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 500;
            margin-bottom: 8px;
        }

        .stat-card-value {
            font-size: 28px;
            font-weight: 700;
            color: var(--text-dark);
        }

        .stat-card-sub {
            font-size: 12px;
            color: var(--primary);
            margin-top: 4px;
        }

        /* ===== TABLE ===== */
        .data-table {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow: hidden;
        }

        .data-table-header {
            padding: 20px 24px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .data-table-header h3 {
            font-size: 16px;
            font-weight: 600;
        }

        .muted {
            color: var(--text-muted);
            font-size: 13px;
            margin: 0;
        }

        .toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .toolbar form {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .data-table table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table thead th {
            padding: 12px 24px;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            font-weight: 600;
            background: var(--table-head-bg);
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        .data-table tbody td {
            padding: 14px 24px;
            font-size: 14px;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            color: var(--text-dark);
        }

        .data-table tbody tr:last-child td {
            border-bottom: none;
        }

        .data-table tbody tr:hover {
            background: var(--table-row-hover);
        }

        /* ===== BADGES ===== */
        .badge-success {
            background: rgba(16, 185, 129, 0.1);
            color: #059669;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-warning {
            background: rgba(245, 158, 11, 0.1);
            color: #d97706;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-danger {
            background: rgba(239, 68, 68, 0.1);
            color: #dc2626;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-info {
            background: rgba(59, 130, 246, 0.1);
            color: #2563eb;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
        }

        /* ===== BUTTONS ===== */
        .btn-primary {
            background: var(--primary) !important;
            border-color: var(--primary) !important;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            padding: 8px 16px;
        }
        .btn-add-product {
            padding: 8px 14px;
            font-size: 13px;
            font-weight: 600;
        }

        .btn-primary:hover {
            background: var(--primary-hover) !important;
            border-color: var(--primary-hover) !important;
        }

        .btn-outline-secondary {
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            padding: 8px 16px;
            background: var(--header-control-bg) !important;
            color: var(--header-control-text) !important;
            border-color: var(--border-color) !important;
        }

        .data-table a {
            color: var(--link-color);
        }

        .data-table .form-control,
        .data-table .form-select,
        .page-content .form-control,
        .page-content .form-select {
            background: var(--input-bg) !important;
            color: var(--input-text) !important;
            border-color: var(--input-border) !important;
        }

        .data-table .form-control::placeholder {
            color: var(--text-muted);
            opacity: 1;
        }

        .page-content .pagination .page-link {
            background: var(--pagination-bg);
            color: var(--pagination-text);
            border-color: var(--border-color);
        }

        .page-content .pagination .page-item.active .page-link {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
        }

        .theme-controls {
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .theme-controls .btn.active {
            background: var(--primary) !important;
            color: #fff !important;
            border-color: var(--primary) !important;
        }

        .admin-form-shell {
            max-width: 1100px;
        }

        .page-content .form-label,
        .page-content label {
            color: var(--text-dark);
        }

        .muted-soft {
            color: var(--text-muted) !important;
        }

        /* ===== AVATAR ===== */
        .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--primary);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 14px;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .sidebar { display: none; }
            .main-content { margin-left: 0; }
            .page-content { padding: 16px; }
        }

        @media (max-width: 1100px) {
            .admin-kpis {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 640px) {
            .admin-kpis {
                grid-template-columns: 1fr;
            }
        }
    </style>
    {% block stylesheets %}{% endblock %}
            <style>
                /* Shared action buttons used across back-office tables */
                .action-btn { width:44px; height:44px; display:inline-flex; align-items:center; justify-content:center; border-radius:8px; padding:0; margin:0 6px; border:none; box-shadow:0 1px 2px rgba(0,0,0,0.06); transition:transform .08s ease, box-shadow .08s ease; }
                .action-btn i { font-size:1.15rem; }
                .action-view { background:#00d2ff; color:#002b33; }
                .action-edit { background:#ffd24d; color:#2b2b2b; }
                .action-delete { background:#e24b5a; color:#fff; }
                .action-btn:hover { transform:translateY(-2px); box-shadow:0 6px 12px rgba(0,0,0,0.12); }

                /* Avatar image style to match .avatar element */
                .avatar-img { width:36px; height:36px; border-radius:50%; object-fit:cover; display:inline-block; }
            </style>
</head>
<body>

    <!-- SIDEBAR -->
    {% block sidebar %}
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">FC</div>
            <div>
                <div class="sidebar-brand-text">sport insight</div>
                <div class="sidebar-brand-sub">Administration</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="sidebar-label">Gestion</div>

           
            {% if app.user %}
            <a href="{{ path('app_user_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_user' ? 'active' : '' }}">
                <i class="lucide-users"></i>
                Utilisateurs
            </a>
            {% else %}
            <a href="{{ path('app_login') }}"
               class="sidebar-link">
                <i class="lucide-users"></i>
                Utilisateurs
            </a>
            {% endif %}

           

            <a href="{{ path('app_annonce_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_annonce' ? 'active' : '' }}">
                <i class="lucide-megaphone"></i>
                Annonces
            </a>

            <a href="{{ path('app_matchs_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_matchs' ? 'active' : '' }}">
                <i class="lucide-trophy"></i>
                Matchs
            </a>

            <a href="{{ path('app_sponsor_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_sponsor' ? 'active' : '' }}">
                <i class="lucide-handshake"></i>
                Sponsors
            </a>

            <a href="{{ path('app_contrat_sponsor_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_contrat_sponsor' ? 'active' : '' }}">
                <i class="lucide-file-signature"></i>
                Contrats Sponsor
            </a>

            <a href="{{ path('app_product_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_product' ? 'active' : '' }}">
                <i class="lucide-shirt"></i>
                Produits
            </a>

            <a href="{{ path('app_order_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_order' ? 'active' : '' }}">
                <i class="lucide-shopping-bag"></i>
                Commandes
            </a>

            <a href="{{ path('app_equipe_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_equipe' ? 'active' : '' }}">
                <i class="lucide-users"></i>
                Equipes
            </a>

            <a href="{{ path('back_entrainement_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'back_entrainement' ? 'active' : '' }}">
                <i class="lucide-dumbbell"></i>
                Entrainements
            </a>

            <a href="{{ path('back_evaluation_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'back_evaluation' ? 'active' : '' }}">
                <i class="lucide-clipboard-check"></i>
                Evaluations
            </a>

            <a href="{{ path('back_participation_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'back_participation' ? 'active' : '' }}">
                <i class="lucide-user-check"></i>
                Participations
            </a>

            <a href="{{ path('app_order_index') }}"
               class="sidebar-link {{ app.request.get('_route') starts with 'app_order' ? 'active' : '' }}">
                <i class="lucide-cart"></i>
                Commandes
            </a>
        </nav>

        <div class="sidebar-footer">
            <a href="{{ path('front_home') }}" class="sidebar-link">
                <i class="lucide-external-link"></i>
                Voir le site
            </a>
        </div>
    </aside>
    {% endblock %}

    <!-- MAIN -->
    <div class="main-content {% block main_content_class %}{% endblock %}">
        <header class="top-header">
            <h1>{% block page_title %}Dashboard{% endblock %}</h1>
            <div class="top-header-actions">
                    {% block header_actions %}{% endblock %}

                    {# Authentication button on the right: shows login if anonymous, else user name and logout #}
                    <div class="d-flex align-items-center" style="gap:10px">
                        {% if app.user %}
                            <div class="me-2 text-muted">{{ app.user.nomComplet }}</div>
                            <a href="{{ path('app_user_index') }}" class="btn btn-sm btn-outline-secondary">Utilisateurs</a>
                            <form method="post" action="{{ path('app_logout') }}" style="display:inline;margin:0">
                                <button class="btn btn-sm btn-danger">Se déconnecter</button>
                            </form>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn btn-sm btn-primary">Se connecter</a>
                        {% endif %}

                        {% if app.user and app.user.photo %}
                            <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" alt="avatar" class="avatar-img">
                        {% else %}
                            <div class="avatar">A</div>
                        {% endif %}
                    </div>
                </div>
        </header>

        <main class="page-content">
            {# Flash messages #}
            <div class="mb-16">
                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="stat-card js-flash-message" data-flash-type="{{ type }}" style="border-left:4px solid {% if type in ['danger','error'] %}#ef4444{% elseif type in ['success'] %}#16a34a{% else %}#f59e0b{% endif %}; margin-bottom:12px;">
                            <div style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
                                <div style="font-weight:600;">{{ message }}</div>
                            </div>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>

            {% block body %}{% endblock %}
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            var themeButtons = document.querySelectorAll('.js-theme-switch');
            if (!themeButtons.length) {
                return;
            }

            function applyTheme(mode) {
                document.documentElement.setAttribute('data-theme', mode);
                try {
                    localStorage.setItem('admin_theme_mode', mode);
                } catch (e) {}

                themeButtons.forEach(function (btn) {
                    btn.classList.toggle('active', btn.dataset.themeMode === mode);
                });
            }

            themeButtons.forEach(function (btn) {
                btn.addEventListener('click', function (event) {
                    event.preventDefault();
                    var mode = btn.dataset.themeMode;
                    if (!mode) {
                        return;
                    }

                    applyTheme(mode);

                    fetch(btn.href, { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                        .catch(function () {
                            window.location.href = btn.href;
                        });
                });
            });
        })();
    </script>
    {{ importmap('app') }}
    {% include '_partials/global_form_ux.html.twig' %}
    {% block javascripts %}{% endblock %}
</body>
</html>
