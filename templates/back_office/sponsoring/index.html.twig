                {% if contrats|length > 0 %}
                    {% for contrat in contrats %}
                        <tr>
                            <td>
                                {% set logo = contrat.sponsor.logoName ?? contrat.sponsor.logo %}
                                {% if logo %}
                                    <img src="{{ asset('uploads/logos/' ~ logo) }}" alt="{{ contrat.sponsor.nom }}" style="height:32px; width:32px; object-fit:contain; border-radius:4px; background:#fff; padding:2px;" onerror="this.onerror=null;this.src='{{ asset('uploads/sponsors/' ~ logo) }}';">
                                {% else %}
                                    <div style="height:32px; width:32px; display:flex; align-items:center; justify-content:center; background:var(--body-bg); border-radius:4px; color:var(--text-muted); font-weight:700; font-size:12px;">{{ contrat.sponsor.nom[0] ?? 'S' }}</div>
                                {% endif %}
                            </td>
                            <td><strong>{{ contrat.sponsor.nom }}</strong></td>
                            <td style="font-weight:600; color:var(--primary);">{{ contrat.montant }} DT</td>
                            <td>
                                {% if contrat.statutPaiement == 'Payé' %}
                                    <span class="badge-success" style="font-size: 11px;">Payé ✅</span>
                                {% else %}
                                    <span class="badge-danger" style="font-size: 11px;">En attente ⏳</span>
                                {% endif %}
                            </td>
                            <td><span class="muted">{{ contrat.dateDebut ? contrat.dateDebut|date('d/m/Y') : '-' }}</span></td>
                            <td><span class="muted">{{ contrat.dateFin ? contrat.dateFin|date('d/m/Y') : '-' }}</span></td>
                            <td>{{ contrat.equipe.nom ?? '-' }}</td>
                            <td>
                                {% if contrat.isExpired() %}
                                    <span class="badge-danger">Expiré</span>
                                {% else %}
                                    <span class="badge-success">Actif</span>
                                {% endif %}
                            </td>
                            <td>
                                <div style="display: flex; gap: 4px; align-items: center; flex-wrap: wrap;">
                                    {% if contrat.statutPaiement != 'Payé' %}
                                        <a href="{{ path('app_payment_checkout', {'id': contrat.id}) }}" class="btn btn-sm" style="background:var(--primary); color:white; border:none; border-radius:4px; padding:4px 8px; font-weight:600; text-decoration:none;">💳 Lien Stripe</a>
                                    {% endif %}
                                    <a href="{{ path('app_contrat_sponsor_edit', {'id': contrat.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                                    <a href="{{ path('app_contrat_sponsor_pdf', {'id': contrat.id}) }}" class="btn btn-sm btn-outline-secondary" target="_blank">PDF</a>
                                    <form method="post" action="{{ path('app_contrat_sponsor_delete', {'id': contrat.id}) }}" onsubmit="return confirm('Êtes-vous sûr ?');" style="margin:0;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ contrat.id) }}">
                                        <button type="submit" class="btn btn-sm" style="color:var(--danger); background:none; border:none; padding:4px 8px; font-weight:600;">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                {% else %}
