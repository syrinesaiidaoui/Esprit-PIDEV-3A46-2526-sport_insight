{% extends 'back_office/base.html.twig' %}

{% block title %}Admin - Joueurs{% endblock %}
{% block page_title %}Joueurs{% endblock %}

{% block header_actions %}
    <a href="{{ path('back_joueur_new') }}" class="btn btn-primary btn-sm">
        <i class="lucide-plus" style="font-size:14px"></i> Ajouter un joueur
    </a>
{% endblock %}

{% block body %}
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-card-label">Total joueurs</div>
                <div class="stat-card-value">{{ joueurs|length }}</div>
                <div class="stat-card-sub">Tous les effectifs</div>
            </div>
        </div>
    </div>

    {% if app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {% for message in app.flashes('success') %}
                {{ message }}
            {% endfor %}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endif %}

    <div class="data-table">
        <div class="data-table-header">
            <h3>Liste des joueurs</h3>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Photo</th>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Date de naissance</th>
                    <th>Numéro</th>
                    <th>Équipe</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% if joueurs is not empty %}
                    {% for joueur in joueurs %}
                        <tr>
                            <td>
                                {% if joueur.image %}
                                    <img src="{{ media_url(joueur.image, 'joueurs') }}" alt="{{ joueur.prenom }} {{ joueur.nom }}" style="max-height: 40px; max-width: 40px; border-radius: 4px;">
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>{{ joueur.nom }}</td>
                            <td>{{ joueur.prenom }}</td>
                            <td>{{ joueur.dateNaissance|date('d/m/Y') }}</td>
                            <td>
                                <span class="badge bg-primary">{{ joueur.numero }}</span>
                            </td>
                            <td>{{ joueur.equipe.nom }}</td>
                            <td>
                                <a href="{{ path('back_joueur_show', {'id': joueur.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                                <a href="{{ path('back_joueur_edit', {'id': joueur.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                                <form method="post" action="{{ path('back_joueur_delete', {'id': joueur.id}) }}" style="display: inline-block;" onsubmit="return confirm('Êtes-vous sûr?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ joueur.id) }}">
                                    <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center">Aucun joueur trouvé</td>
                    </tr>
                {% endif %}
            </tbody>
        </table>
    </div>
{% endblock %}
