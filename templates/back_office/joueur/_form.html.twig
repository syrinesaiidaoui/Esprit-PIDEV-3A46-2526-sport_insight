{{ form_start(form, { 'attr': { 'enctype': 'multipart/form-data' } }) }}
    <div class="card">
        <div class="card-body">
            <div class="form-group mb-3">
                {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Nom du joueur'}}) }}
                {{ form_errors(form.nom) }}
            </div>

            <div class="form-group mb-3">
                {{ form_label(form.prenom, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.prenom, {'attr': {'class': 'form-control', 'placeholder': 'Prénom du joueur'}}) }}
                {{ form_errors(form.prenom) }}
            </div>

            <div class="form-group mb-3">
                {{ form_label(form.dateNaissance, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.dateNaissance, {'attr': {'class': 'form-control', 'type': 'date'}}) }}
                {{ form_errors(form.dateNaissance) }}
            </div>

            <div class="form-group mb-3">
                {{ form_label(form.numero, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.numero, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.numero) }}
            </div>

            <div class="form-group mb-3">
                {{ form_label(form.image, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.image, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.image) }}
                <small class="text-muted">Formats acceptés: JPEG, PNG, GIF, WebP (max 5MB)</small>
            </div>

            <div class="form-group mb-3">
                {{ form_label(form.equipe, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.equipe, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.equipe) }}
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
                <a href="{{ path('back_joueur_index') }}" class="btn btn-secondary">Retour</a>
            </div>
        </div>
    </div>
{{ form_end(form) }}
