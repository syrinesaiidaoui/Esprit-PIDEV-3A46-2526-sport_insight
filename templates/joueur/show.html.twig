{% extends 'front_office/base.html.twig' %}

{% block title %}{{ joueur.prenom }} {{ joueur.nom }} - Sport Insight{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .player-detail-hero {
            position: relative;
            max-width: 1320px;
            margin: 16px auto 0;
            padding: clamp(16px, 3vw, 24px);
            border-radius: 28px;
            background: radial-gradient(circle at 20% 24%, rgba(52, 211, 153, 0.22), rgba(2, 6, 23, 0) 46%),
                        radial-gradient(circle at 78% 78%, rgba(96, 165, 250, 0.2), rgba(2, 6, 23, 0) 50%),
                        var(--hero-grad);
            overflow: hidden;
        }

        .player-detail-hero__card {
            position: relative;
            border-radius: 22px;
            border: 1px solid rgba(226, 232, 240, 0.26);
            overflow: hidden;
            padding: clamp(22px, 4vw, 34px);
            color: #f8fafc;
            isolation: isolate;
            box-shadow: var(--soft-shadow);
        }

        .player-detail-hero__card::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: url('{{ asset('images/players.jpg') }}');
            background-size: cover;
            background-position: center;
            transform: scale(1.04);
            z-index: 0;
        }

        .player-detail-hero__card::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, rgba(2, 6, 23, 0.84) 0%, rgba(2, 6, 23, 0.72) 46%, rgba(5, 150, 105, 0.58) 100%);
            z-index: 1;
        }

        .player-detail-hero__card > * {
            position: relative;
            z-index: 2;
        }

        .player-detail-hero__eyebrow {
            display: inline-flex;
            align-items: center;
            border-radius: 999px;
            padding: 6px 12px;
            border: 1px solid rgba(226, 232, 240, 0.34);
            background: rgba(2, 6, 23, 0.48);
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .player-detail-hero__card h1 {
            margin: 14px 0 0;
            font-size: clamp(30px, 5vw, 46px);
            line-height: 1.15;
            color: #f8fafc;
        }

        .player-detail-hero__card p {
            margin: 12px 0 0;
            max-width: 760px;
            color: #dbeafe;
            font-size: 16px;
        }

        .player-detail-shell {
            display: grid;
            gap: 18px;
        }

        .player-profile-card,
        .player-team-card {
            border-radius: 22px;
            border: 1px solid var(--border-color);
            background: var(--card-bg);
            box-shadow: var(--soft-shadow);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            overflow: hidden;
        }

        .player-profile-grid {
            display: grid;
            grid-template-columns: minmax(220px, 290px) 1fr;
            gap: 22px;
            padding: 22px;
        }

        .player-photo-panel {
            border-radius: 18px;
            border: 1px solid var(--border-color);
            background: var(--surface);
            padding: 16px;
            min-height: 300px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .player-photo-inner {
            width: min(230px, 100%);
            aspect-ratio: 1 / 1;
            border-radius: 18px;
            border: 1px solid var(--border-color);
            background: var(--card-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .player-photo-inner img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .player-photo-fallback {
            width: 104px;
            height: 104px;
            border-radius: 50%;
            border: 1px solid rgba(16, 185, 129, 0.3);
            background: rgba(16, 185, 129, 0.12);
            color: var(--primary);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
        }

        .player-info-panel {
            display: grid;
            align-content: start;
            gap: 14px;
        }

        .player-info-title {
            margin: 0;
            font-size: 34px;
            line-height: 1.2;
            color: var(--text-main);
        }

        .player-info-subtitle {
            margin: 0;
            font-size: 14px;
            color: var(--text-soft);
        }

        .player-chip-row {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .player-chip {
            border-radius: 999px;
            border: 1px solid var(--border-color);
            background: var(--surface);
            padding: 5px 11px;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-soft);
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .player-chip i {
            color: var(--primary);
            font-size: 13px;
        }

        .player-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 10px;
        }

        .player-info-item {
            border-radius: 14px;
            border: 1px solid var(--border-color);
            background: var(--surface);
            padding: 12px 13px;
            display: grid;
            gap: 5px;
        }

        .player-info-item span {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
            color: var(--text-soft);
        }

        .player-info-item strong {
            font-size: 15px;
            color: var(--text-main);
            line-height: 1.35;
            word-break: break-word;
        }

        .player-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .player-btn {
            min-height: 42px;
            padding: 0 14px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 700;
            border: 1px solid transparent;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            transition: transform .2s ease, box-shadow .2s ease, background-color .2s ease, border-color .2s ease;
        }

        .player-btn--primary {
            background: linear-gradient(135deg, #34d399, #10b981);
            color: #f8fafc;
            border-color: rgba(16, 185, 129, 0.35);
            box-shadow: 0 12px 22px rgba(16, 185, 129, 0.2);
        }

        .player-btn--primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 26px rgba(16, 185, 129, 0.3);
            color: #f8fafc;
        }

        .player-btn--ghost {
            border-color: var(--border-color);
            background: var(--surface);
            color: var(--text-main);
        }

        .player-btn--ghost:hover {
            border-color: rgba(16, 185, 129, 0.55);
            background: rgba(16, 185, 129, 0.1);
            color: var(--text-main);
        }

        .player-team-card__head {
            padding: 18px 20px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            flex-wrap: wrap;
        }

        .player-team-card__head h2 {
            margin: 0;
            font-size: 25px;
            color: var(--text-main);
        }

        .player-team-card__badge {
            border-radius: 999px;
            border: 1px solid var(--border-color);
            background: var(--surface);
            padding: 5px 11px;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-soft);
        }

        .player-team-card__body {
            padding: 18px 20px;
            display: grid;
            gap: 12px;
        }

        .player-team-mini {
            display: grid;
            grid-template-columns: 72px 1fr;
            gap: 12px;
            align-items: center;
            border-radius: 14px;
            border: 1px solid var(--border-color);
            background: var(--surface);
            padding: 12px;
        }

        .player-team-mini__logo {
            width: 72px;
            height: 72px;
            border-radius: 14px;
            border: 1px solid var(--border-color);
            background: var(--card-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .player-team-mini__logo img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .player-team-mini__fallback {
            font-size: 24px;
            font-weight: 800;
            color: var(--text-soft);
        }

        .player-team-mini__name {
            margin: 0;
            font-size: 20px;
            color: var(--text-main);
            line-height: 1.25;
        }

        .player-team-mini__meta {
            margin: 5px 0 0;
            font-size: 13px;
            color: var(--text-soft);
        }

        @media (max-width: 980px) {
            .player-profile-grid {
                grid-template-columns: 1fr;
            }

            .player-photo-panel {
                min-height: 230px;
            }
        }

        @media (max-width: 760px) {
            .player-detail-hero {
                margin-top: 10px;
                border-radius: 20px;
                padding: 12px;
            }

            .player-detail-hero__card {
                border-radius: 18px;
                padding: 18px;
            }

            .player-profile-grid,
            .player-team-card__body {
                padding: 14px;
            }

            .player-info-title {
                font-size: 28px;
            }

            .player-team-mini {
                grid-template-columns: 1fr;
                text-align: center;
            }

            .player-team-mini__logo {
                justify-self: center;
            }
        }
    </style>
{% endblock %}

{% block hero %}
    <section class="player-detail-hero">
        <div class="player-detail-hero__card">
            <span class="player-detail-hero__eyebrow">Player profile</span>
            <h1>{{ joueur.prenom }} {{ joueur.nom }}</h1>
            <p>Fiche complete du joueur, numero, age et rattachement equipe.</p>
        </div>
    </section>
{% endblock %}

{% block body %}
    {% set playerAge = date('now').diff(joueur.dateNaissance).y %}

    <section class="player-detail-shell">
        <article class="player-profile-card">
            <div class="player-profile-grid">
                <div class="player-photo-panel">
                    <div class="player-photo-inner">
                        {% if joueur.image %}
                            <img src="{{ media_url(joueur.image, 'joueurs') }}" alt="{{ joueur.prenom }} {{ joueur.nom }}">
                        {% else %}
                            <span class="player-photo-fallback"><i class="lucide-user-round"></i></span>
                        {% endif %}
                    </div>
                </div>

                <div class="player-info-panel">
                    <div>
                        <h2 class="player-info-title">{{ joueur.prenom }} {{ joueur.nom }}</h2>
                        <p class="player-info-subtitle">Profil joueur et informations principales.</p>
                    </div>

                    <div class="player-chip-row">
                        <span class="player-chip"><i class="lucide-shirt"></i> Numero #{{ joueur.numero }}</span>
                        <span class="player-chip"><i class="lucide-shield"></i> {{ joueur.equipe.nom }}</span>
                    </div>

                    <div class="player-info-grid">
                        <div class="player-info-item">
                            <span><i class="lucide-hash"></i> ID</span>
                            <strong>#{{ joueur.id }}</strong>
                        </div>

                        <div class="player-info-item">
                            <span><i class="lucide-user-round"></i> Nom complet</span>
                            <strong>{{ joueur.prenom }} {{ joueur.nom }}</strong>
                        </div>

                        <div class="player-info-item">
                            <span><i class="lucide-calendar-days"></i> Date de naissance</span>
                            <strong>{{ joueur.dateNaissance|date('d/m/Y') }}</strong>
                        </div>

                        <div class="player-info-item">
                            <span><i class="lucide-cake"></i> Age</span>
                            <strong>{{ playerAge }} ans</strong>
                        </div>

                        <div class="player-info-item">
                            <span><i class="lucide-shield-check"></i> Equipe</span>
                            <strong>{{ joueur.equipe.nom }}</strong>
                        </div>

                        <div class="player-info-item">
                            <span><i class="lucide-shirt"></i> Numero de maillot</span>
                            <strong>#{{ joueur.numero }}</strong>
                        </div>
                    </div>

                    <div class="player-actions">
                        <a href="{{ path('app_joueurs_index') }}" class="player-btn player-btn--ghost">
                            <i class="lucide-arrow-left"></i>
                            Retour aux joueurs
                        </a>
                        <a href="{{ path('app_joueurs_by_equipe', {'equipeId': joueur.equipe.id}) }}" class="player-btn player-btn--primary">
                            <i class="lucide-users-round"></i>
                            Voir l'effectif
                        </a>
                    </div>
                </div>
            </div>
        </article>

        <article class="player-team-card">
            <header class="player-team-card__head">
                <h2>Equipe du joueur</h2>
                <span class="player-team-card__badge">ID equipe #{{ joueur.equipe.id }}</span>
            </header>

            <div class="player-team-card__body">
                <article class="player-team-mini">
                    <div class="player-team-mini__logo">
                        {% if joueur.equipe.image %}
                            <img src="{{ media_url(joueur.equipe.image, 'equipes') }}" alt="{{ joueur.equipe.nom }}">
                        {% else %}
                            <span class="player-team-mini__fallback">{{ joueur.equipe.nom|slice(0, 1)|upper }}</span>
                        {% endif %}
                    </div>

                    <div>
                        <h3 class="player-team-mini__name">{{ joueur.equipe.nom }}</h3>
                        <p class="player-team-mini__meta">
                            Coach: {{ joueur.equipe.coach ?: 'Non renseigne' }}
                        </p>
                    </div>
                </article>

                <div class="player-actions">
                    <a href="{{ path('app_front_equipes_show', {'id': joueur.equipe.id}) }}" class="player-btn player-btn--ghost">
                        <i class="lucide-shield"></i>
                        Ouvrir la fiche equipe
                    </a>
                </div>
            </div>
        </article>
    </section>
{% endblock %}
