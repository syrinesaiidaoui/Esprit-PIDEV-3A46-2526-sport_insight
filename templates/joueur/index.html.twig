{% extends 'front_office/base.html.twig' %}

{% block title %}Joueurs - Sport Insight{% endblock %}

{% block body %}


    <!-- ...existing HTML content for joueurs... (all joueurs-section, search, grid, etc.) ... -->

    <!-- Floating Chatbot Button (at end of body) -->
    <button id="aiChatBubbleBtn" title="Chat IA" style="padding:0; background:none; border:none; position: fixed; right: 32px; bottom: 32px; z-index: 1001;">
        <img src="{{ asset('images/logo chatbot.png') }}" alt="Chatbot" style="width:60px; height:60px; border-radius:50%; box-shadow:0 4px 16px rgba(16,185,129,0.18); object-fit:cover; display:block;">
    </button>
    <!-- Chatbot Popup -->
    <div id="aiChatPopup" style="border-radius: 18px; box-shadow: 0 8px 40px #10b98133; overflow: hidden; position: fixed; right: 32px; bottom: 100px; width: 420px; max-width: 98vw; height: 540px; max-height: 90vh; background: white; display: none; flex-direction: column; z-index: 1002;">
        <div id="aiChatPopupHeader" style="background: linear-gradient(90deg, #10b981 60%, #34d399 100%); border-radius: 18px 18px 0 0; box-shadow: 0 2px 8px #10b98133; display: flex; align-items: center; justify-content: space-between; padding: 18px 22px;">
            <span style="font-size: 20px; display: flex; align-items: center; gap: 10px; font-weight: 700; letter-spacing: 0.5px;">
                <span>Sport Insight AI</span>
            </span>
            <button id="aiChatPopupClose" title="Fermer" style="background: none; border: none; color: white; font-size: 30px; cursor: pointer;">&times;</button>
        </div>
        <div id="aiChatHistory" style="background: #f3f4f6; padding: 22px; min-height: 120px; max-height: 340px; overflow-y: auto; font-size: 16px; box-shadow: 0 1px 4px #10b98122; flex: 1;"></div>
        <form id="aiChatForm" style="display: flex; gap: 10px; padding: 18px; background: #e0f7ef; border-radius: 0 0 18px 18px;">
            <input type="text" id="aiChatInput" placeholder="Posez une question sur les joueurs" autocomplete="off" style="flex:1; padding: 14px 18px; border-radius: 10px; border: 1.5px solid #10b981; font-size: 16px; background: #fff;">
            <button type="submit" id="aiChatSendBtn" style="padding: 12px 28px; border-radius: 10px; background: linear-gradient(90deg, #10b981 60%, #34d399 100%); color: white; border: none; font-weight: 700; font-size: 16px; box-shadow: 0 2px 8px #10b98133; transition: background 0.2s;">Envoyer</button>
        </form>
    </div>

    <script>
        // Chatbot floating logic
        const chatBtn = document.getElementById('aiChatBubbleBtn');
        const chatPopup = document.getElementById('aiChatPopup');
        const chatClose = document.getElementById('aiChatPopupClose');
        // Toggle on click (ouvre/ferme)
        chatBtn.onclick = () => {
            if (chatPopup.style.display === 'flex') {
                chatPopup.style.display = 'none';
            } else {
                chatPopup.style.display = 'flex';
            }
        };
        chatClose.onclick = () => chatPopup.style.display = 'none';
        // Fermer avec Echap
        document.addEventListener('keydown', e => { if (e.key === 'Escape') chatPopup.style.display = 'none'; });

        // Chatbot logic (questions sur les joueurs)
        function isJoueurRelated(question) {
            const q = question.toLowerCase();
            const keywords = [
                'joueur', 'joueurs', 'effectif', 'liste', 'nom', 'prénom', 'âge', 'age', 'poste', 'équipe', 'club', 'stat', 'statistique', 'meilleur', 'gardien', 'attaquant', 'défenseur', 'milieu', 'capitaine', 'nationalité', 'nombre', 'combien', 'présence', 'absent', 'présent', 'remplaçant', 'titulaires', 'remplaçants'
            ];
            return keywords.some(k => k && q.includes(k));
        }
        async function fakeAIResponse(question) {
            const q = question.toLowerCase();
            if (!isJoueurRelated(question)) {
                return "<span style='color:#ef4444'>❌ Je peux répondre uniquement aux questions sur les joueurs ou les équipes. Posez-moi une question sur un joueur, une équipe, une statistique, etc.</span>";
            }
            if (q.includes('meilleur') && (q.includes('buteur') || q.includes('attaquant'))) {
                return "Le meilleur buteur est affiché dans la section statistiques si disponible.";
            }
            if (q.includes('liste') || q.includes('effectif') || (q.includes('tous') && q.includes('joueurs'))) {
                return "La liste complète des joueurs est affichée sur cette page.";
            }
            if (q.includes('nombre') || q.includes('combien')) {
                const count = document.querySelectorAll('.joueur-card').length;
                return `Il y a <b>${count}</b> joueurs affichés sur cette page.`;
            }
            if (q.includes('gardien')) {
                return "Les gardiens sont indiqués dans la fiche de chaque joueur si disponible.";
            }
            if (q.includes('capitaine')) {
                return "Le capitaine de chaque équipe est affiché dans la fiche équipe si disponible.";
            }
            // Réponse générique
            return "C'est une bonne question sur les joueurs ! (Démo IA locale)";
        }
        document.getElementById('aiChatForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const input = document.getElementById('aiChatInput');
            const history = document.getElementById('aiChatHistory');
            const question = input.value.trim();
            if (!question) return;
            history.innerHTML += `<div class='ai-msg-user'><span style='display:inline-block;background:linear-gradient(90deg,#10b981 60%,#34d399 100%);color:white;padding:8px 14px;border-radius:16px 16px 4px 16px;font-size:15px;max-width:80%;box-shadow:0 1px 4px #10b98122;'><b>Vous:</b> ${question}</span></div>`;
            input.value = '';
            history.scrollTop = history.scrollHeight;
            const response = await fakeAIResponse(question);
            history.innerHTML += `<div class='ai-msg-bot'><span style='display:inline-block;background:#e0f7ef;color:#059669;padding:8px 14px;border-radius:16px 16px 16px 4px;font-size:15px;max-width:80%;box-shadow:0 1px 4px #10b98122;'><b>Bot:</b> ${response}</span></div>`;
            history.scrollTop = history.scrollHeight;
        });
    </script>

    <style>
        .joueurs-section {
            max-width: 1300px;
            margin: 0 auto;
            padding: 40px 24px;
        }
        /* ...existing styles... */
    </style>
    <style>

        .filter-buttons {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }

        .filter-btn {
            padding: 10px 16px;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: var(--text-dark);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.15s;
            cursor: pointer;
        }

        .filter-btn:hover,
        .filter-btn.active {
            border-color: var(--primary);
            background: var(--primary);
            color: white;
        }

        .joueurs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 24px;
        }

        .joueur-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            display: flex;
            flex-direction: column;
        }

        .joueur-card:hover {
            border-color: var(--primary);
            box-shadow: 0 12px 32px rgba(16, 185, 129, 0.2);
            transform: translateY(-8px);
        }

        .joueur-image-section {
            position: relative;
            background: linear-gradient(135deg, var(--body-bg) 0%, #f0f9ff 100%);
            padding: 16px;
            min-height: 240px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .joueur-image {
            width: 100%;
            height: 240px;
            object-fit: cover;
            border-radius: 8px;
        }

        .joueur-placeholder {
            font-size: 60px;
            opacity: 0.5;
        }

        .numero-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            background: var(--primary);
            color: white;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 18px;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        }

        .joueur-info {
            padding: 20px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .joueur-name {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 4px;
        }

        .joueur-equipe {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 12px;
        }

        .joueur-stats {
            padding: 12px 0;
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 12px;
            font-size: 13px;
        }

        .stat-row {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
        }

        .stat-label {
            color: var(--text-muted);
        }

        .stat-value {
            font-weight: 600;
            color: var(--text-dark);
        }

        .joueur-btn {
            padding: 10px 12px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .joueur-btn:hover {
            background: var(--primary-hover);
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }

        .empty-state-icon {
            font-size: 60px;
            opacity: 0.5;
            margin-bottom: 16px;
        }

        .equipe-section {
            margin-bottom: 48px;
        }

        .equipe-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 20px;
            padding-bottom: 16px;
            border-bottom: 2px solid var(--primary);
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
            user-select: none;
        }

        .equipe-title:hover {
            opacity: 0.8;
        }

        .equipe-toggle-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.3s ease;
            font-size: 20px;
        }

        .equipe-title.collapsed .equipe-toggle-icon {
            transform: rotate(-90deg);
        }

        .equipe-logo {
            width: 48px;
            height: 48px;
            border-radius: 8px;
            object-fit: contain;
            background: var(--card-bg);
            padding: 4px;
        }

        .joueurs-grid {
            max-height: none;
            overflow: hidden;
            transition: max-height 0.3s ease, opacity 0.3s ease;
            opacity: 1;
        }

        .joueurs-grid.hidden {
            max-height: 0;
            opacity: 0;
        }
    </style>

    <div class="joueurs-section">
        <div class="joueurs-header">
            <h1>Les Joueurs</h1>
        </div>

        <!-- Formulaire de recherche avancée -->
        <div style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 20px; margin-bottom: 24px;">
            <form method="GET" class="search-form">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
                    <div>
                        <label for="search" style="font-size: 13px; font-weight: 600; margin-bottom: 4px; display: block;">Recherche (Nom/Prénom)</label>
                        <input type="text" name="search" id="search" value="{{ search }}" placeholder="Ex: Mbappé..." class="form-control" style="padding: 8px 12px; border: 1px solid var(--border-color); border-radius: 6px;">
                    </div>
                    <div>
                        <label for="equipe" style="font-size: 13px; font-weight: 600; margin-bottom: 4px; display: block;">Équipe</label>
                        <select name="equipe" id="equipe" class="form-control" style="padding: 8px 12px; border: 1px solid var(--border-color); border-radius: 6px;">
                            <option value="">- Toutes les équipes -</option>
                            {% for eq in equipes %}
                                <option value="{{ eq.id }}" {% if equipe and equipe == eq.id %}selected{% endif %}>{{ eq.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div style="display: flex; gap: 8px; margin-top: 12px;">
                    <button type="submit" class="btn btn-primary" style="padding: 8px 16px; border: none; border-radius: 6px; cursor: pointer; font-weight: 600;">🔍 Rechercher</button>
                    <a href="{{ path('app_joueurs_index') }}" class="btn btn-secondary" style="padding: 8px 16px; border: 1px solid var(--border-color); border-radius: 6px; cursor: pointer; font-weight: 600; text-decoration: none; display: inline-block;">Réinitialiser</a>
                </div>
            </form>
        </div>

        {% if joueursGroupes is not empty %}
            {% for equipeId, groupe in joueursGroupes %}
                <div class="equipe-section">
                    <div class="equipe-title collapsed" data-equipe-id="{{ equipeId }}">
                        <span class="equipe-toggle-icon">▼</span>
                        {% if groupe.equipe.image %}
                            <img src="{{ asset('uploads/equipes/' ~ groupe.equipe.image) }}" alt="{{ groupe.equipe.nom }}" class="equipe-logo">
                        {% endif %}
                        {{ groupe.equipe.nom }}
                    </div>
                    <div class="joueurs-grid hidden" data-equipe-grid="{{ equipeId }}">
                        {% for joueur in groupe.joueurs %}
                            <div class="joueur-card">
                                <div class="joueur-image-section">
                                    {% if joueur.image %}
                                        <img src="{{ asset('uploads/joueurs/' ~ joueur.image) }}" alt="{{ joueur.prenom }} {{ joueur.nom }}" class="joueur-image">
                                    {% else %}
                                        <div class="joueur-placeholder">👤</div>
                                    {% endif %}
                                    <div class="numero-badge">{{ joueur.numero }}</div>
                                </div>

                                <div class="joueur-info">
                                    <div class="joueur-name">{{ joueur.prenom }} {{ joueur.nom }}</div>
                                    <div class="joueur-equipe">{{ joueur.equipe.nom }}</div>

                                    <div class="joueur-stats">
                                        <div class="stat-row">
                                            <span class="stat-label">Âge</span>
                                            <span class="stat-value">{{ (now|date('Y')) - (joueur.dateNaissance|date('Y')) }} ans</span>
                                        </div>
                                        <div class="stat-row">
                                            <span class="stat-label">Naissance</span>
                                            <span class="stat-value">{{ joueur.dateNaissance|date('d/m/Y') }}</span>
                                        </div>
                                    </div>

                                    <a href="{{ path('app_joueur_show', {'id': joueur.id}) }}" class="joueur-btn">
                                        Voir le profil
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <div class="empty-state">
                <div class="empty-state-icon">👥</div>
                <h3>Aucun joueur trouvé</h3>
                <p>Les joueurs seront ajoutés bientôt</p>
            </div>
        {% endif %}
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const titles = document.querySelectorAll('.equipe-title');
            
            titles.forEach(title => {
                title.addEventListener('click', function() {
                    const equipeId = this.getAttribute('data-equipe-id');
                    const grid = document.querySelector(`[data-equipe-grid="${equipeId}"]`);
                    
                    if (grid) {
                        this.classList.toggle('collapsed');
                        grid.classList.toggle('hidden');
                    }
                });
            });
        });
    </script>
{% endblock %}
