{% extends 'back_office/base.html.twig' %}

{% block title %}Produits - Admin{% endblock %}
{% block page_title %}Gestion des produits{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_product_new') }}" class="btn btn-primary btn-add-product">Ajouter un produit</a>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .orders-bi-grid {
            display: grid;
            grid-template-columns: repeat(12, minmax(0, 1fr));
            gap: 14px;
            margin: 16px 0 18px;
        }

        .orders-bi-card {
            grid-column: span 4;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 12px;
            box-shadow: var(--card-shadow);
            min-height: 180px;
        }

        .orders-bi-card--wide {
            grid-column: span 8;
        }

        .orders-bi-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 8px;
        }

        .orders-bi-head h3,
        .orders-bi-head h4 {
            margin: 0;
            font-size: 19px;
            color: var(--text-primary);
        }

        .orders-bi-head p {
            margin: 3px 0 0;
            color: var(--text-muted);
            font-size: 13px;
        }

        .orders-bi-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            justify-content: flex-end;
        }

        .orders-bi-chip {
            border-radius: 999px;
            border: 1px solid var(--border-color);
            background: var(--bg-tertiary);
            color: var(--text-secondary);
            padding: 4px 9px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .2px;
        }

        .orders-bi-canvas {
            position: relative;
            height: 180px;
        }

        .orders-bi-canvas--short {
            height: 165px;
        }

        @media (max-width: 1200px) {
            .orders-bi-card,
            .orders-bi-card--wide {
                grid-column: span 12;
            }
        }
    </style>
{% endblock %}

{% block body %}
{% set dashboard = dashboard|default({
    totalProducts: products|length,
    totalOrders: 0,
    pendingOrders: 0,
    revenue: 0,
    lowStockCount: 0,
    outOfStockCount: 0,
    deliveryRate: 0
}) %}
{% set productDashboard = productDashboard|default({
    trend: {labels: [], orders: [], revenue: []},
    categoryStock: {labels: [], values: []},
    stockHealth: {labels: [], values: []},
    topRevenueProducts: {labels: [], values: []},
    topVolumeProducts: {labels: [], values: []}
}) %}

<div class="admin-kpis">
    <div class="stat-card">
        <div class="stat-card-label">Produits</div>
        <div class="stat-card-value">{{ dashboard.totalProducts }}</div>
        <div class="stat-card-sub">Catalogue actif</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">Commandes</div>
        <div class="stat-card-value">{{ dashboard.totalOrders }}</div>
        <div class="stat-card-sub">Activite totale</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">CA valide</div>
        <div class="stat-card-value">{{ dashboard.revenue|number_format(0, ',', ' ') }} USD</div>
        <div class="stat-card-sub">Confirmee/expediee/livree</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">Taux livraison</div>
        <div class="stat-card-value">{{ dashboard.deliveryRate }}%</div>
        <div class="stat-card-sub">Progression commandes</div>
    </div>
</div>

<div class="admin-kpis" style="grid-template-columns:repeat(3,minmax(0,1fr));">
    <div class="stat-card">
        <div class="stat-card-label">En attente</div>
        <div class="stat-card-value">{{ dashboard.pendingOrders }}</div>
        <div class="stat-card-sub">Commandes a traiter</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">Stock faible</div>
        <div class="stat-card-value">{{ dashboard.lowStockCount }}</div>
        <div class="stat-card-sub">Produits <= 5</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">Rupture</div>
        <div class="stat-card-value">{{ dashboard.outOfStockCount }}</div>
        <div class="stat-card-sub">Produits a reapprovisionner</div>
    </div>
</div>

<div class="orders-bi-grid">
    <section class="orders-bi-card orders-bi-card--wide">
        <div class="orders-bi-head">
            <div>
                <h3>Dashboard produits</h3>
                <p>Vue synthétique catalogue et commandes</p>
            </div>
            <div class="orders-bi-meta">
                <span class="orders-bi-chip">{{ dashboard.totalProducts }} produits</span>
                <span class="orders-bi-chip">{{ dashboard.totalOrders }} cmd</span>
                <span class="orders-bi-chip">{{ dashboard.revenue|number_format(2, ',', ' ') }} USD</span>
                <span class="orders-bi-chip">Livraison: {{ dashboard.deliveryRate|number_format(0, ',', ' ') }}%</span>
            </div>
        </div>
        <div class="orders-bi-canvas">
            <canvas id="productsTrendChart"></canvas>
        </div>
    </section>

    <section class="orders-bi-card">
        <div class="orders-bi-head">
            <div>
                <h4>Stock par catégorie</h4>
                <p>Répartition des stocks</p>
            </div>
        </div>
        <div class="orders-bi-canvas orders-bi-canvas--short">
            <canvas id="productsCategoryStockChart"></canvas>
        </div>
    </section>

    <section class="orders-bi-card">
        <div class="orders-bi-head">
            <div>
                <h4>Santé du stock</h4>
                <p>Healthy / Low / Out</p>
            </div>
        </div>
        <div class="orders-bi-canvas orders-bi-canvas--short">
            <canvas id="productsStockHealthChart"></canvas>
        </div>
    </section>

    <section class="orders-bi-card orders-bi-card--wide">
        <div class="orders-bi-head">
            <div>
                <h4>Top CA par produit</h4>
                <p>Revenus sur ventes confirmées/livrées</p>
            </div>
        </div>
        <div class="orders-bi-canvas orders-bi-canvas--short">
            <canvas id="productsTopRevenueChart"></canvas>
        </div>
    </section>
</div>

<div class="data-table">
    <div class="data-table-header">
        <div class="toolbar">
            <div>
                <h3>Produits</h3>
                <p class="muted">Ajouter, modifier, supprimer et suivre le stock</p>
            </div>
            <form method="GET">
                <input type="text" name="search" class="form-control" style="min-width:220px;" placeholder="Nom, categorie, marque..." value="{{ searchTerm|default('') }}">
                <select name="sort" class="form-select">
                    <option value="id" {% if sortBy == 'id' %}selected{% endif %}>ID</option>
                    <option value="name" {% if sortBy == 'name' %}selected{% endif %}>Nom</option>
                    <option value="price" {% if sortBy == 'price' %}selected{% endif %}>Prix</option>
                    <option value="stock" {% if sortBy == 'stock' %}selected{% endif %}>Stock</option>
                    <option value="category" {% if sortBy == 'category' %}selected{% endif %}>Categorie</option>
                </select>
                <select name="order" class="form-select" style="max-width:96px;">
                    <option value="ASC" {% if sortOrder == 'ASC' %}selected{% endif %}>ASC</option>
                    <option value="DESC" {% if sortOrder == 'DESC' %}selected{% endif %}>DESC</option>
                </select>
                <button type="submit" class="btn btn-primary">Filtrer</button>
                <a href="{{ path('app_product_index') }}" class="btn btn-outline-secondary">Reinit.</a>
            </form>
        </div>
    </div>

    <div style="overflow-x:auto;">
        <table>
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Nom</th>
                    <th>Categorie</th>
                    <th>Prix</th>
                    <th>Stock</th>
                    <th>Marque</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for product in products %}
                    <tr>
                        <td>
                            {% if product.image %}
                                {% set imageSrc = product.image starts with 'http://' or product.image starts with 'https://' ? product.image : (product.image starts with 'api/' ? asset(product.image) : (product.image starts with '/api/' ? product.image : asset('uploads/' ~ product.image))) %}
                                <img src="{{ imageSrc }}" alt="{{ product.name }}" style="width:52px;height:52px;object-fit:cover;border-radius:10px;border:1px solid #e5e7eb;">
                            {% else %}
                                <div style="width:52px;height:52px;border-radius:10px;background:var(--table-head-bg);display:flex;align-items:center;justify-content:center;" class="muted-soft">IMG</div>
                            {% endif %}
                        </td>
                        <td style="font-weight:600;">{{ product.name }}</td>
                        <td>{{ product.category ?? '-' }}</td>
                        <td style="font-weight:700;color:var(--primary);">{{ product.price|number_format(2, ',', ' ') }} USD</td>
                        <td>
                            {% if product.stock > 10 %}
                                <span class="badge-success">{{ product.stock }}</span>
                            {% elseif product.stock > 0 %}
                                <span class="badge-warning">{{ product.stock }}</span>
                            {% else %}
                                <span class="badge-danger">0</span>
                            {% endif %}
                        </td>
                        <td>{{ product.brand ?? '-' }}</td>
                        <td>
                            <div style="display:flex; gap:8px; flex-wrap:wrap;">
                                <a href="{{ path('app_product_show', { id: product.id }) }}" class="btn btn-sm btn-info">Voir</a>
                                <a href="{{ path('app_product_edit', { id: product.id }) }}" class="btn btn-sm btn-warning">Modifier</a>
                                <form method="POST" action="{{ path('app_product_delete', { id: product.id }) }}" data-confirm="Supprimer ce produit ?">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" style="padding:40px;text-align:center;" class="muted-soft">Aucun produit trouve</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if totalPages is defined and page is defined and totalPages > 1 %}
        <nav aria-label="Product pagination" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item{% if page == 1 %} disabled{% endif %}">
                    <a class="page-link" href="?search={{ searchTerm|default('') }}&sort={{ sortBy|default('id') }}&order={{ sortOrder|default('ASC') }}&page={{ page-1 }}">Precedent</a>
                </li>
                {% for p in 1..totalPages %}
                    <li class="page-item{% if p == page %} active{% endif %}"><a class="page-link" href="?search={{ searchTerm|default('') }}&sort={{ sortBy|default('id') }}&order={{ sortOrder|default('ASC') }}&page={{ p }}">{{ p }}</a></li>
                {% endfor %}
                <li class="page-item{% if page == totalPages %} disabled{% endif %}">
                    <a class="page-link" href="?search={{ searchTerm|default('') }}&sort={{ sortBy|default('id') }}&order={{ sortOrder|default('ASC') }}&page={{ page+1 }}">Suivant</a>
                </li>
            </ul>
        </nav>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const dashboardData = {{ productDashboard|json_encode|raw }};
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            const textColor = isDark ? '#e2e8f0' : '#0f172a';
            const mutedColor = isDark ? '#94a3b8' : '#475569';
            const gridColor = isDark ? 'rgba(148, 163, 184, 0.16)' : 'rgba(148, 163, 184, 0.25)';

            const formatMoney = (amount) => {
                const num = Number(amount || 0);
                return num.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' USD';
            };

            if (typeof Chart === 'undefined') {
                return;
            }

            const commonLegend = {
                labels: {
                    color: textColor,
                    boxWidth: 12,
                    boxHeight: 12,
                },
            };

            const trendCanvas = document.getElementById('productsTrendChart');
            if (trendCanvas) {
                new Chart(trendCanvas, {
                    type: 'bar',
                    data: {
                        labels: dashboardData.trend.labels,
                        datasets: [
                            {
                                type: 'bar',
                                label: 'Commandes',
                                data: dashboardData.trend.orders,
                                backgroundColor: 'rgba(34, 197, 94, 0.55)',
                                borderColor: '#22c55e',
                                borderWidth: 1.2,
                                yAxisID: 'y',
                                borderRadius: 6,
                            },
                            {
                                type: 'line',
                                label: 'Chiffre d\'affaires',
                                data: dashboardData.trend.revenue,
                                borderColor: '#38bdf8',
                                backgroundColor: 'rgba(56, 189, 248, 0.2)',
                                borderWidth: 2,
                                pointRadius: 3,
                                pointHoverRadius: 4,
                                tension: 0.35,
                                yAxisID: 'y1',
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: commonLegend,
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        if (context.dataset.yAxisID === 'y1') {
                                            return context.dataset.label + ': ' + formatMoney(context.parsed.y);
                                        }
                                        return context.dataset.label + ': ' + context.parsed.y;
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                ticks: { color: mutedColor },
                                grid: { color: gridColor }
                            },
                            y: {
                                beginAtZero: true,
                                ticks: { color: mutedColor, precision: 0 },
                                grid: { color: gridColor }
                            },
                            y1: {
                                beginAtZero: true,
                                position: 'right',
                                ticks: {
                                    color: mutedColor,
                                    callback: (value) => Number(value).toLocaleString('fr-FR') + ' USD'
                                },
                                grid: { drawOnChartArea: false }
                            }
                        }
                    }
                });
            }

            const categoryCanvas = document.getElementById('productsCategoryStockChart');
            if (categoryCanvas) {
                new Chart(categoryCanvas, {
                    type: 'bar',
                    data: {
                        labels: dashboardData.categoryStock.labels,
                        datasets: [{
                            label: 'Stock',
                            data: dashboardData.categoryStock.values,
                            backgroundColor: 'rgba(59, 130, 246, 0.62)',
                            borderColor: '#3b82f6',
                            borderWidth: 1.2,
                            borderRadius: 6,
                        }]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: commonLegend },
                        scales: {
                            x: {
                                beginAtZero: true,
                                ticks: { color: mutedColor, precision: 0 },
                                grid: { color: gridColor }
                            },
                            y: {
                                ticks: { color: mutedColor },
                                grid: { color: 'transparent' }
                            }
                        }
                    }
                });
            }

            const stockHealthCanvas = document.getElementById('productsStockHealthChart');
            if (stockHealthCanvas) {
                new Chart(stockHealthCanvas, {
                    type: 'doughnut',
                    data: {
                        labels: dashboardData.stockHealth.labels,
                        datasets: [{
                            data: dashboardData.stockHealth.values,
                            backgroundColor: ['#22c55e', '#f59e0b', '#ef4444'],
                            borderColor: isDark ? '#0f172a' : '#ffffff',
                            borderWidth: 2,
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { ...commonLegend, position: 'bottom' }
                        }
                    }
                });
            }

            const topRevenueCanvas = document.getElementById('productsTopRevenueChart');
            if (topRevenueCanvas) {
                new Chart(topRevenueCanvas, {
                    type: 'bar',
                    data: {
                        labels: dashboardData.topRevenueProducts.labels,
                        datasets: [{
                            label: 'CA (USD)',
                            data: dashboardData.topRevenueProducts.values,
                            backgroundColor: 'rgba(249, 115, 22, 0.62)',
                            borderColor: '#f97316',
                            borderWidth: 1.2,
                            borderRadius: 6,
                        }]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: commonLegend,
                            tooltip: {
                                callbacks: {
                                    label: (context) => context.dataset.label + ': ' + formatMoney(context.parsed.x)
                                }
                            }
                        },
                        scales: {
                            x: {
                                beginAtZero: true,
                                ticks: {
                                    color: mutedColor,
                                    callback: (value) => Number(value).toLocaleString('fr-FR') + ' USD'
                                },
                                grid: { color: gridColor }
                            },
                            y: {
                                ticks: { color: mutedColor },
                                grid: { color: 'transparent' }
                            }
                        }
                    }
                });
            }
        });
    </script>
{% endblock %}
