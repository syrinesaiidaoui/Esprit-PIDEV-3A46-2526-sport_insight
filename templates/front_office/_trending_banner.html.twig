<style>
    .trending-banner {
        background: linear-gradient(90deg, rgba(16, 185, 129, 0.16), rgba(16, 185, 129, 0.04));
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 14px 18px;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .trending-banner__icon {
        width: 46px;
        height: 46px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #0f766e;
        color: #f8fafc;
        font-weight: 800;
        font-size: 16px;
        flex: 0 0 auto;
    }

    .trending-banner__title {
        font-size: 16px;
        font-weight: 800;
        color: var(--dark);
        margin: 0;
    }

    .trending-banner__text {
        margin: 4px 0 0;
        color: var(--text-muted);
    }

    .trending-banner__action {
        margin-left: auto;
        flex: 0 0 auto;
    }

    [data-theme="dark"] .trending-banner {
        background: linear-gradient(90deg, rgba(16, 185, 129, 0.18), rgba(15, 23, 42, 0.5));
    }

    [data-theme="dark"] .trending-banner__icon {
        background: #047857;
    }

    @media (max-width: 760px) {
        .trending-banner {
            flex-wrap: wrap;
        }

        .trending-banner__action {
            width: 100%;
            margin-left: 0;
        }

        .trending-banner__action .btn {
            width: 100%;
        }
    }
</style>

<div class="trending-banner">
    <div class="trending-banner__icon">TOP</div>
    <div>
        {% set names = [] %}
        {% for item in trendingItems %}
            {% set names = names|merge([item.product.name]) %}
        {% endfor %}

        {% if names|length > 0 %}
            <p class="trending-banner__title">{{ 'trending.title'|trans }}</p>
            <p class="trending-banner__text">
                {{ names|slice(0,3)|join(', ') }}{% if names|length > 3 %} {{ 'trending.more'|trans({'%count%': names|length - 3}) }}{% endif %} - {{ 'trending.suffix'|trans }}
            </p>
        {% else %}
            <p class="trending-banner__title">{{ 'trending.empty.title'|trans }}</p>
            <p class="trending-banner__text">{{ 'trending.empty.desc'|trans }}</p>
        {% endif %}
    </div>
    <div class="trending-banner__action">
        <a href="{{ path('app_shop_index') }}" class="btn btn-primary">{{ 'trending.button'|trans }}</a>
    </div>
</div>
