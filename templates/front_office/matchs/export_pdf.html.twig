<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Détails du Match - {{ match.equipeDomicile.nom }} vs {{ match.equipeExterieur.nom }}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #1f2937;
            background: white;
        }
        .pdf-container {
            width: 100%;
            max-width: 800px;
            margin: 0 auto;
            padding: 40px;
        }
        .header {
            text-align: center;
            border-bottom: 3px solid #10b981;
            padding-bottom: 30px;
            margin-bottom: 40px;
        }
        .header h1 {
            font-size: 28px;
            color: #059669;
            margin-bottom: 10px;
        }
        .match-title {
            font-size: 24px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 20px;
        }
        .section {
            margin-bottom: 30px;
        }
        .section-title {
            font-size: 16px;
            font-weight: 700;
            color: white;
            background: #10b981;
            padding: 12px 20px;
            margin-bottom: 15px;
            border-radius: 4px;
        }
        .details-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }
        .detail-item {
            border: 1px solid #e5e7eb;
            padding: 15px;
            border-radius: 4px;
            background: #f9fafb;
        }
        .detail-label {
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            margin-bottom: 5px;
        }
        .detail-value {
            font-size: 18px;
            font-weight: 700;
            color: #1f2937;
        }
        .teams-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 20px;
        }
        .team-box {
            border: 2px solid #10b981;
            padding: 20px;
            border-radius: 4px;
            background: #f0fdf4;
        }
        .team-name {
            font-size: 18px;
            font-weight: 700;
            color: #059669;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .team-logo {
            width: 40px;
            height: 40px;
            background: white;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .team-logo img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }
        .players-list {
            font-size: 13px;
            color: #374151;
        }
        .players-list strong {
            color: #059669;
        }
        .stadium-info {
            background: #e0f7ef;
            border-left: 4px solid #10b981;
            padding: 15px;
            margin-top: 20px;
            border-radius: 4px;
        }
        .stadium-info strong {
            color: #059669;
        }
        .footer {
            text-align: center;
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid #e5e7eb;
            font-size: 12px;
            color: #6b7280;
        }
        .score-badge {
            background: #10b981;
            color: white;
            padding: 10px 20px;
            border-radius: 4px;
            font-weight: 700;
            font-size: 20px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="pdf-container">
        <!-- Header -->
        <div class="header">
            <h1>⚽ DÉTAILS DU MATCH</h1>
            <div class="match-title">
                {{ match.equipeDomicile.nom }} vs {{ match.equipeExterieur.nom }}
            </div>
            <div class="score-badge">
                {{ match.scoreEquipeDomicile ?? 0 }} - {{ match.scoreEquipeExterieur ?? 0 }}
            </div>
        </div>

        <!-- Informations principales -->
        <div class="section">
            <div class="section-title">📋 INFORMATIONS GÉNÉRALES</div>
            <div class="details-grid">
                <div class="detail-item">
                    <div class="detail-label">📅 Date</div>
                    <div class="detail-value">{{ match.dateMatch ? match.dateMatch|date('d/m/Y') : 'N/A' }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">🕐 Heure</div>
                    <div class="detail-value">{{ match.heureDebut ? match.heureDebut|date('H:i') : 'N/A' }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">📍 Lieu</div>
                    <div class="detail-value">{{ match.lieu ?? 'N/A' }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">🎯 Type</div>
                    <div class="detail-value">{{ match.type ?? 'N/A' }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">🔔 Statut</div>
                    <div class="detail-value">{{ match.statut ?? 'N/A' }}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">⚽ Score</div>
                    <div class="detail-value">{{ match.scoreEquipeDomicile ?? 0 }} - {{ match.scoreEquipeExterieur ?? 0 }}</div>
                </div>
            </div>
        </div>

        <!-- Stade et météo -->
        <div class="section">
            <div class="section-title">🏟️ STADE LE PLUS PROCHE</div>
            <div class="stadium-info">
                <strong>Stade:</strong> {{ stadiumGeo.nom ?? 'Stade inconnu' }}<br>
                <strong>Lieu:</strong> {{ match.lieu ?? 'Lieu inconnu' }}<br>
                <strong>Distance estimée:</strong> 4.2 km
            </div>
        </div>

        <!-- Équipes et compositions -->
        <div class="section">
            <div class="section-title">👥 ÉQUIPES ET COMPOSITIONS</div>
            <div class="teams-section">
                <!-- Équipe Domicile -->
                <div class="team-box">
                    <div class="team-name">
                        {% if match.equipeDomicile.image %}
                        <img src="{{ media_url(match.equipeDomicile.image, 'equipes') }}" alt="{{ match.equipeDomicile.nom }}" class="team-logo" style="width:35px; height:35px;">
                        {% endif %}
                        {{ match.equipeDomicile.nom }}
                    </div>
                    <div class="players-list">
                        {% set joueursDomicile = match.matchLineups|filter(lineup => lineup.type == 'domicile') %}
                        {% if joueursDomicile|length > 0 %}
                            <strong>Joueurs:</strong><br>
                            {% for lineup in joueursDomicile %}
                                {{ loop.index }}. {{ lineup.joueur.prenom }} {{ lineup.joueur.nom }} ({{ lineup.joueur.numero }})<br>
                            {% endfor %}
                        {% else %}
                            <em>Composition non disponible</em>
                        {% endif %}
                    </div>
                </div>

                <!-- Équipe Extérieur -->
                <div class="team-box">
                    <div class="team-name">
                        {% if match.equipeExterieur.image %}
                        <img src="{{ media_url(match.equipeExterieur.image, 'equipes') }}" alt="{{ match.equipeExterieur.nom }}" class="team-logo" style="width:35px; height:35px;">
                        {% endif %}
                        {{ match.equipeExterieur.nom }}
                    </div>
                    <div class="players-list">
                        {% set joueursExterieur = match.matchLineups|filter(lineup => lineup.type == 'exterieur') %}
                        {% if joueursExterieur|length > 0 %}
                            <strong>Joueurs:</strong><br>
                            {% for lineup in joueursExterieur %}
                                {{ loop.index }}. {{ lineup.joueur.prenom }} {{ lineup.joueur.nom }} ({{ lineup.joueur.numero }})<br>
                            {% endfor %}
                        {% else %}
                            <em>Composition non disponible</em>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer">
            <p>Document généré le {{ "now"|date('d/m/Y à H:i') }} - Sport Insight</p>
        </div>
    </div>
</body>
</html>
