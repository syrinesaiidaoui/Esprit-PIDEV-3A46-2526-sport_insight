{% extends 'front_office/base.html.twig' %}

{% block title %}Détails du Match - Sport Insight{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .match-details {
            max-width: 1000px;
            margin: 40px auto;
            padding: 0 20px;
        }
        .details-header {
            margin-bottom: 32px;
            text-align: center;
        }
        .details-header h1 {
            font-size: 36px;
            font-weight: 800;
            color: #1e293b;
        }
        .match-card {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }
        .match-header {
            background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
            padding: 24px;
            color: #ffffff;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .match-title {
            font-size: 20px;
            font-weight: 700;
        }
        .match-id-badge {
            background: rgba(255, 255, 255, 0.2);
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
        }
        .details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            padding: 32px;
        }
        .detail-item {
            display: flex;
            flex-direction: column;
            gap: 8px;
            background: #f8fafc;
            padding: 16px;
            border-radius: 12px;
            border: 1px solid #f1f5f9;
        }
        .detail-label {
            font-size: 12px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .detail-value {
            font-size: 16px;
            font-weight: 600;
            color: #1e293b;
        }
        .teams-section {
            padding: 0 32px 32px;
            border-top: 1px solid #f1f5f9;
        }
        .teams-section h3 {
            font-size: 18px;
            font-weight: 700;
            color: #1e293b;
            margin: 24px 0 20px;
        }
        .team-heading {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            font-size: 18px;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 16px;
        }
        .football-field {
            position: relative;
            width: 100%;
            aspect-ratio: 2/3;
            background: #2e7d32;
            border-radius: 12px;
            border: 4px solid #ffffff;
            overflow: hidden;
            margin-bottom: 24px;
        }
        .field-lines {
            position: absolute;
            inset: 0;
            pointer-events: none;
        }
        .field-center-line {
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 2px;
            background: rgba(255, 255, 255, 0.5);
        }
        .field-center-circle {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 80px;
            height: 80px;
            border: 2px solid rgba(255, 255, 255, 0.5);
            border-radius: 50%;
            transform: translate(-50%, -50%);
        }
        .field-center-dot {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 6px;
            height: 6px;
            background: #ffffff;
            border-radius: 50%;
            transform: translate(-50%, -50%);
        }
        .field-penalty-area {
            position: absolute;
            left: 50%;
            width: 60%;
            height: 20%;
            border: 2px solid rgba(255, 255, 255, 0.5);
            transform: translateX(-50%);
        }
        .field-penalty-area-domicile { top: 0; border-top: none; }
        .field-penalty-area-exterieur { bottom: 0; border-bottom: none; }
        .field-goal-box {
            position: absolute;
            left: 50%;
            width: 30%;
            height: 8%;
            border: 2px solid rgba(255, 255, 255, 0.5);
            transform: translateX(-50%);
        }
        .field-goal-box-domicile { top: 0; border-top: none; }
        .field-goal-box-exterieur { bottom: 0; border-bottom: none; }
        
        .joueurs-field {
            position: relative;
            width: 100%;
            height: 100%;
        }
        .joueur-position {
            position: absolute;
            transform: translate(-50%, -50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            z-index: 10;
        }
        .joueur-photo {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: 2px solid #ffffff;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            object-fit: cover;
            background: #ffffff;
        }
        .joueur-placeholder {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #f1f5f9;
            border: 2px solid #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }
        .joueur-numero-badge {
            position: absolute;
            bottom: -2px;
            right: -2px;
            background: #10b981;
            color: #ffffff;
            font-size: 10px;
            font-weight: 700;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1.5px solid #ffffff;
        }
        .joueur-nom {
            font-size: 11px;
            font-weight: 700;
            color: #ffffff;
            text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
            white-space: nowrap;
        }
        .lineup-section {
            background: #f8fafc;
            border-left: 4px solid #10b981;
            padding: 16px;
            border-radius: 0 12px 12px 0;
            text-align: left;
        }
        .lineup-label {
            font-size: 12px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            margin-bottom: 4px;
        }
        .lineup-text {
            font-size: 14px;
            color: #1e293b;
        }
        .action-buttons {
            display: flex;
            gap: 12px;
            padding: 24px 32px;
            background: #f8fafc;
            border-top: 1px solid #f1f5f9;
        }
        .action-btn {
            flex: 1;
            padding: 12px;
            border-radius: 10px;
            font-weight: 600;
            text-align: center;
            text-decoration: none;
            transition: all 0.2s;
        }
        .btn-back {
            background: #ffffff;
            color: #64748b;
            border: 1px solid #e2e8f0;
        }
        .btn-back:hover {
            background: #f1f5f9;
            color: #1e293b;
        }
        .btn-edit {
            background: #1e293b;
            color: #ffffff;
        }
        .btn-edit:hover {
            background: #0f172a;
        }

        /* Weather and Geo cards */
        .modern-glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
        }
        .weather-title, .location-title {
            font-size: 14px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .weather-main {
            font-size: 28px;
            font-weight: 800;
            color: #1e293b;
            margin-bottom: 12px;
        }
        .weather-badges {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }
        .weather-badge, .location-badge {
            background: #f1f5f9;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            color: #475569;
        }
        .weather-desc, .location-distance {
            margin-top: 12px;
            font-size: 13px;
            color: #64748b;
        }
        .location-map-btn {
            margin-top: 16px;
            width: 100%;
            padding: 10px;
            background: #10b981;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
        }

        /* Floating AI Chat */
        #aiChatBubbleBtn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 999;
            cursor: pointer;
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        #aiChatBubbleBtn:hover {
            transform: scale(1.1) rotate(5deg);
        }
        #aiChatPopup {
            position: fixed;
            bottom: 100px;
            right: 30px;
            width: 380px;
            height: 520px;
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
            display: flex;
            flex-direction: column;
            z-index: 1000;
            overflow: hidden;
            opacity: 0;
            visibility: hidden;
            transform: translateY(20px);
            transition: all 0.3s ease;
        }
        #aiChatPopup.open {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }
        #aiChatPopupHeader {
            background: #10b981;
            color: #ffffff;
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        #aiChatPopupClose {
            background: none;
            border: none;
            color: #ffffff;
            font-size: 24px;
            cursor: pointer;
        }
        #aiChatHistory {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            background: #f8fafc;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        #aiChatForm {
            padding: 16px;
            background: #ffffff;
            border-top: 1px solid #e2e8f0;
            display: flex;
            gap: 10px;
        }
        #aiChatInput {
            flex: 1;
            padding: 10px 16px;
            border: 1px solid #e2e8f0;
            border-radius: 999px;
            font-size: 14px;
        }
        #aiChatSendBtn {
            background: #10b981;
            color: #ffffff;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }
        .ai-msg-user { align-self: flex-end; }
        .ai-msg-bot { align-self: flex-start; display: flex; gap: 8px; }
        .ai-bubble {
            max-width: 280px;
            padding: 10px 16px;
            border-radius: 16px;
            font-size: 14px;
            line-height: 1.5;
        }
        .ai-bubble-user { background: #10b981; color: #ffffff; border-bottom-right-radius: 4px; }
        .ai-bubble-bot { background: #ffffff; color: #1e293b; border: 1px solid #e2e8f0; border-bottom-left-radius: 4px; }
        .ai-bot-avatar { width: 30px; height: 30px; border-radius: 50%; object-fit: cover; }
        
        .modern-cards-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 32px;
        }
        @media (max-width: 768px) {
            .modern-cards-container { grid-template-columns: 1fr; }
        }
    </style>

    <div class="match-details">
        <div class="details-header">
            <h1>⚽ Détails du Match</h1>
        </div>

        <div class="modern-cards-container">
            <div class="modern-glass-card" id="weatherCard">
                <div class="weather-title">🌤️ Conditions Météo</div>
                <div id="weatherContent">
                    <div class="weather-main">--°C</div>
                    <div class="weather-desc">Chargement des données...</div>
                </div>
            </div>

            <div class="modern-glass-card" id="stadiumGeoCard">
                <div class="location-title">🏟️ Stade le plus proche</div>
                <div id="stadiumGeoContent">
                    <div class="location-badge">📍 {{ match.lieu ?? 'Lieu inconnu' }}</div>
                    <div class="location-distance">Recherche en cours...</div>
                </div>
                <button class="location-map-btn" onclick="window.open('https://www.google.com/maps/search/?api=1&query={{ (match.lieu ?? '')|url_encode }}','_blank')">Voir sur la carte</button>
            </div>
        </div>

        <div class="match-card">
            <div class="match-header">
                <div class="match-title">
                    {{ match.equipeDomicile.nom }} vs {{ match.equipeExterieur.nom }}
                </div>
                <div class="match-id-badge">#{{ match.id }}</div>
            </div>

            <div class="details-grid">
                <div class="detail-item">
                    <span class="detail-label">📅 Date</span>
                    <span class="detail-value">{{ match.dateMatch ? match.dateMatch|date('d/m/Y') : 'N/A' }}</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">🕐 Heure</span>
                    <span class="detail-value">{{ match.heureDebut ? match.heureDebut|date('H:i') : 'N/A' }}</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">📍 Lieu</span>
                    <span class="detail-value">{{ match.lieu ?? 'N/A' }}</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">🎯 Type</span>
                    <span class="detail-value">{{ match.type ?? 'N/A' }}</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">🔔 Statut</span>
                    <span class="detail-value">{{ match.statut ?? 'N/A' }}</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">⚽ Score</span>
                    <span class="detail-value">{{ match.scoreEquipeDomicile ?? 0 }} - {{ match.scoreEquipeExterieur ?? 0 }}</span>
                </div>
            </div>

            <div style="display: flex; justify-content: center; margin-bottom: 32px;">
                <a href="{{ path('app_front_matchs_export_pdf', {'id': match.id}) }}" class="btn btn-primary" style="padding: 12px 24px;">📄 Exporter en PDF</a>
            </div>

            <div class="teams-section">
                <h3>Équipes et Compositions</h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px;">
                    <!-- Équipe Domicile -->
                    <div style="text-align: center;">
                        <div class="team-heading">
                            {% if match.equipeDomicile.image %}
                                <img src="{{ asset('uploads/equipes/' ~ match.equipeDomicile.image) }}" alt="{{ match.equipeDomicile.nom }}" style="width: 40px; height: 40px; object-fit: contain;">
                            {% endif %}
                            {{ match.equipeDomicile.nom }}
                        </div>

                        {% set joueursDomicile = match.matchLineups|filter(lineup => lineup.type == 'domicile')|sort((a, b) => a.joueur.numero <=> b.joueur.numero) %}
                        {% if joueursDomicile|length > 0 %}
                            <div class="football-field">
                                <div class="field-lines">
                                    <div class="field-center-line"></div>
                                    <div class="field-center-circle"></div>
                                    <div class="field-center-dot"></div>
                                    <div class="field-penalty-area field-penalty-area-domicile"></div>
                                    <div class="field-goal-box field-goal-box-domicile"></div>
                                    <div class="field-penalty-area field-penalty-area-exterieur"></div>
                                    <div class="field-goal-box field-goal-box-exterieur"></div>
                                </div>
                                <div class="joueurs-field">
                                    {% for lineup in joueursDomicile %}
                                        <div class="joueur-position" style="left: {{ lineup.positionX ?? 50 }}%; top: {{ lineup.positionY ?? 50 }}%;">
                                            <div style="position: relative;">
                                                {% if lineup.joueur.image %}
                                                    <img src="{{ asset('uploads/joueurs/' ~ lineup.joueur.image) }}" class="joueur-photo">
                                                {% else %}
                                                    <div class="joueur-placeholder">👤</div>
                                                {% endif %}
                                                <div class="joueur-numero-badge">{{ lineup.joueur.numero }}</div>
                                            </div>
                                            <div class="joueur-nom">{{ lineup.joueur.nom }}</div>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% else %}
                            <div class="lineup-section">
                                <div class="lineup-label">Composition</div>
                                <div class="lineup-text">Aucun joueur sélectionné</div>
                            </div>
                        {% endif %}
                    </div>

                    <!-- Équipe Extérieure -->
                    <div style="text-align: center;">
                        <div class="team-heading">
                            {% if match.equipeExterieur.image %}
                                <img src="{{ asset('uploads/equipes/' ~ match.equipeExterieur.image) }}" alt="{{ match.equipeExterieur.nom }}" style="width: 40px; height: 40px; object-fit: contain;">
                            {% endif %}
                            {{ match.equipeExterieur.nom }}
                        </div>

                        {% set joueursExterieur = match.matchLineups|filter(lineup => lineup.type == 'exterieur')|sort((a, b) => a.joueur.numero <=> b.joueur.numero) %}
                        {% if joueursExterieur|length > 0 %}
                            <div class="football-field">
                                <div class="field-lines">
                                    <div class="field-center-line"></div>
                                    <div class="field-center-circle"></div>
                                    <div class="field-center-dot"></div>
                                    <div class="field-penalty-area field-penalty-area-domicile"></div>
                                    <div class="field-goal-box field-goal-box-domicile"></div>
                                    <div class="field-penalty-area field-penalty-area-exterieur"></div>
                                    <div class="field-goal-box field-goal-box-exterieur"></div>
                                </div>
                                <div class="joueurs-field">
                                    {% for lineup in joueursExterieur %}
                                        <div class="joueur-position" style="left: {{ lineup.positionX ?? 50 }}%; top: {{ lineup.positionY ?? 50 }}%;">
                                            <div style="position: relative;">
                                                {% if lineup.joueur.image %}
                                                    <img src="{{ asset('uploads/joueurs/' ~ lineup.joueur.image) }}" class="joueur-photo">
                                                {% else %}
                                                    <div class="joueur-placeholder">👤</div>
                                                {% endif %}
                                                <div class="joueur-numero-badge" style="background: #3b82f6;">{{ lineup.joueur.numero }}</div>
                                            </div>
                                            <div class="joueur-nom">{{ lineup.joueur.nom }}</div>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% else %}
                            <div class="lineup-section">
                                <div class="lineup-label">Composition</div>
                                <div class="lineup-text">Aucun joueur sélectionné</div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="action-buttons">
                <a href="{{ path('app_front_matchs_index') }}" class="action-btn btn-back">← Retour aux matchs</a>
                <a href="{{ path('app_match_edit_formation', {'id': match.id}) }}" class="action-btn btn-edit">⚽ Modifier la formation</a>
            </div>
        </div>
    </div>

    <!-- Floating AI Chat -->
    <button id="aiChatBubbleBtn" title="Chatbot Sport Insight" style="padding:0; background:none; border:none;">
        <img src="{{ asset('images/logo chatbot.png') }}" alt="AI" style="width:60px; height:60px; border-radius:50%; box-shadow:0 10px 25px rgba(0,0,0,0.18);">
    </button>
    <div id="aiChatPopup">
        <div id="aiChatPopupHeader">
            <span style="font-weight:700;">Sport Insight AI</span>
            <button id="aiChatPopupClose">&times;</button>
        </div>
        <div id="aiChatHistory">
            <div class="ai-msg-bot">
                <img class="ai-bot-avatar" src="{{ asset('images/logo chatbot.png') }}">
                <div class="ai-bubble ai-bubble-bot">Bonjour ! Je suis l assistant Sport Insight. Posez-moi vos questions sur ce match !</div>
            </div>
        </div>
        <form id="aiChatForm">
            <input type="text" id="aiChatInput" placeholder="Votre question..." autocomplete="off">
            <button type="submit" id="aiChatSendBtn">🚀</button>
        </form>
    </div>

    <script>
        // Weather
        function loadWeather() {
            const lieu = '{{ match.lieu|e("js") }}';
            const apiKey = '{{ weatherApiKey|default('87661002e861d90473336214197c31d1')|e('js') }}';
            if (!lieu) return;

            fetch(`https://api.openweathermap.org/data/2.5/weather?q=${encodeURIComponent(lieu)}&units=metric&lang=fr&appid=${apiKey}`)
                .then(r => r.json())
                .then(data => {
                    if (data.cod === 200) {
                        const html = `<div class="weather-main">${Math.round(data.main.temp)}°C</div><div class="weather-badges"><span class="weather-badge">💧 ${data.main.humidity}%</span><span class="weather-badge">💨 ${Math.round(data.wind.speed * 3.6)} km/h</span></div><div class="weather-desc">${data.weather[0].description}</div>`;
                        document.getElementById('weatherContent').innerHTML = html;
                    }
                });
        }

        // Closest Stadium
        const stadiums = [
            { name: 'Santiago Bernabéu', lat: 40.4531, lng: -3.6883 },
            { name: 'Camp Nou', lat: 41.3809, lng: 2.1228 },
            { name: 'Parc des Princes', lat: 48.8414, lng: 2.2530 },
            { name: 'Allianz Arena', lat: 48.2188, lng: 11.6247 },
            { name: 'Stade de France', lat: 48.9244, lng: 2.3601 }
        ];
        function showStadiumNearMatch() {
            const lieu = '{{ match.lieu|e('js') }}';
            if (!lieu) return;
            fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(lieu)}`)
                .then(r => r.json())
                .then(results => {
                    if (results && results.length > 0) {
                        const lat = parseFloat(results[0].lat);
                        const lon = parseFloat(results[0].lon);
                        let best = null, minDist = Infinity;
                        stadiums.forEach(s => {
                            const d = Math.sqrt(Math.pow(s.lat - lat, 2) + Math.pow(s.lng - lon, 2));
                            if (d < minDist) { minDist = d; best = s; }
                        });
                        if (best) document.getElementById('stadiumGeoContent').innerHTML = `<div class="location-badge">🏙️ ${best.name}</div><div class="location-distance">C est le stade majeur le plus proche.</div>`;
                    }
                });
        }

        // Chatbot logic
        const chatBtn = document.getElementById('aiChatBubbleBtn');
        const chatPopup = document.getElementById('aiChatPopup');
        const chatClose = document.getElementById('aiChatPopupClose');
        chatBtn.onclick = () => chatPopup.classList.toggle('open');
        chatClose.onclick = () => chatPopup.classList.remove('open');
        
        document.getElementById('aiChatForm').onsubmit = async (e) => {
            e.preventDefault();
            const input = document.getElementById('aiChatInput');
            const history = document.getElementById('aiChatHistory');
            const q = input.value.trim();
            if (!q) return;

            history.innerHTML += `<div class="ai-msg-user"><div class="ai-bubble ai-bubble-user">${q}</div></div>`;
            input.value = '';
            history.scrollTop = history.scrollHeight;

            try {
                const res = await fetch('{{ path('app_front_matchs_ai_chat', {id: match.id}) }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: q })
                });
                const data = await res.json();
                history.innerHTML += `<div class="ai-msg-bot"><img class="ai-bot-avatar" src="{{ asset('images/logo chatbot.png') }}"><div class="ai-bubble ai-bubble-bot">${data.reply || 'Information non disponible.'}</div></div>`;
            } catch (err) {
                history.innerHTML += `<div class="ai-msg-bot"><div class="ai-bubble ai-bubble-bot">Erreur de connexion.</div></div>`;
            }
            history.scrollTop = history.scrollHeight;
        };

        document.addEventListener('DOMContentLoaded', () => { loadWeather(); showStadiumNearMatch(); });
    </script>
{% endblock %}
