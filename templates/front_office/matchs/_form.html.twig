{{ form_start(form, { 'attr': { 'id': 'match-form', 'enctype': 'multipart/form-data', 'data-match-id': match.id|default('new') } }) }}
    
    <div class="mb-3">
        {{ form_label(form.id_match, 'ID Match', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.id_match, {'attr': {'class': 'form-control', 'placeholder': 'Ex: M-2025-001'}}) }}
        {{ form_errors(form.id_match) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.dateMatch, 'Date du match', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.dateMatch, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.dateMatch) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.heureDebut, 'Heure de début', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.heureDebut, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.heureDebut) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.lieu, 'Lieu du match', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.lieu, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.lieu) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.type, 'Type de match', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.type, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.type) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.statut, 'Statut du match', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.statut, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.statut) }}
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                {{ form_label(form.equipeDomicile, 'Équipe Domicile', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.equipeDomicile, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.equipeDomicile) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                {{ form_label(form.equipeExterieur, 'Équipe Extérieure', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.equipeExterieur, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.equipeExterieur) }}
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                {{ form_label(form.scoreEquipeDomicile, 'Score Domicile', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.scoreEquipeDomicile, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.scoreEquipeDomicile) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                {{ form_label(form.scoreEquipeExterieur, 'Score Extérieur', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.scoreEquipeExterieur, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.scoreEquipeExterieur) }}
            </div>
        </div>
    </div>

    <!-- Lineup fields if they exist in form -->
    {% if form.lineup_domicile is defined %}
        <div class="mb-3">
            {{ form_label(form.lineup_domicile, 'Lineup Domicile (JSON/Text)', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.lineup_domicile, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.lineup_domicile) }}
        </div>
    {% endif %}
    {% if form.lineup_exterieur is defined %}
        <div class="mb-3">
            {{ form_label(form.lineup_exterieur, 'Lineup Extérieur (JSON/Text)', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.lineup_exterieur, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.lineup_exterieur) }}
        </div>
    {% endif %}

    <div class="mt-4">
        <button class="btn btn-success">{{ button_label|default('Enregistrer le match') }}</button>
    </div>
{{ form_end(form) }}