        <div class="filter-group">
            <label for="f-size">Taille</label>
            <select id="f-size" class="form-select js-filter">
                <option value="">Toutes</option>
                <option>XS</option>
                <option>S</option>
                <option>M</option>
                <option>L</option>
                <option>XL</option>
                <option>40</option>
