                                        {% set sizeOptions = ['XS','S','M','L','XL','XXL','5','6','7','8','9','10','40','41','42','43','44','45'] %}
                                        {% for opt in sizeOptions %}
                                            <option value="{{ opt }}" {% if product.size is defined and product.size == opt %}selected{% endif %}>{{ opt }}</option>
                                        {% endfor %}
