{% extends 'front_office/base.html.twig' %}

{% block title %}Sport Insight | Équipement & Boutique{% endblock %}

{% block extra_chat %}
<div id="ai-chat-bubble">AI</div>
<div id="ai-chat-window">
    <div id="ai-chat-header">
        Assistant boutique
        <span id="ai-chat-close">x</span>
    </div>
    <div id="ai-quick-replies" aria-label="Suggestions rapides"></div>
    <div id="ai-chat-messages"></div>
    <form id="ai-chat-form">
        <input type="text" id="ai-chat-input" placeholder="Demandez des chaussures, maillots, tailles, stock..." required aria-describedby="ai-chat-error">
        <button type="submit">Envoyer</button>
    </form>
    <div id="ai-chat-error" role="alert" aria-live="polite"></div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .shop-grid {
        display: grid;
        grid-template-columns: 290px 1fr;
        gap: 16px;
    }

    .catalog-bar {
        margin-bottom: 24px;
    }

    .catalog-form { display: grid; gap: 8px; }
    .catalog-row { display: grid; grid-template-columns: 1.4fr 0.8fr 0.8fr auto; gap: 10px; align-items: end; }
    .catalog-field { display: flex; flex-direction: column; gap: 6px; }
    .catalog-field.wide { grid-column: span 2; }
    .catalog-label { font-size: 12px; text-transform: uppercase; letter-spacing: .5px; color: #64748b; font-weight: 800; margin: 0; }
    .catalog-form .form-control,
    .catalog-form .form-select { border-radius: 10px; min-height: 44px; }
    .sort-inline { display: grid; grid-template-columns: 1fr 90px; gap: 6px; }
    .catalog-actions { display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }

    .filter-panel {
        position: sticky;
        top: 90px;
        height: fit-content;
    }

    .filter-title {
        margin: 0 0 12px;
        font-size: 28px;
    }

    .filter-group {
        margin-bottom: 14px;
    }

    .filter-group label {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #64748b;
        font-weight: 800;
        margin-bottom: 6px;
        display: block;
    }

    .product-layout {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .product-card {
        padding: 0;
        overflow: hidden;
        position: relative;
        border-radius: 12px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.1);
    }

    .card-media {
        height: 180px;
        background: linear-gradient(140deg, #0f2f22, #1f6b49);
        position: relative;
    }

    .card-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .product-badges {
        position: absolute;
        left: 10px;
        top: 10px;
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .product-badges span {
        background: rgba(255,255,255,.92);
        border-radius: 999px;
        padding: 5px 8px;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        color: #0f172a;
    }

    .wishlist-btn {
        position: absolute;
        right: 10px;
        top: 10px;
        width: 34px;
        height: 34px;
        border: 0;
        border-radius: 999px;
        background: rgba(255,255,255,.96);
        color: #64748b;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
    }

    .wishlist-btn.active {
        color: #dc2626;
    }

    .product-body {
        padding: 14px;
    }

    .product-name {
        margin: 0;
        font-size: 20px;
        line-height: 1.2;
        font-weight: 700;
        color: #0f172a;
    }

    .product-meta {
        margin-top: 7px;
        font-size: 12px;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
    }

    .rating {
        margin-top: 7px;
        color: #f59e0b;
        font-size: 12px;
        font-weight: 700;
    }

    .price-row {
        margin-top: 8px;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 8px;
    }

    .price-row strong {
        font-size: 23px;
        font-family: 'Barlow Condensed', sans-serif;
        color: #16a34a;
        font-weight: 800;
    }

    .old-price {
        color: #94a3b8;
        text-decoration: line-through;
        font-size: 13px;
    }

    .option-tags {
        margin-top: 10px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .option-tags span {
        font-size: 10px;
        padding: 4px 8px;
        border: 1px solid #dbe2ea;
        border-radius: 999px;
        color: #475569;
        font-weight: 700;
    }

    .card-actions {
        margin-top: 14px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    #ai-chat-bubble {
        position: fixed;
        bottom: 22px;
        right: 22px;
        width: 60px;
        height: 60px;
        border-radius: 999px;
        background: linear-gradient(135deg, #16a34a 0%, #0f2f22 100%);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 10px 30px rgba(22,163,74,0.3);
        z-index: 999;
        font-size: 14px;
        letter-spacing: 1px;
    }

    #ai-chat-window {
        position: fixed;
        bottom: 100px;
        right: 22px;
        width: 380px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        display: none;
        flex-direction: column;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        z-index: 999;
    }

    #ai-chat-header {
        background: #0f2f22;
        color: #fff;
        padding: 16px;
        font-weight: 700;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    #ai-chat-messages {
        height: 350px;
        overflow-y: auto;
        padding: 16px;
        background: #f8fafc;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .user-bubble {
        align-self: flex-end;
        background: #16a34a;
        color: #fff;
        padding: 10px 16px;
        border-radius: 18px 18px 4px 18px;
        max-width: 80%;
        font-size: 14px;
        font-weight: 500;
    }

    .ai-card {
        align-self: flex-start;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-left: 4px solid #16a34a;
        padding: 12px;
        border-radius: 4px 18px 18px 18px;
        max-width: 90%;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    @media (max-width: 900px) {
        .product-layout { grid-template-columns: 1fr 1fr; }
        .shop-grid { grid-template-columns: 1fr; }
        .filter-panel { position: static; }
    }
</style>
{% endblock %}

{% block body %}
<section class="front-card" style="margin-bottom:32px;background:linear-gradient(130deg,#0f2f22,#16a34a);color:#fff;border-radius:24px;padding:50px;">
    <span style="font-size:12px;letter-spacing:1px;text-transform:uppercase;font-weight:800;color:#4ade80;">Boutique Officielle</span>
    <h1 style="font-size:56px;line-height:1;margin:12px 0 16px;font-family: 'Bebas Neue', sans-serif;">Équipez-vous Comme un Pro</h1>
    <p style="margin:0;max-width:700px;color:rgba(255,255,255,0.8);font-size:18px;">Découvrez notre sélection exclusive de chaussures, maillots et accessoires de match. Performance, style et qualité Sport Insight.</p>
</section>

<div class="catalog-bar">
    <form method="get" id="catalog-form" class="catalog-form">
        <div class="catalog-row">
            <div class="catalog-field wide">
                <label for="search" class="catalog-label">Recherche</label>
                <input id="search" type="search" name="q" class="form-control" placeholder="Chaussures, Maillots, Ballons..." value="{{ app.request.query.get('q') }}">
            </div>

            <div class="catalog-field">
                <label for="category" class="catalog-label">Catégorie</label>
                <select id="category" name="category" class="form-select">
                    <option value="">Toutes</option>
                    {% for cat in categories|default(['Boots', 'Jersey', 'Accessories', 'Training']) %}
                        <option value="{{ cat }}" {% if app.request.query.get('category') == cat %}selected{% endif %}>{{ cat }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="catalog-field">
                <label for="sortBy" class="catalog-label">Trier par</label>
                <div class="sort-inline">
                    <select id="sortBy" name="sortBy" class="form-select">
                        <option value="name" {% if app.request.query.get('sortBy') == 'name' %}selected{% endif %}>Nom</option>
                        <option value="price" {% if app.request.query.get('sortBy') == 'price' %}selected{% endif %}>Prix</option>
                    </select>
                </div>
            </div>

            <div class="catalog-actions">
                <button class="btn btn-primary" type="submit">Rechercher</button>
                <a class="btn btn-secondary" href="{{ path('front_equipement_index') }}">Réinitialiser</a>
                <a href="{{ path('front_equipement_cart') }}" class="btn btn-outline-primary">Panier</a>
            </div>
        </div>
    </form>
</div>

<div class="shop-grid">
    <aside class="front-card filter-panel" style="border-radius: 20px; padding: 24px; border: 1px solid #e2e8f0;">
        <h2 class="filter-title" style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 1px;">Filtres</h2>

        <div class="filter-group">
            <label>Marque</label>
            <select id="f-brand" class="form-select js-filter">
                <option value="">Toutes</option>
                <option>Nike</option>
                <option>Adidas</option>
                <option>Puma</option>
            </select>
        </div>

        <div class="filter-group">
            <label>Prix Max</label>
            <select id="f-price" class="form-select js-filter">
                <option value="">Tous les prix</option>
                <option value="0-50">< 50 USD</option>
                <option value="0-100">< 100 USD</option>
                <option value="100-200">100 - 200 USD</option>
            </select>
        </div>

        <div class="filter-group">
            <label>Taille</label>
            <select id="f-size" class="form-select js-filter">
                <option value="">Toutes</option>
                <option>S</option><option>M</option><option>L</option>
                <option>41</option><option>42</option><option>43</option>
            </select>
        </div>
    </aside>

    <section>
        <div class="product-layout" id="product-grid">
            {% for product in products %}
                <article class="front-card product-card js-card" 
                         data-brand="{{ (product.brand|default('Nike'))|lower }}"
                         data-price="{{ product.price }}"
                         data-size="{{ (product.size|default('M'))|lower }}">
                    <div class="card-media">
                        <div class="product-badges">
                            <span>{{ product.category|default('Foot') }}</span>
                            {% if product.stock < 5 and product.stock > 0 %}
                                <span style="background: #fef3c7; color: #92400e;">Stock Faible</span>
                            {% endif %}
                        </div>
                        <button type="button" class="wishlist-btn">+</button>
                        {% if product.image %}
                            <img src="{{ product.image starts with 'http' ? product.image : asset('uploads/' ~ product.image) }}" alt="{{ product.name }}">
                        {% endif %}
                    </div>
                    <div class="product-body">
                        <h3 class="product-name">{{ product.name }}</h3>
                        <p class="product-meta">{{ product.brand|default('Sport Insight') }} • {{ product.size|default('S-XL') }}</p>
                        
                        <div class="price-row">
                            <strong>{{ product.price|number_format(2) }} USD</strong>
                        </div>

                        <div class="card-actions">
                            <a href="{{ path('front_equipement_show', {'id': product.id}) }}" class="btn btn-secondary btn-sm">Détails</a>
                            {% if product.stock > 0 %}
                                <a href="{{ path('front_equipement_buy', {'id': product.id}) }}" class="btn btn-primary btn-sm">Acheter</a>
                            {% else %}
                                <button class="btn btn-secondary btn-sm" disabled>Rupture</button>
                            {% endif %}
                        </div>
                    </div>
                </article>
            {% else %}
                <div class="text-center py-5">
                    <p class="text-muted">Aucun produit ne correspond à votre recherche.</p>
                </div>
            {% endfor %}
        </div>
    </section>
</div>

{# REST OF JS LOGIC FROM HEAD VERSION #}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Simplification for the walkthrough - real file has more JS
    document.addEventListener('DOMContentLoaded', function () {
        const bubble = document.getElementById('ai-chat-bubble');
        const chatWindow = document.getElementById('ai-chat-window');
        const closeBtn = document.getElementById('ai-chat-close');
        
        if(bubble && chatWindow && closeBtn) {
            bubble.onclick = () => { chatWindow.style.display = 'flex'; bubble.style.display = 'none'; };
            closeBtn.onclick = () => { chatWindow.style.display = 'none'; bubble.style.display = 'flex'; };
        }
    });
</script>
{% endblock %}
