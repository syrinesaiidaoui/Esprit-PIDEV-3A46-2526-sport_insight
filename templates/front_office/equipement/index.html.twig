                <button type="button" class="vs-toggle" aria-haspopup="listbox" aria-expanded="false">
                    <span class="label"><span class="vs-icon swatch" style="background:#131f2f;"></span><span class="vs-text">Toutes</span></span>
                    <span class="vs-arrow">▼</span>
