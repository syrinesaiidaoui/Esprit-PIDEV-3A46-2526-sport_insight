                    <h3 style="font-size:28px;margin:0 0 6px;">{{ 'results.none'|trans }}</h3>
                    <p style="margin:0;color:#64748b;">{{ 'btn.apply'|trans }} / {{ 'btn.reset'|trans }}</p>
                </div>
            {% endfor %}
        </div>

        {% if totalPages is defined and page is defined and totalPages > 1 %}
            {% set currentQuery = app.request.query.all %}
            <nav aria-label="Pagination des produits" style="margin-top:14px;">
                <ul class="pagination justify-content-center">
                    <li class="page-item{% if page <= 1 %} disabled{% endif %}">
                        <a class="page-link" href="{{ path('front_equipement_index', currentQuery|merge({page: page - 1})) }}">Precedent</a>
                    </li>
                    {% for p in 1..totalPages %}
                        <li class="page-item{% if p == page %} active{% endif %}">
                            <a class="page-link" href="{{ path('front_equipement_index', currentQuery|merge({page: p})) }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                    <li class="page-item{% if page >= totalPages %} disabled{% endif %}">
                        <a class="page-link" href="{{ path('front_equipement_index', currentQuery|merge({page: page + 1})) }}">Suivant</a>
                    </li>
                </ul>
            </nav>
        {% endif %}

        <div class="helper-grid">
            <div class="front-card">
                <h3 style="font-size:25px;margin:0 0 8px;">{{ 'section.personalization'|trans }}</h3>
                <p style="margin:0;color:#64748b;">{{ 'section.personalization.desc'|trans }}</p>
            </div>
            <div class="front-card">
                <h3 style="font-size:25px;margin:0 0 8px;">{{ 'section.bundle'|trans }}</h3>
                <p style="margin:0;color:#64748b;">{{ 'section.bundle.desc'|trans }}</p>
            </div>
            <div class="front-card">
                <h3 style="font-size:25px;margin:0 0 8px;">{{ 'section.delivery'|trans }}</h3>
                <p style="margin:0;color:#64748b;">{{ 'section.delivery.desc'|trans }}</p>
            </div>
        </div>
    </section>
</div>

<h2 class="section-title" style="margin-top:22px;">Produits phares API</h2>
<div class="product-layout">
    {% for apiProduct in apiProducts|default([]) %}
        {% set apiPrice = apiProduct.price|default(0) + 0 %}
        {% set apiStock = apiProduct.stock|default(0) %}
        <article class="front-card product-card {% if apiProduct.dbId is defined %}js-card{% endif %}"
                 {% if apiProduct.dbId is defined %}data-url="{{ path('front_equipement_show', {'id': apiProduct.dbId}) }}"{% endif %}
                 data-brand="{{ apiProduct.brand|default('')|lower }}"
                 data-size="{{ apiProduct.size|default('M')|lower }}"
                 data-color="{{ apiProduct.color|default('')|lower }}"
                 data-surface="{{ apiProduct.category|default('training')|lower }}"
