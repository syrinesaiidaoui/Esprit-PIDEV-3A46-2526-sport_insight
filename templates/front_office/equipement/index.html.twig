                        <div class="option-tags">
                            <span>{{ 'card.opt.fit'|trans }}</span>
                            <span>{{ 'card.opt.fabric'|trans }}</span>
                            <span>{{ 'card.opt.edition'|trans }}</span>
                            <span>{{ 'card.opt.team'|trans }}</span>
                        </div>

                        <p style="margin:10px 0 0; font-size:12px;" class="stock-pill {{ product.stock <= 0 ? 'stock-out' : (product.stock < 15 ? 'stock-low' : 'stock-ok') }}">
                            <span class="dot" aria-hidden="true"></span>
                            {% if product.stock <= 0 %}
                                {{ 'stock.out'|trans }}
                            {% elseif product.stock < 15 %}
                                {{ 'stock.low'|trans({'%count%': product.stock}) }}
                            {% else %}
                                {{ 'stock.ok'|trans({'%count%': product.stock}) }}
                            {% endif %}
                        </p>

                        <div class="card-actions">
                            {% if product.stock > 0 %}
                                <form method="get" action="{{ path('front_equipement_buy', {'id': product.id}) }}" class="d-flex gap-2" style="margin:0;">
