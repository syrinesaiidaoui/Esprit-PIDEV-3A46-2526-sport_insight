                    {% if apiProduct.imageUrl is defined and apiProduct.imageUrl %}
                        <img src="{{ apiProduct.imageUrl }}" alt="{{ apiProduct.name|default('API product') }}">
                    {% elseif apiProduct.image starts with 'http://' or apiProduct.image starts with 'https://' %}
                        <img src="{{ apiProduct.image }}" alt="{{ apiProduct.name|default('API product') }}">
                    {% else %}
                        <img src="{{ asset('api/' ~ apiProduct.image) }}" alt="{{ apiProduct.name|default('API product') }}">
                    {% endif %}
                {% endif %}
            </div>
            <div class="product-body">
                <h3 class="product-name">{{ apiProduct.name|default('Produit API') }}</h3>
                <p class="product-meta">{{ 'card.meta'|trans({'%brand%': apiProduct.brand|default('N/A'), '%size%': apiProduct.size|default('M'), '%surface%': 'training'}) }}</p>
                <div class="price-row">
                    <strong>{{ apiPrice|number_format(2, '.', ',') }} USD</strong>
                    <span class="old-price">{{ (apiPrice * 1.2)|number_format(2, '.', ',') }} USD</span>
                </div>
                <p style="margin:10px 0 0; font-size:12px;" class="{{ apiStock <= 0 ? 'stock-out' : 'stock-ok' }}">
                    {{ apiStock > 0 ? 'stock.ok'|trans({'%count%': apiStock}) : 'stock.out'|trans }}
                </p>
                <p style="margin:8px 0 0;color:#64748b;font-size:13px;">{{ apiProduct.description|default('Produit API depuis products.json') }}</p>
                <div class="card-actions">
                    {% if apiProduct.dbId is defined %}
                        {% if apiStock > 0 %}
                            <a href="{{ path('front_equipement_buy', {'id': apiProduct.dbId}) }}" class="btn btn-primary">{{ 'card.add'|trans }}</a>
                        {% else %}
                            <button class="btn btn-secondary" disabled>{{ 'card.unavailable'|trans }}</button>
                        {% endif %}
                    {% else %}
                        <button class="btn btn-secondary" disabled>Non synchronise</button>
                    {% endif %}
                </div>
            </div>
        </article>
    {% else %}
        <div class="front-card">
            <p style="margin:0;color:#64748b;">Aucun produit API trouve dans public/api/products.json.</p>
        </div>
    {% endfor %}
</div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const cards = Array.from(document.querySelectorAll('.js-card'));
    const filters = Array.from(document.querySelectorAll('.js-filter'));
    const resetBtn = document.getElementById('reset-filters');
    const catalogForm = document.getElementById('catalog-form');
    const searchInput = document.getElementById('search');
    const categoryInput = document.getElementById('category');
    const sortInput = document.getElementById('sortBy');
    const dirInput = document.getElementById('dir');
    const grid = document.getElementById('product-grid');

    function withinPrice(cardPrice, range) {
        if (!range) return true;
        const [min, max] = range.split('-').map(Number);
        return cardPrice >= min && cardPrice <= max;
    }

    function applyFilters() {
        const values = {
            brand: (document.getElementById('f-brand')?.value || '').toLowerCase(),
            size: (document.getElementById('f-size')?.value || '').toLowerCase(),
            color: (document.getElementById('f-color')?.value || '').toLowerCase(),
            surface: (document.getElementById('f-surface')?.value || '').toLowerCase(),
            availability: (document.getElementById('f-availability')?.value || '').toLowerCase(),
            price: (document.getElementById('f-price')?.value || '').toLowerCase(),
            search: (searchInput?.value || '').trim().toLowerCase(),
            category: (categoryInput?.value || '').trim().toLowerCase()
        };

        cards.forEach((card) => {
            const brand = card.dataset.brand || '';
            const size = card.dataset.size || '';
            const color = card.dataset.color || '';
            const surface = card.dataset.surface || '';
            const stock = parseInt(card.dataset.stock || '0', 10);
            const price = parseFloat(card.dataset.price || '0');
            const name = card.dataset.name || '';
            const meta = card.dataset.meta || '';
            const cat = card.dataset.category || '';

            const matchBrand = !values.brand || brand.includes(values.brand);
            const matchSize = !values.size || size.includes(values.size);
            const matchColor = !values.color || color.includes(values.color);
            const matchSurface = !values.surface || surface.includes(values.surface);
            const matchPrice = withinPrice(price, values.price);
            const matchAvailability = !values.availability
                || (values.availability === 'in' && stock > 0)
                || (values.availability === 'low' && stock > 0 && stock < 15)
                || (values.availability === 'out' && stock <= 0);
            const matchSearch = !values.search || name.includes(values.search) || meta.includes(values.search);
            const matchCategory = !values.category || cat === values.category;

            card.style.display = matchBrand && matchSize && matchColor && matchSurface && matchPrice && matchAvailability && matchSearch && matchCategory
                ? ''
                : 'none';
        });
        applySort();
    }

    // Visual select (logos / swatches) synced with hidden native select
    const visualSelects = [];
    function initVisualSelect(wrapperId) {
        const wrapper = document.getElementById(wrapperId);
        if (!wrapper) return;
        const select = wrapper.querySelector('.vs-hidden-select');
        const toggle = wrapper.querySelector('.vs-toggle');
        const list = wrapper.querySelector('.vs-list');
        const text = wrapper.querySelector('.vs-text');
        const icon = wrapper.querySelector('.vs-icon');
        if (!select || !toggle || !list || !text || !icon) return;

        const options = Array.from(list.querySelectorAll('.vs-option'));
        const closeList = () => { list.style.display = 'none'; toggle.setAttribute('aria-expanded', 'false'); };
        const openList = () => { list.style.display = 'block'; toggle.setAttribute('aria-expanded', 'true'); };

        toggle.addEventListener('click', (e) => {
            e.preventDefault();
            const isOpen = list.style.display === 'block';
            isOpen ? closeList() : openList();
        });

        options.forEach((opt) => {
            opt.addEventListener('click', () => {
                const value = opt.dataset.value || '';
                select.value = value;
                options.forEach((o) => o.classList.remove('active'));
                opt.classList.add('active');
                const iconSpan = opt.querySelector('.vs-icon');
                if (iconSpan) {
                    icon.style.background = iconSpan.style.background;
                    icon.className = iconSpan.className;
                }
                text.textContent = opt.innerText.trim();
                closeList();
                applyFilters();
            });
        });

        document.addEventListener('click', (ev) => {
            if (!wrapper.contains(ev.target)) closeList();
        });

        document.addEventListener('keydown', (ev) => {
            if (ev.key === 'Escape') closeList();
        });

        // initialize active state from current select value
        const current = options.find((o) => (o.dataset.value || '') === (select.value || '')) || options[0];
        if (current) current.click();

        visualSelects.push({ wrapper, select, toggle, list, options, text, icon, closeList, openList });
    }

    initVisualSelect('vs-brand');
    initVisualSelect('vs-color');
    initVisualSelect('vs-availability');

    filters.forEach((el) => el.addEventListener('change', applyFilters));

    const resetVisualSelects = () => {
        visualSelects.forEach((vs) => {
            const first = vs.options?.[0];
            if (first) first.click();
        });
    };

    resetBtn?.addEventListener('click', () => {
        filters.forEach((el) => el.value = '');
        resetVisualSelects();
        applyFilters();
        const url = resetBtn.dataset.resetUrl;
        if (url) {
            window.location.href = url;
        }
    });

    applyFilters();

    // live search/filter as user types
    if (searchInput) {
        searchInput.addEventListener('input', () => {
            applyFilters();
        });
    }

    [categoryInput, sortInput, dirInput].forEach((el) => {
        if (!el) return;
        el.addEventListener('change', applyFilters);
    });

    if (catalogForm) {
        catalogForm.addEventListener('submit', (e) => {
            e.preventDefault();
            applyFilters();
        });
    }

    function applySort() {
        if (!grid || !sortInput) return;
        const sortBy = sortInput.value;
        const dir = (dirInput?.value || 'asc') === 'desc' ? -1 : 1;
        const visibleCards = cards.filter((c) => c.style.display !== 'none');
        const getValue = (card) => {
            if (sortBy === 'price') return parseFloat(card.dataset.price || '0');
            if (sortBy === 'stock') return parseInt(card.dataset.stock || '0', 10);
            return (card.dataset.name || '').toLowerCase();
        };
        visibleCards.sort((a, b) => {
            const va = getValue(a);
            const vb = getValue(b);
            if (va < vb) return -1 * dir;
            if (va > vb) return 1 * dir;
            return 0;
        });
        visibleCards.forEach((card) => grid.appendChild(card));
    }

    // Make entire product cards clickable (except interactive controls)
    document.addEventListener('click', function (event) {
        const card = event.target.closest('.js-card');
        if (!card || !card.dataset.url) return;
        const isInteractive = event.target.closest('a, button, select, option, input, textarea, label, form');
        if (isInteractive) return;
        window.location = card.dataset.url;
    });

    const bubble = document.getElementById('ai-chat-bubble');
    const chatWindow = document.getElementById('ai-chat-window');
    const closeBtn = document.getElementById('ai-chat-close');
    const form = document.getElementById('ai-chat-form');
    const input = document.getElementById('ai-chat-input');
    const messages = document.getElementById('ai-chat-messages');
    const quickReplies = document.getElementById('ai-quick-replies');
    const errorBox = document.getElementById('ai-chat-error');
    const chatEndpoint = "{{ path('front_equipement_ai_chat') }}";

    if (!bubble || !chatWindow || !closeBtn || !form || !input || !messages) return;

    bubble.addEventListener('click', function () {
        chatWindow.style.display = 'flex';
        bubble.style.display = 'none';
        input.focus();

        // Auto-greet when opening
        const existingMsgs = messages?.children?.length || 0;
        if (existingMsgs === 0) {
            const intro = "Bonjour, je suis l'assistant Sport Insight. Dites-moi ce que vous cherchez ou utilisez un bouton rapide.";
            messages.innerHTML += `<div class="ai-message"><div class="ai-generic">${intro}</div></div>`;
        }
    });

    closeBtn.addEventListener('click', function () {
        chatWindow.style.display = 'none';
        bubble.style.display = 'flex';
    });

    const presetReplies = [
        'Voir les produits phares',
        'Trouver des gants taille M',
        'Besoin de 2 perceuses pour Sousse lundi prochain',
        'Comment commander ?',
        'Suivre commande #123',
        'Propose un équivalent moins cher',
        'Aide retour / mauvais article'
    ];

    if (quickReplies) {
        quickReplies.innerHTML = presetReplies.map((text) =>
            `<button type="button" class="ai-chip" data-msg="${text.replace(/"/g, '&quot;')}">${text}</button>`
        ).join('');

        quickReplies.querySelectorAll('.ai-chip').forEach((btn) => {
            btn.addEventListener('click', () => {
                const msg = btn.dataset.msg || '';
                input.value = msg;
                input.focus();
                form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
            });
        });
    }

    const setError = (msg) => {
        if (!errorBox) return;
        errorBox.textContent = msg || '';
    };

    const clearError = () => setError('');

    const isLowSignal = (text) => {
        const trimmed = text.replace(/\s+/g, ' ').trim();
        if (trimmed.length < 3) return true;
        const letters = trimmed.replace(/[^a-zA-Z0-9]/g, '');
        return letters.length < 2;
    };

    let sending = false;

    form.addEventListener('submit', async function (e) {
        e.preventDefault();
        const userText = input.value.trim();
        if (!userText) return;

        if (isLowSignal(userText)) {
            setError('Merci de préciser votre demande (min. 3 caractères utiles).');
            input.focus();
            return;
        }

        if (userText.length > 300) {
            setError('Message trop long (300 caractères max).');
            input.focus();
            return;
        }

        if (sending) return;
        sending = true;
        clearError();

        const escapeHtml = (text) => String(text)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');

        const toLinkChip = (label, path, primary = false) => {
            if (!path || !path.startsWith('/')) return '';
            const safeLabel = escapeHtml(label);
            const safePath = escapeHtml(path);
            return `<a class="ai-link-chip ${primary ? 'primary' : ''}" href="${safePath}">${safeLabel}</a>`;
        };

        const renderAssistantReply = (reply) => {
            const text = (reply || '').trim();
            if (!text) {
                return '<div class="ai-generic">Impossible de repondre pour le moment.</div>';
            }

            const lines = text.split(/\r?\n/).map((line) => line.trim()).filter((line) => line.length > 0);
            const map = {};
            const actions = [];

            lines.forEach((line) => {
                const separatorIndex = line.indexOf(':');
                if (separatorIndex > 0) {
                    const key = line.slice(0, separatorIndex).trim().toLowerCase();
                    const value = line.slice(separatorIndex + 1).trim();
                    if (line.startsWith('- ')) {
                        actions.push({ key: key.replace(/^-+\s*/, ''), value });
                    } else {
                        map[key] = value;
                    }
                }
                if (line.startsWith('- ')) {
                    const actionLine = line.replace(/^-+\s*/, '');
                    const idx = actionLine.indexOf(':');
                    if (idx > 0) {
                        actions.push({
                            key: actionLine.slice(0, idx).trim().toLowerCase(),
                            value: actionLine.slice(idx + 1).trim()
                        });
                    }
                }
            });

            const hasStructuredProduct =
                Object.prototype.hasOwnProperty.call(map, 'product') ||
                Object.prototype.hasOwnProperty.call(map, 'price') ||
                Object.prototype.hasOwnProperty.call(map, 'availability');

            if (!hasStructuredProduct) {
                return `<div class="ai-generic">${escapeHtml(text)}</div>`;
            }

            const product = map['product'] || 'Product';
            const price = map['price'] || '';
            const availability = map['availability'] || '';
            const description = map['description'] || '';
            const image = map['image'] || '';

            const availabilityClass = /out/i.test(availability) ? 'stock-out' : 'stock-ok';

            let html = `<div class="ai-card">`;
            html += `<div class="ai-title">${escapeHtml(product)}</div>`;
            if (price) {
                html += `<div class="ai-row"><span class="ai-label">Price</span><span class="ai-value price">${escapeHtml(price)}</span></div>`;
            }
            if (availability) {
                html += `<div class="ai-row"><span class="ai-label">Stock</span><span class="ai-value ${availabilityClass}">${escapeHtml(availability)}</span></div>`;
            }
            if (description) {
                html += `<div class="ai-row"><span class="ai-label">Details</span><span class="ai-value">${escapeHtml(description)}</span></div>`;
            }
            if (image) {
                const safeImage = escapeHtml(image);
                if (image.startsWith('/')) {
                    html += `<div class="ai-row"><span class="ai-label">Image</span><span class="ai-value"><a class="ai-image-link" href="${safeImage}" target="_blank" rel="noopener">${safeImage}</a></span></div>`;
                } else {
                    html += `<div class="ai-row"><span class="ai-label">Image</span><span class="ai-value">${safeImage}</span></div>`;
                }
            }

            const viewAction = actions.find((a) => a.key.includes('view product'));
            const addAction = actions.find((a) => a.key.includes('add to cart'));
            const cartAction = actions.find((a) => a.key.includes('view cart'));
            if (viewAction || addAction || cartAction) {
                html += '<div class="ai-actions">';
                if (viewAction) html += toLinkChip('View product', viewAction.value);
                if (addAction) html += toLinkChip('Add to cart', addAction.value, true);
                if (cartAction) html += toLinkChip('View cart', cartAction.value);
                html += '</div>';
            }
            html += `</div>`;
            return html;
        };

        messages.innerHTML += `<div class="user-message"><span class="user-bubble">${escapeHtml(userText)}</span></div>`;
        input.value = '';
        messages.scrollTop = messages.scrollHeight;

        messages.innerHTML += '<div class="ai-message" id="loading">Assistant en train d ecrire...</div>';

        try {
            const response = await fetch(chatEndpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: userText })
            });

            let data = null;
            try {
                data = await response.json();
            } catch (jsonError) {
                data = null;
            }

            const loading = document.getElementById('loading');
            if (loading) loading.remove();

            if (response.redirected || response.status === 401 || response.status === 403) {
                messages.innerHTML += `<div class="ai-message">${renderAssistantReply('Session expiree. Merci de vous reconnecter pour utiliser l assistant boutique.')}</div>`;
                messages.scrollTop = messages.scrollHeight;
                return;
            }

            if (!response.ok) {
                const serverMessage = data && data.reply ? data.reply : `Erreur serveur (${response.status}).`;
                messages.innerHTML += `<div class="ai-message">${renderAssistantReply(serverMessage)}</div>`;
                messages.scrollTop = messages.scrollHeight;
                return;
            }

        messages.innerHTML += `<div class="ai-message">${renderAssistantReply((data && data.reply) ? data.reply : 'Impossible de repondre pour le moment.')}</div>`;
        messages.scrollTop = messages.scrollHeight;
    } catch (error) {
        const loading = document.getElementById('loading');
        if (loading) loading.remove();
        messages.innerHTML += `<div class="ai-message">${renderAssistantReply('Erreur de connexion. Veuillez reessayer.')}</div>`;
    }
    sending = false;
});
});
</script>
{% endblock %}

