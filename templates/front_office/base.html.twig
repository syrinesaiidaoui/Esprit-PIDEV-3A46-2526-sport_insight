{% set currentTheme = app.request.session.get('theme_mode', 'light') %}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}" data-theme="{{ currentTheme }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Sport Insight Boutique{% endblock %}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('images/logos/mini%20logo%20nuit.png') }}?v=20260304">
    <link rel="shortcut icon" href="{{ asset('images/logos/mini%20logo%20nuit.png') }}?v=20260304">
    <link rel="apple-touch-icon" href="{{ asset('images/logos/mini%20logo%20nuit.png') }}?v=20260304">
    <script>
        (function () {
            function isValidMode(mode) {
                return mode === 'light' || mode === 'dark';
            }

            try {
                var savedTheme = localStorage.getItem('theme_mode')
                    || localStorage.getItem('front_theme_mode')
                    || localStorage.getItem('admin_theme_mode');

                var mode = isValidMode(savedTheme)
                    ? savedTheme
                    : (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

                document.documentElement.setAttribute('data-theme', mode);
            } catch (e) {
                if (!isValidMode(document.documentElement.getAttribute('data-theme'))) {
                    document.documentElement.setAttribute('data-theme', 'light');
                }
            }
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/lucide-static@latest/font/lucide.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/front_base.css') }}?v=20260305">
    {% block stylesheets %}{% endblock %}
</head>
<body class="{{ currentTheme == 'dark' ? 'dark' : '' }}" data-turbo="false">
    {% set cartCount = app.request.session.get('cart', {})|length %}
    {% set currentRoute = app.request.get('_route') %}
    {% set isAuthNavPage = currentRoute in ['app_login', 'app_register', 'app_sign_up'] %}

    <nav class="top-navbar">
        <div class="nav-left">
            <a href="{{ path('front_home') }}" class="nav-brand">
                <img src="{{ asset('images/logos/logo.png') }}" alt="{{ 'nav.brand'|trans }}" class="nav-brand-logo nav-brand-logo--light">
                <img src="{{ asset('images/logos/logo%20nn.png') }}" alt="{{ 'nav.brand'|trans }}" class="nav-brand-logo nav-brand-logo--dark">
            </a>
        </div>

        <div class="nav-center">
            {% if not isAuthNavPage %}
                <ul class="nav-links">
                    <li class="dropdown">
                        <a href="#" class="dropdown-toggle {{ app.request.get('_route') starts with 'front_entrainement' or app.request.get('_route') starts with 'front_participation' or app.request.get('_route') starts with 'front_evaluation' or app.request.get('_route') starts with 'front_matchmaking' ? 'active' : '' }}" data-bs-toggle="dropdown">
                            {{ 'nav.training'|trans }}
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="{{ path('front_entrainement_index') }}">{{ 'nav.trainings'|trans }}</a></li>
                            <li><a class="dropdown-item" href="{{ path('front_participation_index') }}">{{ 'nav.participations'|trans }}</a></li>
                            <li><a class="dropdown-item" href="{{ path('front_evaluation_index') }}">{{ 'nav.evaluations'|trans }}</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item dropdown-item-accent" href="{{ path('front_matchmaking_index') }}">{{ 'nav.matchmaking_ai'|trans }}</a></li>
                        </ul>
                    </li>
                    <li class="dropdown">
                        <a href="#" class="dropdown-toggle {{ app.request.get('_route') starts with 'app_front_matchs' or app.request.get('_route') starts with 'app_front_equipes' or app.request.get('_route') starts with 'app_joueur' ? 'active' : '' }}" data-bs-toggle="dropdown">
                            {{ 'nav.matches'|trans }}
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="{{ path('app_front_matchs_index') }}">{{ 'nav.matches'|trans }}</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_front_equipes_index') }}">{{ 'nav.teams'|trans }}</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_joueurs_index') }}">{{ 'nav.players'|trans }}</a></li>
                        </ul>
                    </li>
                    <li><a href="{{ path('front_equipement_index') }}" class="{{ app.request.get('_route') starts with 'front_equipement' ? 'active' : '' }}">{{ 'nav.equipment'|trans }}</a></li>
                    <li><a href="{{ path('front_sponsoring_index') }}" class="{{ app.request.get('_route') starts with 'front_sponsoring' ? 'active' : '' }}">{{ 'nav.sponsors'|trans }}</a></li>
                    <li><a href="{{ path('app_annonce_index') }}" class="{{ app.request.get('_route') starts with 'app_annonce' ? 'active' : '' }}">{{ 'nav.announcements'|trans }}</a></li>
                </ul>
            {% endif %}
        </div>

        <div class="nav-right">
            <div class="nav-actions">
                {% if not isAuthNavPage %}
                    <a href="{{ path('front_equipement_cart') }}" class="btn-chip btn-chip--cta">
                        <span class="cart-chip-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false">
                                <path d="M7 6h13.1a1 1 0 0 1 .98 1.2l-1.3 6.5a2 2 0 0 1-1.96 1.6H9.1a2 2 0 0 1-1.96-1.6L5.6 4.8 4 4" stroke="none"/>
                                <circle cx="10" cy="19" r="1.6" stroke="none"/>
                                <circle cx="17" cy="19" r="1.6" stroke="none"/>
                            </svg>
                        </span>
                        <span>{{ 'nav.cart'|trans }}</span>
                        <span class="cart-pill">{{ cartCount }}</span>
                    </a>
                {% endif %}

                <div class="dropdown" data-bs-auto-close="outside">
                    <button class="settings-trigger" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="{{ 'settings.title'|trans }}">
                        <img src="{{ asset('images/settings.png') }}" alt="{{ 'settings.title'|trans }}">
                    </button>
                    <div class="dropdown-menu dropdown-menu-end settings-menu">
                        <p class="settings-title">{{ 'settings.language'|trans }}</p>
                        <div class="settings-row">
                            <a href="{{ path('app_locale_switch', {'locale':'fr'}) }}" class="settings-pill {{ app.request.locale starts with 'fr' ? 'active' : '' }}"><i class="lucide-languages"></i>FR</a>
                            <a href="{{ path('app_locale_switch', {'locale':'en'}) }}" class="settings-pill {{ app.request.locale starts with 'en' ? 'active' : '' }}"><i class="lucide-languages"></i>EN</a>
                        </div>

                        <div class="settings-divider"></div>

                        <p class="settings-title">{{ 'settings.theme'|trans }}</p>
                        <div class="settings-theme-row">
                            <span class="settings-theme-label">{{ 'settings.theme_light'|trans }}</span>
                            <button type="button" id="js-theme-toggle" class="theme-toggle settings-theme-toggle" aria-label="{{ 'settings.theme_toggle'|trans }}" aria-pressed="false" role="switch" aria-checked="false">
                                <span class="theme-toggle-track">
                                    <span class="theme-toggle-thumb" aria-hidden="true">
                                        <span class="theme-toggle-icon">
                                            <svg class="theme-toggle-icon--sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                                <circle cx="12" cy="12" r="4"></circle>
                                                <path d="M12 2V4"></path>
                                                <path d="M12 20V22"></path>
                                                <path d="M4.93 4.93L6.34 6.34"></path>
                                                <path d="M17.66 17.66L19.07 19.07"></path>
                                                <path d="M2 12H4"></path>
                                                <path d="M20 12H22"></path>
                                                <path d="M4.93 19.07L6.34 17.66"></path>
                                                <path d="M17.66 6.34L19.07 4.93"></path>
                                            </svg>
                                            <svg class="theme-toggle-icon--moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M21 12.8A9 9 0 1 1 11.2 3A7 7 0 0 0 21 12.8Z"></path>
                                            </svg>
                                        </span>
                                    </span>
                                </span>
                            </button>
                            <span class="settings-theme-label">{{ 'settings.theme_dark'|trans }}</span>
                        </div>

                        <div class="settings-divider"></div>

                        <p class="settings-title">{{ 'settings.account'|trans }}</p>
                        <div class="settings-group">
                            {% if app.user %}
                                <a href="{{ path('app_logout') }}" class="settings-link"><i class="lucide-log-out"></i>{{ 'nav.logout'|trans }}</a>
                                <a href="{{ path('app_profile_edit') }}" class="settings-link"><i class="lucide-user"></i>{{ app.user.prenom }}</a>
                            {% else %}
                                <a href="{{ path('app_login') }}" class="settings-link"><i class="lucide-log-in"></i>{{ 'nav.login'|trans }}</a>
                            {% endif %}
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('back_entrainement_index') }}" class="settings-link"><i class="lucide-shield"></i>{{ 'nav.admin'|trans }}</a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </nav>

    {% if currentRoute not in ['app_login', 'app_logout', 'app_register', 'app_sign_up'] %}
        {% include 'front_office/_trending_banner.html.twig' with { trendingNames: trending_product_names(30, 5) } %}
    {% endif %}

    {% block hero %}{% endblock %}

    <div class="page-container">
        <div class="flash-stack">
            {% for label, messages in app.flashes %}
                {% if label != 'moderation_error' %}
                    {% for message in messages %}
                        <div class="flash-item flash-{{ label }}">{{ message }}</div>
                    {% endfor %}
                {% endif %}
            {% endfor %}
        </div>

        {% block body %}{% endblock %}
    </div>

    {% block extra_chat %}{% endblock %}

    <footer class="site-footer">
        <p>&copy; {{ "now"|date("Y") }} {{ 'footer.copyright'|trans }}</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            function optimizeImages() {
                var images = document.querySelectorAll('img:not([loading])');
                for (var i = 0; i < images.length; i += 1) {
                    var image = images[i];
                    if (image.classList.contains('nav-brand-logo')) {
                        image.loading = 'eager';
                        image.decoding = 'sync';
                        continue;
                    }

                    image.loading = 'lazy';
                    image.decoding = 'async';
                }
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', optimizeImages, { once: true });
            } else {
                optimizeImages();
            }
        })();
    </script>
    <script>
        (function () {
            var themeToggle = document.getElementById('js-theme-toggle');
            if (!themeToggle) {
                return;
            }
            var themeUrls = {
                light: '{{ path('app_theme_set', {mode: 'light'}) }}',
                dark: '{{ path('app_theme_set', {mode: 'dark'}) }}'
            };

            function isValidMode(mode) {
                return mode === 'light' || mode === 'dark';
            }

            function getStoredMode() {
                try {
                    var stored = localStorage.getItem('theme_mode')
                        || localStorage.getItem('front_theme_mode')
                        || localStorage.getItem('admin_theme_mode');
                    return isValidMode(stored) ? stored : null;
                } catch (e) {
                    return null;
                }
            }

            function persistMode(mode) {
                try {
                    localStorage.setItem('theme_mode', mode);
                    localStorage.setItem('front_theme_mode', mode);
                    localStorage.setItem('admin_theme_mode', mode);
                } catch (e) {}
            }

            function preferredSystemMode() {
                return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }

            function currentMode() {
                var htmlTheme = document.documentElement.getAttribute('data-theme');
                return isValidMode(htmlTheme) ? htmlTheme : 'light';
            }

            function resolveInitialMode() {
                var storedMode = getStoredMode();
                if (storedMode) {
                    return storedMode;
                }
                var htmlTheme = document.documentElement.getAttribute('data-theme');
                if (htmlTheme === 'light' || htmlTheme === 'dark') {
                    return htmlTheme;
                }
                return preferredSystemMode();
            }

            function refreshToggle(mode) {
                var isDark = mode === 'dark';
                themeToggle.classList.toggle('is-dark', isDark);
                themeToggle.setAttribute('aria-pressed', isDark ? 'true' : 'false');
                themeToggle.setAttribute('aria-checked', isDark ? 'true' : 'false');
            }

            function applyMode(mode, shouldPersist) {
                var root = document.documentElement;
                var isDark = mode === 'dark';
                root.classList.add('theme-switching');
                root.setAttribute('data-theme', mode);
                document.body.classList.toggle('dark', isDark);
                refreshToggle(mode);
                if (shouldPersist !== false) {
                    persistMode(mode);
                }
                setTimeout(function () {
                    root.classList.remove('theme-switching');
                }, 400);
            }

            applyMode(resolveInitialMode(), false);

            themeToggle.addEventListener('click', function (event) {
                event.preventDefault();
                event.stopPropagation();
                var next = currentMode() === 'dark' ? 'light' : 'dark';
                applyMode(next, true);

                fetch(themeUrls[next], {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                }).catch(function () {});
            });
        })();
    </script>
    {% include '_partials/global_form_ux.html.twig' %}
    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}
    {% if app.debug %}
        <script>
            (function () {
                var tries = 0;
                var timer = setInterval(function () {
                    tries++;
                    var toolbar = document.querySelector('.sf-toolbar.sf-display-none');
                    if (!toolbar) {
                        if (tries > 30) {
                            clearInterval(timer);
                        }
                        return;
                    }

                    toolbar.classList.remove('sf-display-none');
                    var main = toolbar.querySelector('[id^="sfToolbarMainContent-"]');
                    var clearer = toolbar.querySelector('[id^="sfToolbarClearer-"]');
                    var mini = toolbar.querySelector('[id^="sfMiniToolbar-"]');

                    if (main && !main.style.display) {
                        main.style.display = 'block';
                    }
                    if (clearer && !clearer.style.display) {
                        clearer.style.display = 'block';
                    }
                    if (mini && !mini.style.display) {
                        mini.style.display = 'none';
                    }

                    clearInterval(timer);
                }, 200);
            })();
        </script>
    {% endif %}
</body>
</html>
