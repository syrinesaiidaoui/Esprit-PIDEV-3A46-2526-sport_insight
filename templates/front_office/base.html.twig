    <script>
        (function () {
            var themeToggle = document.getElementById('js-theme-toggle');
            if (!themeToggle) {
                return;
            }
            var themeUrls = {
                light: '{{ path('app_theme_set', {mode: 'light'}) }}',
                dark: '{{ path('app_theme_set', {mode: 'dark'}) }}'
            };

            function getStoredMode() {
                try {
                    var stored = localStorage.getItem('front_theme_mode');
                    return stored === 'light' || stored === 'dark' ? stored : null;
                } catch (e) {
                    return null;
                }
            }

            function preferredSystemMode() {
                return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }

            function currentMode() {
                return document.body.classList.contains('dark') ? 'dark' : 'light';
            }

            function resolveInitialMode() {
                var storedMode = getStoredMode();
                if (storedMode) {
                    return storedMode;
                }
                var htmlTheme = document.documentElement.getAttribute('data-theme');
                if (htmlTheme === 'light' || htmlTheme === 'dark') {
                    return htmlTheme;
                }
                return preferredSystemMode();
            }

            function refreshToggle(mode) {
                var isDark = mode === 'dark';
                themeToggle.classList.toggle('is-dark', isDark);
                themeToggle.setAttribute('aria-pressed', isDark ? 'true' : 'false');
                themeToggle.setAttribute('aria-checked', isDark ? 'true' : 'false');
            }

            function applyMode(mode, persistMode) {
                var root = document.documentElement;
                var isDark = mode === 'dark';
                root.classList.add('theme-switching');
                root.setAttribute('data-theme', mode);
                document.body.classList.toggle('dark', isDark);
                refreshToggle(mode);
                if (persistMode !== false) {
                    try {
                        localStorage.setItem('front_theme_mode', mode);
                    } catch (e) {}
                }
                setTimeout(function () {
                    root.classList.remove('theme-switching');
                }, 400);
            }

            applyMode(resolveInitialMode(), false);

            themeToggle.addEventListener('pointerdown', function (event) {
                event.preventDefault();
                event.stopPropagation();
            });

            themeToggle.addEventListener('click', function (event) {
                event.preventDefault();
                event.stopPropagation();
                var next = currentMode() === 'dark' ? 'light' : 'dark';
                applyMode(next, true);

                fetch(themeUrls[next], {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                }).catch(function () {});
            });
        })();
    </script>
