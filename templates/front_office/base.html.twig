        .settings-theme-toggle {
            --toggle-width: 72px;
            --toggle-height: 34px;
            --toggle-padding: 3px;
            --toggle-knob-size: 28px;
            --toggle-shift: calc(var(--toggle-width) - var(--toggle-knob-size) - (var(--toggle-padding) * 2));
