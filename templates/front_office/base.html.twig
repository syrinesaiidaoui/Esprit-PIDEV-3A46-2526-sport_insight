        }

        .theme-toggle-track {
            position: relative;
            display: block;
            width: var(--toggle-width);
            height: var(--toggle-height);
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.35);
            background: var(--toggle-track-light);
            box-shadow: inset 0 2px 7px rgba(15, 23, 42, 0.2);
            transition: background var(--theme-transition-duration) var(--theme-transition-ease),
                        border-color var(--theme-transition-duration) var(--theme-transition-ease),
                        box-shadow var(--theme-transition-duration) var(--theme-transition-ease);
        }

        .theme-toggle-thumb {
            position: absolute;
            top: var(--toggle-padding);
            left: var(--toggle-padding);
            width: var(--toggle-knob-size);
            height: var(--toggle-knob-size);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--toggle-knob-light);
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.32);
            transform: translateX(0);
            transition: transform var(--theme-transition-duration) var(--theme-transition-ease),
                        background var(--theme-transition-duration) var(--theme-transition-ease),
                        box-shadow var(--theme-transition-duration) var(--theme-transition-ease);
        }

        .theme-toggle-icon {
            position: relative;
            display: block;
            width: 18px;
            height: 18px;
            transform: rotate(0deg);
            transition: transform var(--theme-transition-duration) var(--theme-transition-ease);
        }

        .theme-toggle-icon svg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            display: block;
            transition: opacity var(--theme-transition-duration) var(--theme-transition-ease),
                        transform var(--theme-transition-duration) var(--theme-transition-ease);
        }

        .theme-toggle-icon--sun {
            color: #f59e0b;
            opacity: 1;
            transform: scale(1);
        }

        .theme-toggle-icon--moon {
            color: #ecfeff;
            opacity: 0;
            transform: scale(0.2);
        }

        .theme-toggle.is-dark .theme-toggle-track {
            border-color: rgba(103, 232, 249, 0.55);
