{% set currentTheme = app.request.session.get('theme_mode', 'light') %}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}" data-theme="{{ currentTheme }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Sport Insight Boutique{% endblock %}</title>
    <script>
        (function () {
            try {
                var savedTheme = localStorage.getItem('front_theme_mode');
                if (savedTheme === 'light' || savedTheme === 'dark') {
                    document.documentElement.setAttribute('data-theme', savedTheme);
                }
            } catch (e) {}
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/lucide-static@latest/font/lucide.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --pitch-900: #0b1b14;
            --pitch-800: #123023;
            --pitch-700: #1b4a35;
            --pitch-600: #1f6b49;
            --pitch-500: #2b8b60;
            --line: #e5e7eb;
            --border-color: #dbe2ea;
            --surface: #f6f8f7;
            --ink: #101827;
            --muted: #5e6b66;
            --warn: #f59e0b;
            --danger: #ef4444;
            --ok: #22c55e;
            --page-bg: radial-gradient(circle at 0% 0%, #eef8f1 0, #f8faf9 44%, #f3f5f4 100%);
            --top-navbar-bg: #111827;
            --hero-grad: linear-gradient(120deg, var(--pitch-900), var(--pitch-600));
            --primary: #10b981;
            --primary-hover: #059669;
            --card-bg: #ffffff;
            --footer-bg: var(--pitch-900);
            --footer-text: #c2d5ca;
            --btn-secondary-border: #cbd5e1;
            --btn-secondary-text: #334155;
        }

        [data-theme="dark"] {
            --line: #334155;
            --border-color: #334155;
            --surface: #0f172a;
            --ink: #e2e8f0;
            --muted: #94a3b8;
            --page-bg: radial-gradient(circle at 0% 0%, #0b1221 0, #0b1220 44%, #0a101d 100%);
            --top-navbar-bg: #030712;
            --hero-grad: linear-gradient(120deg, #052e2b, #0f766e);
            --card-bg: #111827;
            --footer-bg: #020617;
            --footer-text: #94a3b8;
            --btn-secondary-border: #334155;
            --btn-secondary-text: #cbd5e1;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: 'Manrope', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--page-bg);
            color: var(--ink);
        }

        h1, h2, h3, h4, h5 {
            font-family: 'Barlow Condensed', sans-serif;
            letter-spacing: .3px;
        }

        .top-navbar {
            background: var(--top-navbar-bg);
            padding: 0 40px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .nav-brand {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: #fff;
        }

        .nav-brand-icon {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #10b981;
            color: #fff;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 700;
        }

        .nav-brand-text {
            display: block;
            color: #fff;
            font-size: 18px;
            font-weight: 700;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 4px;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .nav-links a {
            text-decoration: none;
            color: #9ca3af;
            font-size: 13px;
            font-weight: 700;
            padding: 8px 14px;
            border-radius: 6px;
        }

        .nav-links .dropdown-menu {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,.1);
            min-width: 220px;
            padding: 8px 0;
        }

        .nav-links .dropdown-item {
            font-weight: 700;
            color: #111827;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-links .dropdown-item:hover {
            color: var(--pitch-600);
            background: #f3f4f6;
        }

        .nav-links a.active {
            color: #10b981;
            background: rgba(16, 185, 129, 0.1);
        }

        .nav-links a:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.06);
        }

        .nav-actions {
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-chip {
            background: rgba(255,255,255,0.08);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 6px;
            text-decoration: none;
            padding: 7px 12px;
            font-size: 13px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-chip--cta {
            background: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.35);
        }

        .cart-pill {
            min-width: 22px;
            text-align: center;
            border-radius: 999px;
            background: #ef4444;
            color: #fff;
            font-size: 11px;
            padding: 2px 6px;
        }

        .hero {
            margin: 22px auto 0;
            max-width: 1320px;
            border-radius: 20px;
            overflow: hidden;
            background: var(--hero-grad);
            color: #fff;
            padding: 52px 34px;
        }

        .hero h1 {
            font-size: 58px;
            margin: 0;
            line-height: .95;
        }

        .hero p {
            font-size: 16px;
            color: #ddf7e9;
            margin-top: 12px;
            max-width: 700px;
        }

        .page-container {
            max-width: 1320px;
            margin: 24px auto;
            padding: 0 18px;
        }

        .front-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 32px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .front-card:hover {
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.08), 0 10px 10px -6px rgba(0, 0, 0, 0.08);
        }

        .section-title {
            font-size: 36px;
            margin: 0 0 16px;
        }

        .badge-soft {
            display: inline-block;
            background: #eaf6ef;
            color: var(--pitch-700);
            border-radius: 999px;
            padding: 5px 10px;
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .btn {
            border-radius: 10px !important;
            font-weight: 700 !important;
            padding: 10px 14px !important;
        }

        .btn-primary {
            border: 0 !important;
            background: linear-gradient(120deg, var(--pitch-700), var(--pitch-500)) !important;
        }

        .btn-secondary {
            border: 1px solid var(--btn-secondary-border) !important;
            color: var(--btn-secondary-text) !important;
            background: var(--card-bg) !important;
        }

        .front-table {
            background: var(--card-bg);
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid var(--border-color);
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        }

        .front-table table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .front-table th {
            background: #f8fafc;
            padding: 16px 20px;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--muted);
            border-bottom: 2px solid var(--border-color);
        }

        .front-table td {
            padding: 16px 20px;
            font-size: 14px;
            color: var(--ink);
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
        }

        .front-table tr:last-child td { border-bottom: none; }
        .front-table tr:hover { background-color: #f1f5f9; }

        .site-footer {
            margin-top: 54px;
            background: var(--footer-bg);
            color: var(--footer-text);
            padding: 40px;
            text-align: center;
            font-size: 13px;
        }

        .theme-fab {
            position: fixed;
            left: 22px;
            bottom: 22px;
            width: 62px;
            height: 62px;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.22);
            background: linear-gradient(145deg, #0f172a, #111827);
            color: #e5e7eb;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.5px;
            z-index: 998;
            box-shadow: 0 14px 28px rgba(2, 6, 23, 0.45);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

        [data-theme="dark"] .theme-fab {
            background: linear-gradient(145deg, #065f46, #047857);
            color: #ecfeff;
            border-color: rgba(45, 212, 191, 0.45);
        }

        .flash-stack {
            margin-bottom: 16px;
            display: grid;
            gap: 10px;
        }

        .flash-item {
            border-radius: 10px;
            padding: 10px 12px;
            font-size: 14px;
            font-weight: 700;
        }

        .flash-success { background: #e8f9ee; color: #166534; border: 1px solid #bbf7d0; }
        .flash-warning { background: #fff7e5; color: #92400e; border: 1px solid #fde68a; }
        .flash-danger, .flash-error { background: #fef0f0; color: #991b1b; border: 1px solid #fecaca; }

        @media (max-width: 980px) {
            .top-navbar { padding: 0 16px; }
            .nav-links { display: none; }
            .hero h1 { font-size: 42px; }
        }

        @media (max-width: 640px) {
            .hero { border-radius: 0; margin-top: 0; padding: 40px 20px; }
            .hero h1 { font-size: 35px; }
            .section-title { font-size: 28px; }
            .page-container { padding: 0 12px; }
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {% set cartCount = app.request.session.get('cart', {})|length %}

    <nav class="top-navbar">
        <a href="{{ path('front_home') }}" class="nav-brand">
            <span class="nav-brand-icon">SI</span>
            <span class="nav-brand-text">{{ 'nav.brand'|trans }}</span>
        </a>

        <ul class="nav-links">
            <li class="dropdown">
                <a href="#" class="dropdown-toggle {{ app.request.get('_route') starts with 'front_entrainement' or app.request.get('_route') starts with 'front_participation' or app.request.get('_route') starts with 'front_evaluation' or app.request.get('_route') starts with 'front_matchmaking' ? 'active' : '' }}" data-bs-toggle="dropdown">
                    {{ 'nav.training'|trans }}
                </a>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="{{ path('front_entrainement_index') }}">🏋️ Entrainements</a></li>
                    <li><a class="dropdown-item" href="{{ path('front_participation_index') }}">📜 Participations</a></li>
                    <li><a class="dropdown-item" href="{{ path('front_evaluation_index') }}">⭐ Évaluations</a></li>
                    <li><hr class="dropdown-divider" style="margin:4px 0;"></li>
                    <li><a class="dropdown-item" href="{{ path('front_matchmaking_index') }}" style="color:#16a34a;font-weight:800;">🤖 Matchmaking (IA)</a></li>
                </ul>
            </li>
            <li><a href="{{ path('app_front_equipes_index') }}" class="{{ app.request.get('_route') starts with 'app_front_equipes' ? 'active' : '' }}">{{ 'nav.teams'|trans }}</a></li>
            <li><a href="{{ path('app_joueurs_index') }}" class="{{ app.request.get('_route') starts with 'app_joueur' ? 'active' : '' }}">{{ 'nav.players'|trans }}</a></li>
            <li><a href="{{ path('app_front_matchs_index') }}" class="{{ app.request.get('_route') starts with 'app_front_matchs' ? 'active' : '' }}">{{ 'nav.matches'|trans }}</a></li>
            <li><a href="{{ path('front_equipement_index') }}" class="{{ app.request.get('_route') starts with 'front_equipement' ? 'active' : '' }}">{{ 'nav.equipment'|trans }}</a></li>
            <li><a href="{{ path('app_annonce_index') }}" class="{{ app.request.get('_route') starts with 'app_annonce' ? 'active' : '' }}">Annonces</a></li>
            <li><a href="{{ path('front_sponsoring_index') }}" class="{{ app.request.get('_route') starts with 'front_sponsoring' ? 'active' : '' }}">Sponsors</a></li>
        </ul>

        <div class="nav-actions">
            {% if app.user %}
                <div style="display: flex; align-items: center; gap: 8px; margin-right: 8px;">
                    <a href="{{ path('app_profile_edit') }}" style="text-decoration: none; display: flex; align-items: center; gap: 8px; color: white;">
                        <span style="font-size: 13px; font-weight: 700;">{{ app.user.prenom }}</span>
                        {% if app.user.photo %}
                            <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" style="width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--primary);">
                        {% else %}
                            <div style="width: 32px; height: 32px; border-radius: 50%; background: #374151; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 12px; font-weight: 600;">{{ app.user.prenom|first }}{{ app.user.nom|first }}</div>
                        {% endif %}
                    </a>
                </div>
            {% endif %}

            <div class="btn-chip lang-switch" role="group" aria-label="Choisir la langue">
                <a href="{{ path('app_locale_switch', {'locale':'fr'}) }}" class="{{ app.request.locale starts with 'fr' ? 'active' : '' }}">FR</a>
                <span style="color:#4b5563;">|</span>
                <a href="{{ path('app_locale_switch', {'locale':'en'}) }}" class="{{ app.request.locale starts with 'en' ? 'active' : '' }}">EN</a>
            </div>
            <a href="{{ path('front_equipement_cart') }}" class="btn-chip btn-chip--cta">{{ 'nav.cart'|trans }} <span class="cart-pill">{{ cartCount }}</span></a>
            {% if app.user %}
                <a href="{{ path('app_logout') }}" class="btn-chip">{{ 'nav.logout'|trans }}</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn-chip">{{ 'nav.login'|trans }}</a>
            {% endif %}
            <a href="{{ path('back_entrainement_index') }}" class="btn-chip">{{ 'nav.admin'|trans }}</a>
        </div>

    </nav>

    {% if app.request.get('_route') != 'app_login' and app.request.get('_route') != 'app_logout' %}
        {{ render(path('trending_banner')) }}
    {% endif %}

    {% block hero %}{% endblock %}

    <div class="page-container">
        <div class="flash-stack">
            {% for label, messages in app.flashes %}
                {% if label != 'moderation_error' %}
                    {% for message in messages %}
                        <div class="flash-item flash-{{ label == 'danger' ? 'danger' : (label == 'success' ? 'success' : label) }}">{{ message }}</div>
                    {% endfor %}
                {% endif %}
            {% endfor %}
        </div>

        {% block body %}{% endblock %}
    </div>

    {% block extra_chat %}{% endblock %}
    <button type="button" id="theme-fab" class="theme-fab" aria-label="Toggle theme">THEME</button>

    <footer class="site-footer">
        <p>&copy; {{ "now"|date("Y") }} {{ 'footer.copyright'|trans }}</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            var button = document.getElementById('theme-fab');
            if (!button) {
                return;
            }
            var themeUrls = {
                light: '{{ path('app_theme_set', {mode: 'light'}) }}',
                dark: '{{ path('app_theme_set', {mode: 'dark'}) }}'
            };

            function currentMode() {
                return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
            }

            function refreshLabel(mode) {
                button.textContent = mode === 'dark' ? 'LIGHT' : 'DARK';
                button.setAttribute('aria-label', mode === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
            }

            function applyMode(mode) {
                document.documentElement.setAttribute('data-theme', mode);
                refreshLabel(mode);
                try {
                    localStorage.setItem('front_theme_mode', mode);
                } catch (e) {}
            }

            refreshLabel(currentMode());

            button.addEventListener('click', function () {
                var next = currentMode() === 'dark' ? 'light' : 'dark';
                applyMode(next);

                fetch(themeUrls[next], {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                }).catch(function () {});
            });
        })();
    </script>
    {% include '_partials/global_form_ux.html.twig' %}
    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}
</body>
</html>
