{% extends 'front_office/base.html.twig' %}

{% block title %}Sport Insight | Home{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --bg-main: #f1f5f9;
        --glass-bg: rgba(255, 255, 255, 0.5);
        --glass-border: rgba(148, 163, 184, 0.28);
        --text-main: #0f172a;
        --text-soft: #334155;
        --soft-shadow: 0 8px 40px rgba(0, 0, 0, 0.08);
        --hero-grad: radial-gradient(circle at 50% 30%, #e0f2fe, #f8fafc);
        --hero-glow: rgba(45, 212, 191, 0.35);
        --home-ease: cubic-bezier(0.23, 1, 0.320, 1);
    }

    [data-theme="dark"] {
        --bg-main: #020617;
        --glass-bg: rgba(15, 23, 42, 0.55);
        --glass-border: rgba(148, 163, 184, 0.3);
        --text-main: #e2e8f0;
        --text-soft: #cbd5e1;
        --soft-shadow: 0 8px 40px rgba(0, 0, 0, 0.35);
        --hero-grad: radial-gradient(circle at 50% 30%, #0b2943, #020617);
        --hero-glow: rgba(16, 185, 129, 0.3);
    }

    .home-landing,
    .home-main,
    .home-btn,
    .home-card {
        line-height: 1.5;
        letter-spacing: 0.3px;
    }

    .home-landing {
        position: relative;
        max-width: 1320px;
        margin: 16px auto 0;
        padding: clamp(22px, 3vw, 30px);
        border-radius: 30px;
        background: var(--hero-grad);
        overflow: hidden;
        isolation: isolate;
    }

    .home-landing::before,
    .home-landing::after {
        content: "";
        position: absolute;
        pointer-events: none;
        border-radius: 999px;
        filter: blur(8px);
        z-index: 0;
    }

    .home-landing::before {
        width: 380px;
        height: 380px;
        top: -120px;
        left: 8%;
        background: radial-gradient(circle, var(--hero-glow), rgba(45, 212, 191, 0));
    }

    .home-landing::after {
        width: 420px;
        height: 420px;
        right: -90px;
        bottom: -140px;
        background: radial-gradient(circle, rgba(96, 165, 250, 0.32), rgba(96, 165, 250, 0));
    }

    .home-landing__card {
        position: relative;
        z-index: 1;
        border-radius: 28px;
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        background: var(--glass-bg);
        box-shadow: var(--soft-shadow);
        padding: clamp(24px, 4vw, 44px);
        color: var(--text-main);
    }

    .home-eyebrow {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.1);
        border: 1px solid rgba(148, 163, 184, 0.28);
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
    }

    [data-theme="dark"] .home-eyebrow {
        background: rgba(148, 163, 184, 0.15);
        border-color: rgba(148, 163, 184, 0.3);
    }

    .home-landing__card h1 {
        margin: 14px 0 0;
        font-size: clamp(36px, 5vw, 52px);
        font-weight: 600;
        line-height: 1.2;
        color: var(--text-main);
    }

    .home-landing__card p {
        margin: 14px 0 0;
        max-width: 760px;
        color: var(--text-soft);
        font-size: 19px;
    }

    .home-cta {
        margin-top: 24px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .home-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        border-radius: 14px;
        border: 1px solid transparent;
        padding: 11px 18px;
        font-size: 15px;
        font-weight: 700;
        color: #f8fafc;
        background: linear-gradient(135deg, #34d399, #10b981);
        transition: all .3s cubic-bezier(0.23, 1, 0.320, 1);
        box-shadow: 0 12px 24px rgba(16, 185, 129, 0.24);
    }

    .home-btn:hover {
        transform: scale(1.04);
        box-shadow: 0 16px 30px rgba(16, 185, 129, 0.3);
    }

    .home-btn--ghost {
        color: var(--text-main);
        border-color: var(--glass-border);
        background: rgba(255, 255, 255, 0.55);
        box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
    }

    [data-theme="dark"] .home-btn--ghost {
        color: #e2e8f0;
        background: rgba(30, 41, 59, 0.58);
        border-color: rgba(148, 163, 184, 0.35);
    }

    .home-main {
        margin-top: 22px;
        display: grid;
        gap: 18px;
    }

    .home-grid {
        display: grid;
        gap: 16px;
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .home-card {
        text-decoration: none;
        color: inherit;
        border-radius: 22px;
        padding: 20px;
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        background: var(--glass-bg);
        box-shadow: var(--soft-shadow);
        transition: all .3s cubic-bezier(0.23, 1, 0.320, 1);
    }

    .home-card:hover {
        transform: translateY(-6px);
        border-color: rgba(16, 185, 129, 0.45);
        box-shadow: 0 14px 36px rgba(15, 23, 42, 0.12);
    }

    .home-card__icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(16, 185, 129, 0.15);
        color: #059669;
        font-size: 20px;
        margin-bottom: 10px;
    }

    [data-theme="dark"] .home-card__icon {
        background: rgba(52, 211, 153, 0.2);
        color: #99f6e4;
    }

    .home-card h3 {
        margin: 0;
        font-size: 30px;
        font-weight: 600;
        color: var(--text-main);
    }

    .home-card p {
        margin: 8px 0 0;
        color: var(--text-soft);
        font-size: 16px;
    }

    .home-panel {
        border-radius: 22px;
        padding: 22px;
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        background: var(--glass-bg);
        box-shadow: var(--soft-shadow);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
    }

    .home-panel h2 {
        margin: 0;
        font-size: clamp(30px, 3.8vw, 42px);
        font-weight: 600;
        color: var(--text-main);
        line-height: 1.2;
    }

    .home-panel p {
        margin: 10px 0 0;
        color: var(--text-soft);
        font-size: 17px;
        max-width: 760px;
    }

    .home-panel__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .home-fade {
        opacity: 0;
        transform: translateY(16px);
        animation: homeFade .7s cubic-bezier(0.23, 1, 0.320, 1) forwards;
    }

    .home-fade--hero { animation-delay: .08s; }
    .home-fade--cards { animation-delay: .18s; }
    .home-fade--cta { animation-delay: .24s; }
    .home-fade--panel { animation-delay: .3s; }

    @keyframes homeFade {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 1180px) {
        .home-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 920px) {
        .home-panel {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @media (max-width: 700px) {
        .home-landing {
            margin-top: 10px;
            border-radius: 20px;
            padding: 14px;
        }

        .home-landing__card {
            border-radius: 20px;
            padding: 20px;
        }

        .home-grid {
            grid-template-columns: 1fr;
        }

        .home-btn,
        .home-panel__actions .home-btn {
            width: 100%;
        }

        .home-landing__card p {
            font-size: 17px;
        }
    }
</style>
{% endblock %}

{% block hero %}
<section class="home-landing home-fade home-fade--hero">
    <div class="home-landing__card">
        <span class="home-eyebrow">Football platform</span>
        <h1>Simple, fast and beautiful club experience</h1>
        <p>Manage trainings, teams, players, matches and equipment through one premium interface inspired by modern iOS and SaaS product design.</p>
        <div class="home-cta home-fade home-fade--cta">
            <a href="{{ path('front_equipement_index') }}" class="home-btn">Shop equipment</a>
            <a href="{{ path('app_front_matchs_index') }}" class="home-btn home-btn--ghost">Open matches</a>
        </div>
    </div>
</section>
{% endblock %}

{% block body %}
<div class="home-main">
    <section class="home-grid home-fade home-fade--cards">
        <a class="home-card" href="{{ path('front_entrainement_index') }}">
            <span class="home-card__icon"><i class="lucide-dumbbell"></i></span>
            <h3>Training</h3>
            <p>Plan sessions, track participation and keep team preparation organized.</p>
        </a>
        <a class="home-card" href="{{ path('app_front_equipes_index') }}">
            <span class="home-card__icon"><i class="lucide-users"></i></span>
            <h3>Teams</h3>
            <p>Explore squads, coaches and performance details in one place.</p>
        </a>
        <a class="home-card" href="{{ path('app_joueurs_index') }}">
            <span class="home-card__icon"><i class="lucide-user-plus"></i></span>
            <h3>Players</h3>
            <p>Open player profiles, roles and progression insights instantly.</p>
        </a>
        <a class="home-card" href="{{ path('app_front_matchs_index') }}">
            <span class="home-card__icon"><i class="lucide-trophy"></i></span>
            <h3>Matches</h3>
            <p>Review fixtures, lineups and match outcomes from one dashboard.</p>
        </a>
    </section>

    <section class="home-panel home-fade home-fade--panel">
        <div>
            <h2>Designed for modern club operations</h2>
            <p>Keep sponsors, inventory and weekly scheduling aligned with fast actions and clean visual hierarchy.</p>
        </div>
        <div class="home-panel__actions">
            <a href="{{ path('front_equipement_orders') }}" class="home-btn">View my orders</a>
            <a href="{{ path('front_sponsoring_index') }}" class="home-btn home-btn--ghost">Open sponsors</a>
        </div>
    </section>
</div>
{% endblock %}
