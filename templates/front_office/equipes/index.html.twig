{% extends 'front_office/base.html.twig' %}

{% block title %}Equipes - Sport Insight{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .teams-hero {
            position: relative;
            max-width: 1320px;
            margin: 16px auto 0;
            padding: clamp(16px, 3vw, 24px);
            border-radius: 28px;
            background: radial-gradient(circle at 22% 24%, rgba(52, 211, 153, 0.22), rgba(2, 6, 23, 0) 46%),
                        radial-gradient(circle at 80% 76%, rgba(96, 165, 250, 0.2), rgba(2, 6, 23, 0) 50%),
                        var(--hero-grad);
            overflow: hidden;
        }

        .teams-hero__card {
            position: relative;
            border-radius: 22px;
            border: 1px solid rgba(226, 232, 240, 0.26);
            overflow: hidden;
            padding: clamp(22px, 4vw, 34px);
            color: #f8fafc;
            isolation: isolate;
            box-shadow: var(--soft-shadow);
        }

        .teams-hero__card::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: url('{{ asset('images/equipe.jpg') }}');
            background-size: cover;
            background-position: center;
            transform: scale(1.04);
            z-index: 0;
        }

        .teams-hero__card::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, rgba(2, 6, 23, 0.84) 0%, rgba(2, 6, 23, 0.72) 46%, rgba(5, 150, 105, 0.58) 100%);
            z-index: 1;
        }

        .teams-hero__card > * {
            position: relative;
            z-index: 2;
        }

        .teams-hero__eyebrow {
            display: inline-flex;
            align-items: center;
            border-radius: 999px;
            padding: 6px 12px;
            border: 1px solid rgba(226, 232, 240, 0.34);
            background: rgba(2, 6, 23, 0.48);
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .teams-hero__card h1 {
            margin: 14px 0 0;
            font-size: clamp(30px, 5vw, 46px);
            line-height: 1.15;
            color: #f8fafc;
        }

        .teams-hero__card p {
            margin: 12px 0 0;
            max-width: 740px;
            color: #dbeafe;
            font-size: 17px;
        }

        .teams-shell {
            display: grid;
            gap: 18px;
        }

        .teams-toolbar {
            border-radius: 20px;
            border: 1px solid var(--border-color);
            background: var(--card-bg);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            padding: 18px;
            box-shadow: var(--soft-shadow);
            display: grid;
            gap: 14px;
        }

        .teams-toolbar__head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            flex-wrap: wrap;
        }

        .teams-toolbar__title {
            margin: 0;
            font-size: 28px;
            color: var(--text-main);
        }

        .teams-toolbar__meta {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border-radius: 999px;
            border: 1px solid var(--border-color);
            background: var(--surface);
            padding: 6px 12px;
            font-size: 13px;
            font-weight: 700;
            color: var(--text-soft);
        }

        .teams-search-form {
            display: grid;
            grid-template-columns: minmax(240px, 1.2fr) auto auto;
            gap: 10px;
            align-items: end;
            margin: 0;
            padding: 0;
            border: 0 !important;
            background: transparent !important;
            box-shadow: none !important;
            backdrop-filter: none !important;
            -webkit-backdrop-filter: none !important;
        }

        .teams-field {
            display: grid;
            gap: 6px;
        }

        .teams-field label {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-soft);
        }

        .teams-field input {
            width: 100%;
            min-height: 44px;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            background: var(--input-bg);
            color: var(--input-text);
            padding: 10px 12px;
            font-size: 14px;
            outline: none;
            transition: border-color .2s ease, box-shadow .2s ease;
        }

        .teams-field input:focus {
            border-color: rgba(16, 185, 129, 0.75);
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.12);
        }

        .teams-actions {
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .teams-btn {
            min-height: 44px;
            padding: 0 16px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 700;
            border: 1px solid transparent;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform .2s ease, box-shadow .2s ease, background-color .2s ease, border-color .2s ease;
            white-space: nowrap;
        }

        .teams-btn--primary {
            background: linear-gradient(135deg, #34d399, #10b981);
            color: #f8fafc;
            box-shadow: 0 12px 24px rgba(16, 185, 129, 0.22);
        }

        .teams-btn--primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 26px rgba(16, 185, 129, 0.3);
        }

        .teams-btn--ghost {
            border-color: var(--border-color);
            background: var(--surface);
            color: var(--text-main);
        }

        .teams-btn--ghost:hover {
            border-color: rgba(16, 185, 129, 0.55);
            background: rgba(16, 185, 129, 0.1);
        }

        .teams-loading {
            font-size: 12px;
            color: var(--text-soft);
        }

        .teams-hint {
            font-size: 12px;
            color: #d97706;
        }

        .teams-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 16px;
        }

        .team-card {
            border-radius: 20px;
            border: 1px solid var(--border-color);
            background: var(--card-bg);
            overflow: hidden;
            display: grid;
            box-shadow: var(--soft-shadow);
            transition: transform .24s ease, border-color .24s ease, box-shadow .24s ease;
        }

        .team-card:hover {
            transform: translateY(-5px);
            border-color: rgba(16, 185, 129, 0.45);
            box-shadow: 0 18px 32px rgba(2, 6, 23, 0.22);
        }

        .team-card__logo-wrap {
            padding: 24px 18px 16px;
            display: flex;
            justify-content: center;
        }

        .team-card__logo {
            width: 120px;
            height: 120px;
            border-radius: 18px;
            border: 1px solid var(--border-color);
            background: var(--surface);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .team-card__logo img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .team-card__fallback {
            font-size: 30px;
            font-weight: 800;
            color: var(--text-soft);
        }

        .team-card__content {
            padding: 0 16px 16px;
            display: grid;
            gap: 8px;
        }

        .team-card__name {
            margin: 0;
            font-size: 20px;
            line-height: 1.25;
            color: var(--text-main);
            text-align: center;
        }

        .team-card__coach {
            margin: 0;
            min-height: 20px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            font-size: 13px;
            color: var(--text-soft);
            text-align: center;
        }

        .team-card__coach i {
            color: var(--primary);
            font-size: 14px;
        }

        .team-card__coach--muted {
            opacity: 0.85;
        }

        .team-card__footer {
            padding-top: 10px;
            border-top: 1px solid var(--border-color);
        }

        .team-card__link {
            width: 100%;
            min-height: 40px;
            border-radius: 12px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 700;
            border: 1px solid rgba(16, 185, 129, 0.35);
            color: #f8fafc;
            background: linear-gradient(135deg, #34d399, #10b981);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform .2s ease, box-shadow .2s ease;
            box-shadow: 0 12px 22px rgba(16, 185, 129, 0.2);
        }

        .team-card__link:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 28px rgba(16, 185, 129, 0.3);
            color: #f8fafc;
        }

        .teams-empty-state {
            border-radius: 20px;
            border: 1px dashed var(--border-color);
            background: var(--card-bg);
            box-shadow: var(--soft-shadow);
            padding: 44px 20px;
            text-align: center;
        }

        .teams-empty-state__icon {
            width: 68px;
            height: 68px;
            margin: 0 auto 14px;
            border-radius: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(16, 185, 129, 0.22);
            background: rgba(16, 185, 129, 0.12);
            color: var(--primary);
            font-size: 28px;
        }

        .teams-empty-state h2 {
            margin: 0;
            font-size: 22px;
            color: var(--text-main);
        }

        .teams-empty-state p {
            margin: 10px 0 0;
            color: var(--text-soft);
            font-size: 14px;
        }

        [data-theme="dark"] .teams-toolbar__meta {
            background: rgba(15, 23, 42, 0.6);
        }

        [data-theme="dark"] .team-card__logo {
            background: rgba(15, 23, 42, 0.6);
        }

        @media (max-width: 760px) {
            .teams-hero {
                margin-top: 10px;
                border-radius: 20px;
                padding: 12px;
            }

            .teams-hero__card {
                border-radius: 18px;
                padding: 18px;
            }

            .teams-toolbar {
                border-radius: 16px;
            }

            .teams-search-form {
                grid-template-columns: 1fr;
            }

            .teams-actions {
                width: 100%;
            }

            .teams-btn {
                flex: 1;
            }
        }
    </style>
{% endblock %}

{% block hero %}
    <section class="teams-hero">
        <div class="teams-hero__card">
            <span class="teams-hero__eyebrow">Squads</span>
            <h1>Recherchez les equipes en temps reel</h1>
            <p>Entrez un nom d'equipe pour filtrer instantanement la liste, sans recharger la page.</p>
        </div>
    </section>
{% endblock %}

{% block body %}
    <section class="teams-shell">
        <div class="teams-toolbar">
            <div class="teams-toolbar__head">
                <h2 class="teams-toolbar__title">Equipes</h2>
                <div class="teams-toolbar__meta">
                    <span><strong id="teams-count">{{ equipes|length }}</strong> equipe(s)</span>
                    <span id="teams-loading" class="teams-loading" hidden>Actualisation...</span>
                    <span id="teams-hint" class="teams-hint" hidden></span>
                </div>
            </div>

            <form id="team-search-form" class="teams-search-form" method="GET" action="{{ path('app_front_equipes_index') }}" data-search-url="{{ path('app_front_equipes_search') }}">
                <div class="teams-field">
                    <label for="team">Nom de l'equipe</label>
                    <input type="text" id="team" name="team" value="{{ team }}" placeholder="Ex: Bayern, Barca, Esperance">
                </div>

                <div class="teams-actions">
                    <button type="submit" class="teams-btn teams-btn--primary">Rechercher</button>
                </div>

                <div class="teams-actions">
                    <a href="{{ path('app_front_equipes_index') }}" class="teams-btn teams-btn--ghost">Reinitialiser</a>
                </div>
            </form>
        </div>

        <div id="teams-results">
            {% include 'front_office/equipes/_cards.html.twig' with {'equipes': equipes} %}
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            const form = document.getElementById('team-search-form');
            const input = document.getElementById('team');
            const results = document.getElementById('teams-results');
            const counter = document.getElementById('teams-count');
            const loading = document.getElementById('teams-loading');
            const hint = document.getElementById('teams-hint');

            if (!form || !input || !results) {
                return;
            }

            const MIN_TEAM_LENGTH = 2;
            const INPUT_DEBOUNCE_MS = 450;
            const endpoint = form.dataset.searchUrl;
            let debounceTimer = null;
            let requestController = null;
            let requestVersion = 0;
            let lastSignature = '';

            const setLoading = (active) => {
                if (loading) {
                    loading.hidden = !active;
                }
                results.style.opacity = active ? '0.55' : '1';
            };

            const setHint = (message) => {
                if (!hint) {
                    return;
                }
                hint.textContent = message;
                hint.hidden = message === '';
            };

            const refreshResults = () => {
                if (!endpoint) {
                    return;
                }

                const teamValue = input.value.trim();
                if (teamValue !== '' && teamValue.length < MIN_TEAM_LENGTH) {
                    if (requestController) {
                        requestController.abort();
                        requestController = null;
                    }
                    setHint(`Tapez au moins ${MIN_TEAM_LENGTH} caracteres.`);
                    setLoading(false);
                    return;
                }

                setHint('');
                requestVersion += 1;
                const localVersion = requestVersion;

                if (requestController) {
                    requestController.abort();
                }

                requestController = new AbortController();
                setLoading(true);

                const params = new URLSearchParams(new FormData(form));
                const signature = params.toString();
                if (signature === lastSignature) {
                    setLoading(false);
                    return;
                }
                lastSignature = signature;

                fetch(`${endpoint}?${params.toString()}`, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    signal: requestController.signal
                })
                    .then((response) => {
                        if (!response.ok) {
                            throw new Error('Search request failed');
                        }
                        return response.json();
                    })
                    .then((payload) => {
                        if (typeof payload.html === 'string') {
                            results.innerHTML = payload.html;
                        }
                        if (counter && typeof payload.count === 'number') {
                            counter.textContent = payload.count;
                        }
                    })
                    .catch((error) => {
                        if (error.name !== 'AbortError') {
                            console.error(error);
                            setHint('Erreur reseau, reessayez.');
                        }
                    })
                    .finally(() => {
                        if (localVersion === requestVersion) {
                            setLoading(false);
                        }
                    });
            };

            form.addEventListener('submit', (event) => {
                event.preventDefault();
                refreshResults();
            });

            input.addEventListener('input', () => {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(refreshResults, INPUT_DEBOUNCE_MS);
            });
        })();
    </script>
{% endblock %}
