{% extends 'front_office/base.html.twig' %}

{% block title %}Create Account - Sport Insight{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .auth-hero {
            position: relative;
            max-width: 1320px;
            margin: 16px auto 0;
            padding: clamp(16px, 3vw, 24px);
            border-radius: 28px;
            background: radial-gradient(circle at 20% 24%, rgba(52, 211, 153, 0.24), rgba(2, 6, 23, 0) 46%),
                        radial-gradient(circle at 78% 76%, rgba(96, 165, 250, 0.2), rgba(2, 6, 23, 0) 50%),
                        var(--hero-grad);
            overflow: hidden;
        }

        .auth-hero__card {
            position: relative;
            border-radius: 22px;
            border: 1px solid rgba(226, 232, 240, 0.3);
            overflow: hidden;
            padding: clamp(22px, 4vw, 34px);
            color: #f8fafc;
            isolation: isolate;
            box-shadow: var(--soft-shadow);
        }

        .auth-hero__card::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: url('{{ asset('images/bg.webp') }}');
            background-size: cover;
            background-position: center;
            transform: scale(1.04);
            z-index: 0;
        }

        .auth-hero__card::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, rgba(2, 6, 23, 0.86) 0%, rgba(2, 6, 23, 0.72) 44%, rgba(16, 185, 129, 0.52) 100%);
            z-index: 1;
        }

        .auth-hero__card > * {
            position: relative;
            z-index: 2;
        }

        .auth-hero__eyebrow {
            display: inline-flex;
            align-items: center;
            border-radius: 999px;
            padding: 6px 12px;
            border: 1px solid rgba(226, 232, 240, 0.34);
            background: rgba(2, 6, 23, 0.44);
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .auth-hero__card h1 {
            margin: 14px 0 0;
            font-size: clamp(30px, 5vw, 46px);
            line-height: 1.1;
            color: #f8fafc;
        }

        .auth-hero__card p {
            margin: 12px 0 0;
            max-width: 760px;
            color: #dbeafe;
            font-size: 17px;
        }

        .auth-shell {
            width: min(1160px, 100%);
            margin: 0 auto;
            display: grid;
            gap: 18px;
        }

        .auth-panel {
            border-radius: 24px;
            border: 1px solid var(--border-color);
            background: var(--card-bg);
            box-shadow: var(--soft-shadow);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            overflow: hidden;
            display: grid;
            grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1.1fr);
        }

        .auth-panel__aside {
            padding: 24px;
            position: relative;
            border-right: 1px solid var(--border-color);
            background: linear-gradient(165deg, rgba(16, 185, 129, 0.16), rgba(59, 130, 246, 0.1));
            display: grid;
            align-content: start;
            gap: 16px;
        }

        .auth-panel__badge {
            width: fit-content;
            border-radius: 999px;
            border: 1px solid rgba(16, 185, 129, 0.4);
            background: rgba(16, 185, 129, 0.12);
            color: #059669;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 6px 10px;
        }

        .auth-panel__aside h2 {
            margin: 0;
            font-size: 30px;
            color: var(--text-main);
            line-height: 1.1;
        }

        .auth-panel__aside p {
            margin: 0;
            color: var(--text-soft);
            font-size: 14px;
        }

        .auth-points {
            margin: 0;
            padding: 0;
            list-style: none;
            display: grid;
            gap: 8px;
        }

        .auth-points li {
            border-radius: 12px;
            border: 1px solid var(--border-color);
            background: var(--surface);
            padding: 10px 12px;
            color: var(--text-main);
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .auth-points i {
            color: var(--primary);
            font-size: 14px;
        }

        .auth-panel__form {
            padding: 24px;
            display: grid;
            align-content: start;
            gap: 14px;
        }

        .auth-panel__form h3 {
            margin: 0;
            font-size: 32px;
            color: var(--text-main);
        }

        .auth-panel__form p {
            margin: 0;
            color: var(--text-soft);
            font-size: 14px;
        }

        .auth-form {
            display: grid;
            gap: 12px;
        }

        .auth-grid-2 {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .auth-field {
            display: grid;
            gap: 6px;
        }

        .auth-label {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-soft);
            margin: 0;
        }

        .auth-input {
            width: 100%;
            min-height: 46px;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            background: var(--input-bg);
            color: var(--input-text);
            padding: 11px 13px;
            font-size: 14px;
            outline: none;
            transition: border-color .2s ease, box-shadow .2s ease;
        }

        .auth-input:focus {
            border-color: rgba(16, 185, 129, 0.75);
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.12);
        }

        .auth-help {
            margin: 0;
            font-size: 12px;
            color: var(--text-soft);
            line-height: 1.5;
        }

        .auth-help code {
            font-size: 11px;
            color: #059669;
            background: rgba(16, 185, 129, 0.14);
            border: 1px solid rgba(16, 185, 129, 0.22);
            border-radius: 6px;
            padding: 2px 6px;
        }

        .auth-errors {
            margin: 0;
            color: #dc2626;
            font-size: 12px;
            line-height: 1.4;
        }

        .auth-errors ul {
            margin: 0;
            padding-left: 18px;
        }

        .auth-errors li {
            margin: 2px 0;
        }

        .auth-alert {
            border-radius: 12px;
            border: 1px solid rgba(239, 68, 68, 0.36);
            background: rgba(239, 68, 68, 0.12);
            color: #dc2626;
            padding: 10px 12px;
            font-size: 13px;
            font-weight: 600;
        }

        .auth-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 2px;
        }

        .auth-btn {
            min-height: 44px;
            padding: 0 16px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            border: 1px solid transparent;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease, background-color .2s ease;
        }

        .auth-btn--primary {
            color: #f8fafc;
            background: linear-gradient(135deg, #34d399, #10b981);
            border-color: rgba(16, 185, 129, 0.35);
            box-shadow: 0 12px 22px rgba(16, 185, 129, 0.2);
        }

        .auth-btn--primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 26px rgba(16, 185, 129, 0.3);
            color: #f8fafc;
        }

        .auth-btn--ghost {
            border-color: var(--border-color);
            background: var(--surface);
            color: var(--text-main);
        }

        .auth-btn--ghost:hover {
            border-color: rgba(16, 185, 129, 0.5);
            background: rgba(16, 185, 129, 0.1);
            color: var(--text-main);
        }

        .auth-switch {
            margin-top: 4px;
            padding-top: 12px;
            border-top: 1px solid var(--border-color);
            display: grid;
            gap: 8px;
        }

        .auth-switch p {
            margin: 0;
            font-size: 13px;
            color: var(--text-soft);
        }

        [data-theme="dark"] .auth-panel__aside,
        [data-theme="dark"] .auth-points li,
        [data-theme="dark"] .auth-btn--ghost {
            background: rgba(15, 23, 42, 0.6);
        }

        @media (max-width: 980px) {
            .auth-panel {
                grid-template-columns: 1fr;
            }

            .auth-panel__aside {
                border-right: 0;
                border-bottom: 1px solid var(--border-color);
            }
        }

        @media (max-width: 760px) {
            .auth-hero {
                margin-top: 10px;
                border-radius: 20px;
                padding: 12px;
            }

            .auth-hero__card {
                border-radius: 18px;
                padding: 18px;
            }

            .auth-panel__aside,
            .auth-panel__form {
                padding: 16px;
            }

            .auth-panel__form h3 {
                font-size: 28px;
            }

            .auth-grid-2 {
                grid-template-columns: 1fr;
            }

            .auth-actions {
                flex-direction: column;
            }

            .auth-actions .auth-btn {
                width: 100%;
            }
        }
    </style>
{% endblock %}

{% block hero %}
    <section class="auth-hero">
        <div class="auth-hero__card">
            <span class="auth-hero__eyebrow">Registration</span>
            <h1>Create your Sport Insight account</h1>
            <p>Join the platform to manage training, matches, teams, and shopping in one place.</p>
        </div>
    </section>
{% endblock %}

{% block body %}
    <section class="auth-shell">
        <article class="auth-panel">
            <aside class="auth-panel__aside">
                <span class="auth-panel__badge">New account</span>
                <h2>Build your profile in a minute.</h2>
                <p>Complete the form to unlock your personalized Sport Insight workspace.</p>

                <ul class="auth-points">
                    <li><i class="lucide-user-round"></i> Personal profile and role mapping</li>
                    <li><i class="lucide-shield"></i> Access policy based on your email domain</li>
                    <li><i class="lucide-activity"></i> Track your activity across modules</li>
                </ul>
            </aside>

            <div class="auth-panel__form">
                <h3>Create account</h3>
                <p>Fill in your information to get started.</p>

                {{ form_start(registrationForm, {'attr': {'class': 'auth-form'}}) }}
                    <div class="auth-grid-2">
                        <div class="auth-field">
                            {{ form_label(registrationForm.prenom, null, {'label_attr': {'class': 'auth-label'}}) }}
                            {{ form_widget(registrationForm.prenom, {'attr': {'class': 'auth-input', 'placeholder': 'First name'}}) }}
                            <div class="auth-errors">{{ form_errors(registrationForm.prenom) }}</div>
                        </div>

                        <div class="auth-field">
                            {{ form_label(registrationForm.nom, null, {'label_attr': {'class': 'auth-label'}}) }}
                            {{ form_widget(registrationForm.nom, {'attr': {'class': 'auth-input', 'placeholder': 'Last name'}}) }}
                            <div class="auth-errors">{{ form_errors(registrationForm.nom) }}</div>
                        </div>
                    </div>

                    <div class="auth-field">
                        {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'auth-label'}}) }}
                        {{ form_widget(registrationForm.email, {'attr': {'class': 'auth-input', 'placeholder': 'name@example.com'}}) }}
                        <p class="auth-help">
                            Use <code>@player.com</code> for players, <code>@coach.com</code> for coaches, and <code>@esprit.tn</code> for admins.
                        </p>
                        <div class="auth-errors">{{ form_errors(registrationForm.email) }}</div>
                    </div>

                    <div class="auth-grid-2">
                        <div class="auth-field">
                            {{ form_label(registrationForm.telephone, null, {'label_attr': {'class': 'auth-label'}}) }}
                            {{ form_widget(registrationForm.telephone, {'attr': {'class': 'auth-input', 'placeholder': '+216 ...'}}) }}
                            <div class="auth-errors">{{ form_errors(registrationForm.telephone) }}</div>
                        </div>

                        <div class="auth-field">
                            {{ form_label(registrationForm.dateNaissance, null, {'label_attr': {'class': 'auth-label'}}) }}
                            {{ form_widget(registrationForm.dateNaissance, {'attr': {'class': 'auth-input'}}) }}
                            <div class="auth-errors">{{ form_errors(registrationForm.dateNaissance) }}</div>
                        </div>
                    </div>

                    <div class="auth-grid-2">
                        <div class="auth-field">
                            {{ form_label(registrationForm.plainPassword.first, null, {'label_attr': {'class': 'auth-label'}}) }}
                            {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'auth-input', 'placeholder': 'Minimum 8 characters'}}) }}
                            <div class="auth-errors">{{ form_errors(registrationForm.plainPassword.first) }}</div>
                        </div>

                        <div class="auth-field">
                            {{ form_label(registrationForm.plainPassword.second, null, {'label_attr': {'class': 'auth-label'}}) }}
                            {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'auth-input', 'placeholder': 'Repeat password'}}) }}
                            <div class="auth-errors">{{ form_errors(registrationForm.plainPassword.second) }}</div>
                        </div>
                    </div>

                    {% if not registrationForm.vars.valid %}
                        <div class="auth-alert">Please review the highlighted fields and try again.</div>
                    {% endif %}
                    <div class="auth-errors">{{ form_errors(registrationForm) }}</div>

                    <div class="auth-actions">
                        <button type="submit" class="auth-btn auth-btn--primary">
                            <i class="lucide-user-round-plus"></i>
                            Create account
                        </button>
                        <a href="{{ path('app_login') }}" class="auth-btn auth-btn--ghost">
                            <i class="lucide-arrow-left"></i>
                            Back to sign in
                        </a>
                    </div>
                {{ form_end(registrationForm) }}

                <div class="auth-switch">
                    <p>Already registered?</p>
                    <a href="{{ path('app_login') }}" class="auth-btn auth-btn--ghost">
                        <i class="lucide-log-in"></i>
                        Sign in
                    </a>
                </div>
            </div>
        </article>
    </section>
{% endblock %}
