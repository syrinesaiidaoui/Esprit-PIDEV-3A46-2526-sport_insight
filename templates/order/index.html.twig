{% extends 'back_office/base.html.twig' %}

{% block title %}Commandes - Admin{% endblock %}
{% block page_title %}Gestion des commandes{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_order_new') }}" class="btn btn-primary btn-add-product">Nouvelle commande</a>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .orders-bi-grid {
            display: grid;
            grid-template-columns: repeat(12, minmax(0, 1fr));
            gap: 14px;
            margin: 16px 0 18px;
        }

        .orders-bi-card {
            grid-column: span 4;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 14px;
            box-shadow: var(--card-shadow);
            min-height: 210px;
        }

        .orders-bi-card--wide {
            grid-column: span 8;
        }

        .orders-bi-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 8px;
        }

        .orders-bi-head h3,
        .orders-bi-head h4 {
            margin: 0;
            font-size: 19px;
            color: var(--text-primary);
        }

        .orders-bi-head p {
            margin: 3px 0 0;
            color: var(--text-muted);
            font-size: 13px;
        }

        .orders-bi-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            justify-content: flex-end;
        }

        .orders-bi-chip {
            border-radius: 999px;
            border: 1px solid var(--border-color);
            background: var(--bg-tertiary);
            color: var(--text-secondary);
            padding: 4px 9px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .2px;
        }

        .orders-bi-canvas {
            position: relative;
            height: 240px;
        }

        .orders-bi-canvas--short {
            height: 220px;
        }

        @media (max-width: 1200px) {
            .orders-bi-card,
            .orders-bi-card--wide {
                grid-column: span 12;
            }
        }
    </style>
{% endblock %}

{% block body %}
{% set stats = stats|default({
    total: orders|length,
    pending: 0,
    confirmed: 0,
    shipped: 0,
    delivered: 0,
    rejected: 0,
    revenue: 0
}) %}
{% set page = page|default(1) %}
{% set totalPages = totalPages|default(1) %}
{% set allowedTransitions = allowedTransitions|default({}) %}
{% set orderDashboard = orderDashboard|default({
    trend: {labels: [], orders: [], revenue: []},
    status: {labels: [], values: []},
    paymentMethods: {labels: [], values: []},
    topProducts: {labels: [], qtyValues: [], revenueValues: []},
    totals: {orders: 0, revenue: 0, avgBasket: 0, deliveryRate: 0}
}) %}

<div class="admin-kpis">
    <div class="stat-card">
        <div class="stat-card-label">Commandes</div>
        <div class="stat-card-value">{{ stats.total }}</div>
        <div class="stat-card-sub">Total enregistre</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">A traiter</div>
        <div class="stat-card-value">{{ stats.pending }}</div>
        <div class="stat-card-sub">En attente</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">Validees</div>
        <div class="stat-card-value">{{ stats.confirmed + stats.shipped + stats.delivered }}</div>
        <div class="stat-card-sub">Pipeline actif</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">Rejetees</div>
        <div class="stat-card-value">{{ stats.rejected }}</div>
        <div class="stat-card-sub">Demandes refusees</div>
    </div>
</div>

<div class="orders-bi-grid">
    <section class="orders-bi-card orders-bi-card--wide">
        <div class="orders-bi-head">
            <div>
                <h3>Dashboard commandes</h3>
                <p>Vue synthétique sur les 6 derniers mois</p>
            </div>
            <div class="orders-bi-meta">
                <span class="orders-bi-chip">{{ orderDashboard.totals.orders }} cmd</span>
                <span class="orders-bi-chip">{{ orderDashboard.totals.revenue|number_format(2, ',', ' ') }} USD</span>
                <span class="orders-bi-chip">Panier: {{ orderDashboard.totals.avgBasket|number_format(2, ',', ' ') }} USD</span>
                <span class="orders-bi-chip">Livraisons: {{ orderDashboard.totals.deliveryRate|number_format(1, ',', ' ') }}%</span>
            </div>
        </div>
        <div class="orders-bi-canvas">
            <canvas id="ordersTrendChart"></canvas>
        </div>
    </section>

    <section class="orders-bi-card">
        <div class="orders-bi-head">
            <div>
                <h4>Statuts commandes</h4>
                <p>Répartition globale</p>
            </div>
        </div>
        <div class="orders-bi-canvas orders-bi-canvas--short">
            <canvas id="ordersStatusChart"></canvas>
        </div>
    </section>

    <section class="orders-bi-card">
        <div class="orders-bi-head">
            <div>
                <h4>Modes de paiement</h4>
                <p>Online vs livraison</p>
            </div>
        </div>
        <div class="orders-bi-canvas orders-bi-canvas--short">
            <canvas id="ordersPaymentChart"></canvas>
        </div>
    </section>

    <section class="orders-bi-card orders-bi-card--wide">
        <div class="orders-bi-head">
            <div>
                <h4>Top produits commandés</h4>
                <p>Volumes et revenus associés</p>
            </div>
        </div>
        <div class="orders-bi-canvas orders-bi-canvas--short">
            <canvas id="ordersTopProductsChart"></canvas>
        </div>
    </section>
</div>

<div class="data-table">
    <div class="data-table-header">
        <div class="toolbar">
            <div>
                <h3>Commandes clients</h3>
                <p class="muted">Valider, rejeter et suivre la progression logistique</p>
            </div>
            <form method="GET">
                <input type="text" name="search" class="form-control" style="min-width:220px;" placeholder="Produit ou email..." value="{{ searchTerm|default('') }}">
                <select name="status" class="form-select">
                    <option value="">Tous statuts</option>
                    <option value="pending" {% if statusFilter == 'pending' %}selected{% endif %}>En attente</option>
                    <option value="confirmed" {% if statusFilter == 'confirmed' %}selected{% endif %}>Confirmee</option>
                    <option value="shipped" {% if statusFilter == 'shipped' %}selected{% endif %}>Expediee</option>
                    <option value="delivered" {% if statusFilter == 'delivered' %}selected{% endif %}>Livree</option>
                    <option value="rejected" {% if statusFilter == 'rejected' %}selected{% endif %}>Rejetee</option>
                </select>
                <button type="submit" class="btn btn-primary">Filtrer</button>
                <a href="{{ path('app_order_index') }}" class="btn btn-outline-secondary">Reinit.</a>
            </form>
        </div>
    </div>

    <div style="overflow-x:auto;">
        {% set statusLabels = {
            'confirmed': 'Confirmer',
            'shipped': 'Expédier',
            'delivered': 'Livrer',
            'rejected': 'Rejeter'
        } %}
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Telephone</th>
                    <th>Email</th>
                    <th>Produits</th>
                    <th>Client</th>
                    <th>Total</th>
                    <th>Paiement</th>
                    <th>Statut paiement</th>
                    <th>Date</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for order in orders %}
                    <tr>
                        <td>#{{ order.id }}</td>
                        <td>{{ order.entraineur ? order.entraineur.prenom ~ ' ' ~ order.entraineur.nom : 'Client' }}</td>
                        <td>{{ order.contactEmail ?: (order.entraineur ? order.entraineur.email : '-') }}</td>
                        <td>
                            {% if order.items|length > 0 %}
                                {{ order.items|length }} produit(s)
                            {% else %}
                                {{ order.product ? order.product.name : '-' }}
                            {% endif %}
                        </td>
                        <td>{{ order.contactPhone ?: (order.entraineur ? order.entraineur.telephone : '-') }}</td>
                        <td>{{ (order.totalAmount ?: order.computedTotal)|number_format(2, ',', ' ') }} USD</td>
                        <td>
                            {% if order.paymentMethod == 'online' %}
                                <span class="badge-info">En ligne</span>
                            {% else %}
                                <span class="badge-warning">Livraison</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if order.paymentStatus == 'paid' %}
                                <span class="badge-success">Paid</span>
                            {% elseif order.paymentStatus == 'failed' %}
                                <span class="badge-danger">Failed</span>
                            {% else %}
                                <span class="badge-warning">Pending</span>
                            {% endif %}
                        </td>
                        <td>{{ order.orderDate|date('d/m/Y H:i') }}</td>
                        <td>
                            {% if order.status == 'pending' %}
                                <span class="badge-warning">En attente</span>
                            {% elseif order.status == 'confirmed' %}
                                <span class="badge-info">Confirmee</span>
                            {% elseif order.status == 'shipped' %}
                                <span class="badge-info">Expediee</span>
                            {% elseif order.status == 'delivered' %}
                                <span class="badge-success">Livree</span>
                            {% elseif order.status == 'rejected' %}
                                <span class="badge-danger">Rejetee</span>
                            {% else %}
                                <span class="badge-warning">{{ order.status }}</span>
                            {% endif %}
                        </td>
                        <td>
                            <div style="display:flex; gap:6px; flex-wrap:wrap; align-items:center;">
                                <a href="{{ path('app_order_show', {id: order.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                                {% set allowed = allowedTransitions[order.id]|default([]) %}
                                {% if allowed|length > 0 %}
                                    <form method="POST"
                                          class="d-flex gap-2 align-items-center js-status-form"
                                          data-action-template="{{ path('app_order_change_status', {id: order.id, status: 'STATUS_PLACEHOLDER'}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('order_status_' ~ order.id) }}">
                                        <select name="status" class="form-select form-select-sm js-status-select" aria-label="Choisir statut">
                                            <option value="" selected disabled>Choisir...</option>
                                            {% for status in allowed %}
                                                <option value="{{ status }}">{{ statusLabels[status]|default(status) }}</option>
                                            {% endfor %}
                                        </select>
                                        <button class="btn btn-sm btn-success" type="submit">Mettre à jour</button>
                                    </form>
                                {% else %}
                                    <span class="muted-soft">Aucune action disponible</span>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="11" style="text-align:center;" class="muted-soft">Aucune commande trouvee</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const dashboardData = {{ orderDashboard|json_encode|raw }};
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            const textColor = isDark ? '#e2e8f0' : '#0f172a';
            const mutedColor = isDark ? '#94a3b8' : '#475569';
            const gridColor = isDark ? 'rgba(148, 163, 184, 0.16)' : 'rgba(148, 163, 184, 0.25)';

            const formatMoney = (amount) => {
                const num = Number(amount || 0);
                return num.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' USD';
            };

            if (typeof Chart !== 'undefined') {
                const commonLegend = {
                    labels: {
                        color: textColor,
                        boxWidth: 12,
                        boxHeight: 12,
                    },
                };

                const trendCanvas = document.getElementById('ordersTrendChart');
                if (trendCanvas) {
                    new Chart(trendCanvas, {
                        type: 'bar',
                        data: {
                            labels: dashboardData.trend.labels,
                            datasets: [
                                {
                                    type: 'bar',
                                    label: 'Commandes',
                                    data: dashboardData.trend.orders,
                                    backgroundColor: 'rgba(34, 197, 94, 0.55)',
                                    borderColor: '#22c55e',
                                    borderWidth: 1.2,
                                    yAxisID: 'y',
                                    borderRadius: 6,
                                },
                                {
                                    type: 'line',
                                    label: 'Chiffre d\'affaires',
                                    data: dashboardData.trend.revenue,
                                    borderColor: '#38bdf8',
                                    backgroundColor: 'rgba(56, 189, 248, 0.2)',
                                    borderWidth: 2,
                                    pointRadius: 3,
                                    pointHoverRadius: 4,
                                    tension: 0.35,
                                    yAxisID: 'y1',
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: commonLegend,
                                tooltip: {
                                    callbacks: {
                                        label: function (context) {
                                            if (context.dataset.yAxisID === 'y1') {
                                                return context.dataset.label + ': ' + formatMoney(context.parsed.y);
                                            }
                                            return context.dataset.label + ': ' + context.parsed.y;
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: {
                                    ticks: { color: mutedColor },
                                    grid: { color: gridColor }
                                },
                                y: {
                                    beginAtZero: true,
                                    ticks: { color: mutedColor, precision: 0 },
                                    grid: { color: gridColor }
                                },
                                y1: {
                                    beginAtZero: true,
                                    position: 'right',
                                    ticks: {
                                        color: mutedColor,
                                        callback: (value) => Number(value).toLocaleString('fr-FR') + ' USD'
                                    },
                                    grid: { drawOnChartArea: false }
                                }
                            }
                        }
                    });
                }

                const statusCanvas = document.getElementById('ordersStatusChart');
                if (statusCanvas) {
                    new Chart(statusCanvas, {
                        type: 'doughnut',
                        data: {
                            labels: dashboardData.status.labels,
                            datasets: [{
                                data: dashboardData.status.values,
                                backgroundColor: ['#f59e0b', '#38bdf8', '#6366f1', '#22c55e', '#ef4444'],
                                borderColor: isDark ? '#0f172a' : '#ffffff',
                                borderWidth: 2,
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { ...commonLegend, position: 'bottom' }
                            }
                        }
                    });
                }

                const paymentCanvas = document.getElementById('ordersPaymentChart');
                if (paymentCanvas) {
                    new Chart(paymentCanvas, {
                        type: 'doughnut',
                        data: {
                            labels: dashboardData.paymentMethods.labels,
                            datasets: [{
                                data: dashboardData.paymentMethods.values,
                                backgroundColor: ['#22d3ee', '#f59e0b', '#94a3b8'],
                                borderColor: isDark ? '#0f172a' : '#ffffff',
                                borderWidth: 2,
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { ...commonLegend, position: 'bottom' }
                            }
                        }
                    });
                }

                const topProductsCanvas = document.getElementById('ordersTopProductsChart');
                if (topProductsCanvas) {
                    new Chart(topProductsCanvas, {
                        type: 'bar',
                        data: {
                            labels: dashboardData.topProducts.labels,
                            datasets: [{
                                label: 'Quantité commandée',
                                data: dashboardData.topProducts.qtyValues,
                                backgroundColor: 'rgba(59, 130, 246, 0.62)',
                                borderColor: '#3b82f6',
                                borderWidth: 1.2,
                                borderRadius: 6,
                            }]
                        },
                        options: {
                            indexAxis: 'y',
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: commonLegend,
                                tooltip: {
                                    callbacks: {
                                        afterLabel: function (context) {
                                            const idx = context.dataIndex;
                                            const revenue = dashboardData.topProducts.revenueValues[idx] ?? 0;
                                            return 'CA: ' + formatMoney(revenue);
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: {
                                    beginAtZero: true,
                                    ticks: { color: mutedColor, precision: 0 },
                                    grid: { color: gridColor }
                                },
                                y: {
                                    ticks: { color: mutedColor },
                                    grid: { color: 'transparent' }
                                }
                            }
                        }
                    });
                }
            }

            document.querySelectorAll('.js-status-form').forEach(function (form) {
                const select = form.querySelector('.js-status-select');
                const template = form.dataset.actionTemplate || '';

                form.addEventListener('submit', function (e) {
                    const value = select?.value || '';
                    if (!value) {
                        e.preventDefault();
                        alert('Choisissez un statut.');
                        return;
                    }
                    if (template.includes('STATUS_PLACEHOLDER')) {
                        form.action = template.replace('STATUS_PLACEHOLDER', value);
                    }
                });
            });
        });
    </script>

    {% if totalPages > 1 %}
        <nav aria-label="Order pagination" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item{% if page == 1 %} disabled{% endif %}">
                    <a class="page-link" href="?search={{ searchTerm|default('') }}&status={{ statusFilter|default('') }}&sort={{ sortBy|default('orderDate') }}&order={{ sortOrder|default('DESC') }}&page={{ page-1 }}">Precedent</a>
                </li>
                {% for p in 1..totalPages %}
                    <li class="page-item{% if p == page %} active{% endif %}"><a class="page-link" href="?search={{ searchTerm|default('') }}&status={{ statusFilter|default('') }}&sort={{ sortBy|default('orderDate') }}&order={{ sortOrder|default('DESC') }}&page={{ p }}">{{ p }}</a></li>
                {% endfor %}
                <li class="page-item{% if page == totalPages %} disabled{% endif %}">
                    <a class="page-link" href="?search={{ searchTerm|default('') }}&status={{ statusFilter|default('') }}&sort={{ sortBy|default('orderDate') }}&order={{ sortOrder|default('DESC') }}&page={{ page+1 }}">Suivant</a>
                </li>
            </ul>
        </nav>
    {% endif %}
</div>
{% endblock %}
