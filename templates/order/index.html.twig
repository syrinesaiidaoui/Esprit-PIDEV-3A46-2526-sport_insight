{% extends 'back_office/base.html.twig' %}

{% block title %}Commandes - Admin{% endblock %}
{% block page_title %}Gestion des commandes{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_order_new') }}" class="btn btn-primary btn-add-product">Nouvelle commande</a>
{% endblock %}

{% block body %}
{% set stats = stats|default({
    total: orders|length,
    pending: 0,
    confirmed: 0,
    shipped: 0,
    delivered: 0,
    rejected: 0,
    revenue: 0
}) %}
{% set page = page|default(1) %}
{% set totalPages = totalPages|default(1) %}
{% set allowedTransitions = allowedTransitions|default({}) %}

<div class="admin-kpis">
    <div class="stat-card">
        <div class="stat-card-label">Commandes</div>
        <div class="stat-card-value">{{ stats.total }}</div>
        <div class="stat-card-sub">Total enregistré</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">À traiter</div>
        <div class="stat-card-value">{{ stats.pending }}</div>
        <div class="stat-card-sub">En attente</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">Validées</div>
        <div class="stat-card-value">{{ stats.confirmed + stats.shipped + stats.delivered }}</div>
        <div class="stat-card-sub">Pipeline actif</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">Rejetées</div>
        <div class="stat-card-value">{{ stats.rejected }}</div>
        <div class="stat-card-sub">Demandes refusées</div>
    </div>
</div>

<div class="data-table">
    <div class="data-table-header">
        <div class="toolbar">
            <div>
                <h3>Commandes clients</h3>
                <p class="muted">Valider, rejeter et suivre la progression logistique</p>
            </div>
            <form method="GET" style="display: flex; gap: 12px; flex-wrap: wrap;">
                <input type="text" name="search" class="form-control" style="min-width:220px;" placeholder="Produit ou email..." value="{{ searchTerm|default('') }}">
                <select name="status" class="form-select" style="max-width: 150px;">
                    <option value="">Tous statuts</option>
                    <option value="pending" {% if statusFilter == 'pending' %}selected{% endif %}>En attente</option>
                    <option value="confirmed" {% if statusFilter == 'confirmed' %}selected{% endif %}>Confirmée</option>
                    <option value="shipped" {% if statusFilter == 'shipped' %}selected{% endif %}>Expédiée</option>
                    <option value="delivered" {% if statusFilter == 'delivered' %}selected{% endif %}>Livrée</option>
                    <option value="rejected" {% if statusFilter == 'rejected' %}selected{% endif %}>Rejetée</option>
                </select>
                <select name="sort" class="form-select" style="max-width: 150px;">
                    <option value="orderDate" {% if sortBy|default('orderDate') == 'orderDate' %}selected{% endif %}>Trier par Date</option>
                    <option value="id" {% if sortBy|default('') == 'id' %}selected{% endif %}>Trier par ID</option>
                    <option value="status" {% if sortBy|default('') == 'status' %}selected{% endif %}>Trier par Statut</option>
                    <option value="quantity" {% if sortBy|default('') == 'quantity' %}selected{% endif %}>Trier par Qte</option>
                </select>
                <select name="order" class="form-select" style="max-width: 100px;">
                    <option value="DESC" {% if sortOrder|default('DESC') == 'DESC' %}selected{% endif %}>DESC</option>
                    <option value="ASC" {% if sortOrder|default('') == 'ASC' %}selected{% endif %}>ASC</option>
                </select>
                <button type="submit" class="btn btn-primary">Filtrer</button>
                <a href="{{ path('app_order_index') }}" class="btn btn-outline-secondary">Réinit.</a>
            </form>
        </div>
    </div>

    <div style="overflow-x:auto;">
        {% set statusLabels = {
            'confirmed': 'Confirmer',
            'shipped': 'Expédier',
            'delivered': 'Livrer',
            'rejected': 'Rejeter'
        } %}
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Client</th>
                    <th>Email</th>
                    <th>Produit(s)</th>
                    <th>Telephone</th>
                    <th>Total</th>
                    <th>Paiement</th>
                    <th>Statut paiement</th>
                    <th>Date</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for order in orders %}
                    <tr>
                        <td>#{{ order.id }}</td>
                        <td>{{ order.entraineur ? order.entraineur.prenom ~ ' ' ~ order.entraineur.nom : 'Client' }}</td>
                        <td>{{ order.contactEmail ?: (order.entraineur ? order.entraineur.email : '-') }}</td>
                        <td>
                            {% if order.items|length > 0 %}
                                {{ order.items|length }} produit(s)
                            {% else %}
                                {{ order.product ? order.product.name : '-' }}
                            {% endif %}
                        </td>
                        <td>{{ order.contactPhone ?: (order.entraineur ? order.entraineur.telephone : '-') }}</td>
                        <td>{{ (order.totalAmount ?: order.computedTotal)|number_format(2, ',', ' ') }} USD</td>
                        <td>
                            {% if order.paymentMethod == 'online' %}
                                <span class="badge-info">En ligne</span>
                            {% else %}
                                <span class="badge-warning">Livraison</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if order.paymentStatus == 'paid' %}
                                <span class="badge-success">Paid</span>
                            {% elseif order.paymentStatus == 'failed' %}
                                <span class="badge-danger">Failed</span>
                            {% else %}
                                <span class="badge-warning">Pending</span>
                            {% endif %}
                        </td>
                        <td>{{ order.orderDate|date('d/m/Y H:i') }}</td>
                        <td>
                            {% if order.status == 'pending' %}
                                <span class="badge-warning">En attente</span>
                            {% elseif order.status == 'confirmed' %}
                                <span class="badge-info">Confirmée</span>
                            {% elseif order.status == 'shipped' %}
                                <span class="badge-info">Expédiée</span>
                            {% elseif order.status == 'delivered' %}
                                <span class="badge-success">Livrée</span>
                            {% elseif order.status == 'rejected' %}
                                <span class="badge-danger">Rejetée</span>
                            {% else %}
                                <span class="badge-warning">{{ order.status }}</span>
                            {% endif %}
                        </td>
                        <td>
                            <div style="display:flex; gap:6px; flex-wrap:wrap; align-items:center;">
                                <a href="{{ path('app_order_show', {id: order.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                                <a href="{{ path('app_order_edit', {id: order.id}) }}" class="btn btn-sm btn-outline-warning">Edit</a>
                                <form method="POST" action="{{ path('app_order_delete', { id: order.id }) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette commande ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Suppr.</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="11" style="text-align:center;" class="muted-soft">Aucune commande trouvée</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if totalPages > 1 %}
        <nav aria-label="Order pagination" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item{% if page == 1 %} disabled{% endif %}">
                    <a class="page-link" href="?search={{ searchTerm|default('') }}&status={{ statusFilter|default('') }}&sort={{ sortBy|default('orderDate') }}&order={{ sortOrder|default('DESC') }}&page={{ page-1 }}">Précédent</a>
                </li>
                {% for p in 1..totalPages %}
                    <li class="page-item{% if p == page %} active{% endif %}"><a class="page-link" href="?search={{ searchTerm|default('') }}&status={{ statusFilter|default('') }}&sort={{ sortBy|default('orderDate') }}&order={{ sortOrder|default('DESC') }}&page={{ p }}">{{ p }}</a></li>
                {% endfor %}
                <li class="page-item{% if page == totalPages %} disabled{% endif %}">
                    <a class="page-link" href="?search={{ searchTerm|default('') }}&status={{ statusFilter|default('') }}&sort={{ sortBy|default('orderDate') }}&order={{ sortOrder|default('DESC') }}&page={{ page+1 }}">Suivant</a>
                </li>
            </ul>
        </nav>
    {% endif %}
</div>
{% endblock %}
