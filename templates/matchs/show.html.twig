{% extends 'back_office/base.html.twig' %}

{% block title %}Match Details{% endblock %}

{% block body %}
    <style>
        .match-details {
            max-width: 1000px;
            margin: 0 auto;
            padding: 40px 24px;
        }

        .details-header {
            margin-bottom: 40px;
        }

        .details-header h1 {
            font-size: 32px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 24px;
        }

        .match-card {
            background: var(--card-bg);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            border: 1px solid var(--border-color);
            margin-bottom: 32px;
        }

        .match-header {
            background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
            color: white;
            padding: 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .match-title {
            font-size: 24px;
            font-weight: 700;
            margin: 0;
        }

        .match-id-badge {
            background: rgba(255, 255, 255, 0.2);
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            font-family: 'Courier New', monospace;
        }

        .details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 24px;
            padding: 32px;
        }

        .detail-item {
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 16px;
            background: var(--surface-2);
        }

        .detail-label {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
            display: block;
        }

        .detail-value {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-dark);
            word-break: break-word;
        }

        .teams-section {
            padding: 32px;
            border-top: 1px solid var(--border-color);
        }

        .teams-section h3 {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 24px;
        }

        .teams-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
        }

        .team-box {
            border: 2px solid var(--border-color);
            border-radius: 8px;
            padding: 20px;
            background: var(--surface-2);
        }

        .team-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 12px;
            text-transform: uppercase;
        }

        .team-name {
            font-size: 20px;
            font-weight: 700;
            color: #10b981;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .team-logo {
            width: 60px;
            height: 60px;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .team-logo img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .lineup-section {
            padding: 20px;
            background: var(--card-bg);
            border-radius: 6px;
            margin-top: 12px;
            border-left: 4px solid #10b981;
        }

        .lineup-label {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 16px;
        }

        .joueurs-lineup-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
            gap: 12px;
        }

        .joueur-lineup-card {
            background: var(--surface-2);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 12px;
            text-align: center;
            transition: all 0.2s ease;
        }

        .joueur-lineup-card:hover {
            border-color: #10b981;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.1);
            transform: translateY(-2px);
        }

        .joueur-lineup-image {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            object-fit: cover;
            margin: 0 auto 8px;
            display: block;
            border: 2px solid var(--border-color);
        }

        .joueur-lineup-numero {
            font-size: 18px;
            font-weight: 700;
            color: #10b981;
            margin-bottom: 4px;
        }

        .joueur-lineup-nom {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-dark);
            word-break: break-word;
        }

        .joueur-lineup-prenom {
            font-size: 11px;
            color: var(--text-muted);
            word-break: break-word;
        }

        .joueur-lineup-placeholder {
            width: 60px;
            height: 60px;
            margin: 0 auto 8px;
            border-radius: 50%;
            background: var(--surface-2);
            border: 2px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .action-buttons {
            padding: 24px 32px;
            border-top: 1px solid var(--border-color);
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .action-btn {
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-edit {
            background: #dbeafe;
            color: #1e40af;
        }

        .btn-edit:hover {
            background: #bfdbfe;
        }

        .btn-back {
            background: #f3f4f6;
            color: #1f2937;
            border: 1px solid #e5e7eb;
        }

        .btn-back:hover {
            background: #e5e7eb;
        }

        .btn-delete {
            background: #fee2e2;
            color: #991b1b;
        }

        .btn-delete:hover {
            background: #fecaca;
        }

        [data-theme="dark"] .match-header {
            background: linear-gradient(135deg, #0f172a 0%, #020617 100%);
            border-bottom: 1px solid var(--border-color);
        }

        [data-theme="dark"] .btn-back {
            background: var(--surface-2);
            color: var(--text-dark);
            border-color: var(--border-color);
        }

        [data-theme="dark"] .btn-back:hover {
            background: #1e293b;
        }
    </style>

    <div class="match-details">
        <div class="details-header">
            <h1>⚽ Détails du Match</h1>
        </div>

        <div class="match-card">
            <div class="match-header">
                <div class="match-title">
                    {{ match.equipeDomicile.nom }} vs {{ match.equipeExterieur.nom }}
                </div>
                <div class="match-id-badge">#{{ match.id }}</div>
            </div>

            <div class="details-grid">
                <div class="detail-item">
                    <span class="detail-label">📅 Date</span>
                    <span class="detail-value">{{ match.dateMatch ? match.dateMatch|date('d/m/Y') : 'N/A' }}</span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">🕐 Heure</span>
                    <span class="detail-value">{{ match.heureDebut ? match.heureDebut|date('H:i') : 'N/A' }}</span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">📍 Lieu</span>
                    <span class="detail-value">{{ match.lieu ?? 'N/A' }}</span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">🎯 Type</span>
                    <span class="detail-value">{{ match.type ?? 'N/A' }}</span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">🔔 Statut</span>
                    <span class="detail-value">{{ match.statut ?? 'N/A' }}</span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">⚽ Score</span>
                    <span class="detail-value">{{ match.scoreEquipeDomicile ?? 0 }} - {{ match.scoreEquipeExterieur ?? 0 }}</span>
                </div>
            </div>

            <div class="teams-section">
                <h3>Équipes</h3>
                <div class="teams-grid">
                    <div class="team-box">
                        <div class="team-title">Équipe Domicile</div>
                        <div class="team-name">
                            {% if match.equipeDomicile.image %}
                                <div class="team-logo">
                                    <img src="{{ media_url(match.equipeDomicile.image, 'equipes') }}" alt="{{ match.equipeDomicile.nom }}">
                                </div>
                            {% endif %}
                            {{ match.equipeDomicile.nom }}
                        </div>
                        {% if domicileLineups is not empty %}
                            <div class="lineup-section">
                                <div class="lineup-label">Composition ({{ domicileLineups|length }} joueurs)</div>
                                <div class="joueurs-lineup-grid">
                                    {% for lineup in domicileLineups %}
                                        <div class="joueur-lineup-card">
                                            {% if lineup.joueur.image %}
                                    <img src="{{ media_url(lineup.joueur.image, 'joueurs') }}" alt="{{ lineup.joueur.prenom }} {{ lineup.joueur.nom }}" class="joueur-lineup-image">
                                            {% else %}
                                                <div class="joueur-lineup-placeholder">👤</div>
                                            {% endif %}
                                            <div class="joueur-lineup-numero">{{ lineup.joueur.numero }}</div>
                                            <div class="joueur-lineup-nom">{{ lineup.joueur.nom }}</div>
                                            <div class="joueur-lineup-prenom">{{ lineup.joueur.prenom }}</div>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>

                    <div class="team-box">
                        <div class="team-title">Équipe Extérieure</div>
                        <div class="team-name">
                            {% if match.equipeExterieur.image %}
                                <div class="team-logo">
                                    <img src="{{ media_url(match.equipeExterieur.image, 'equipes') }}" alt="{{ match.equipeExterieur.nom }}">
                                </div>
                            {% endif %}
                            {{ match.equipeExterieur.nom }}
                        </div>
                        {% if exterieurLineups is not empty %}
                            <div class="lineup-section">
                                <div class="lineup-label">Composition ({{ exterieurLineups|length }} joueurs)</div>
                                <div class="joueurs-lineup-grid">
                                    {% for lineup in exterieurLineups %}
                                        <div class="joueur-lineup-card">
                                            {% if lineup.joueur.image %}
                                    <img src="{{ media_url(lineup.joueur.image, 'joueurs') }}" alt="{{ lineup.joueur.prenom }} {{ lineup.joueur.nom }}" class="joueur-lineup-image">
                                            {% else %}
                                                <div class="joueur-lineup-placeholder">👤</div>
                                            {% endif %}
                                            <div class="joueur-lineup-numero">{{ lineup.joueur.numero }}</div>
                                            <div class="joueur-lineup-nom">{{ lineup.joueur.nom }}</div>
                                            <div class="joueur-lineup-prenom">{{ lineup.joueur.prenom }}</div>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="action-buttons">
                <a href="{{ path('app_matchs_index') }}" class="action-btn btn-back">← Retour à la liste</a>
                <a href="{{ path('app_matchs_edit', {'id': match.id}) }}" class="action-btn btn-edit">✏️ Éditer</a>
                {{ include('matchs/_delete_form.html.twig', {'delete_form': delete_form}) }}
            </div>
        </div>
    </div>
{% endblock %}
