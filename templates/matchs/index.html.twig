{% extends 'back_office/base.html.twig' %}

{% block title %}Matchs Management{% endblock %}

{% block body %}
    <style>
        .matchs-admin {
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px 24px;
        }

        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .admin-header h1 {
            font-size: 32px;
            font-weight: 800;
            color: #1f2937;
            margin: 0;
        }

        .header-controls {
            display: flex;
            gap: 12px;
        }

        .sort-btn, .create-btn {
            padding: 10px 16px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .sort-btn {
            background: #f3f4f6;
            color: #1f2937;
            border: 1px solid #e5e7eb;
        }

        .sort-btn:hover {
            background: #e5e7eb;
            border-color: #d1d5db;
        }

        .create-btn {
            background: #10b981;
            color: white;
        }

        .create-btn:hover {
            background: #059669;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        }

        .matchs-table {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            border: 1px solid #e5e7eb;
        }

        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #f9fafb;
            border-bottom: 2px solid #e5e7eb;
        }

        th {
            padding: 16px;
            text-align: left;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        tbody tr {
            border-bottom: 1px solid #e5e7eb;
            transition: background 0.15s;
        }

        tbody tr:hover {
            background: #f9fafb;
        }

        td {
            padding: 16px;
            font-size: 14px;
            color: #1f2937;
        }

        .status-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            text-transform: capitalize;
        }

        .status-programmé { background: #dbeafe; color: #1e40af; }
        .status-en-cours { background: #dcfce7; color: #166534; }
        .status-terminé { background: #f3f4f6; color: #4b5563; }
        .status-annulé { background: #fee2e2; color: #991b1b; }

        .action-btns {
            display: flex;
            gap: 8px;
        }

        .action-btn {
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            gap: 4px;
        }

        .btn-view { background: #e0f2fe; color: #0369a1; }
        .btn-edit { background: #dbeafe; color: #1e40af; }
        .btn-delete { background: #fee2e2; color: #991b1b; }
    </style>

    <div class="matchs-admin">
        <div class="admin-header">
            <h1>⚽ Matchs</h1>
            <div class="header-controls">
                <form method="get" action="{{ path('app_matchs_index') }}" style="display: flex; gap: 8px;">
                    <button type="submit" name="order" value="asc" class="sort-btn">📈 Croissant</button>
                    <button type="submit" name="order" value="desc" class="sort-btn">📉 Décroissant</button>
                </form>
                <a href="{{ path('app_matchs_new') }}" class="create-btn">➕ Nouveau Match</a>
            </div>
        </div>

        <div style="background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 20px; margin-bottom: 24px;">
            <form method="GET" action="{{ path('app_matchs_index') }}">
                <div style="display: flex; gap: 12px; align-items: flex-end;">
                    <div style="flex: 1;">
                        <label for="search" style="font-size: 13px; font-weight: 600; margin-bottom: 6px; display: block;">Recherche</label>
                        <input type="text" name="search" id="search" value="{{ search|default('') }}" placeholder="Rechercher par lieu..." class="form-control">
                    </div>
                    <button type="submit" class="sort-btn">🔍 Rechercher</button>
                    <a href="{{ path('app_matchs_index') }}" class="sort-btn">Réinitialiser</a>
                </div>
            </form>
        </div>

        <div class="matchs-table">
            {% if matchs %}
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Matchs</th>
                                <th>Date & Heure</th>
                                <th>Lieu</th>
                                <th>Score</th>
                                <th>Type</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for match in matchs %}
                            <tr>
                                <td><span class="match-id" style="font-weight: 600; color: #10b981; font-family: monospace;">#{{ match.id }}</span></td>
                                <td>
                                    <div style="font-weight: 600;">
                                        {{ match.equipeDomicile.nom|default('TBD') }}
                                        <span style="color: #6b7280; font-size: 12px;">vs</span>
                                        {{ match.equipeExterieur.nom|default('TBD') }}
                                    </div>
                                </td>
                                <td>
                                    {{ match.dateMatch ? match.dateMatch|date('d/m/Y') : 'N/A' }}<br>
                                    <small style="color: #9ca3af;">{{ match.heureDebut ? match.heureDebut|date('H:i') : 'N/A' }}</small>
                                </td>
                                <td>{{ match.lieu ?? 'N/A' }}</td>
                                <td>
                                    <span style="background: #dbeafe; color: #1e40af; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 600;">
                                        {{ match.scoreEquipeDomicile|default(0) }} - {{ match.scoreEquipeExterieur|default(0) }}
                                    </span>
                                </td>
                                <td>{{ match.type ?? 'N/A' }}</td>
                                <td>
                                    <span class="status-badge status-{{ match.statut|lower|replace({'programmé': 'programmé', 'en cours': 'en-cours', 'terminé': 'terminé', 'annulé': 'annulé'}) }}">
                                        {{ match.statut ?? 'N/A' }}
                                    </span>
                                </td>
                                <td>
                                    <div class="action-btns">
                                        <a href="{{ path('app_matchs_show', {'id': match.id}) }}" class="action-btn btn-view">👁 Voir</a>
                                        <a href="{{ path('app_matchs_edit', {'id': match.id}) }}" class="action-btn btn-edit">✏️ Éditer</a>
                                        <form method="post" action="{{ path('app_matchs_delete', {'id': match.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer ce match ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ match.id) }}">
                                            <button class="action-btn btn-delete" style="border:none; cursor:pointer;">🗑️ Supprimer</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="empty-state" style="padding: 60px 40px; text-align: center;">
                    <div style="font-size: 60px; margin-bottom: 20px; opacity: 0.4;">📭</div>
                    <h3>Aucun match</h3>
                    <p>Il n'y a actuellement aucun match enregistré.</p>
                    <a href="{{ path('app_matchs_new') }}" class="create-btn">➕ Créer le premier match</a>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
