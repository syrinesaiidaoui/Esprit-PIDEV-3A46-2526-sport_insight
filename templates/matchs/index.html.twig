{% extends 'back_office/base.html.twig' %}

{% block title %}Matchs Management{% endblock %}
{% block page_title %}Matchs{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_matchs_new') }}" class="btn btn-primary btn-add-product">Nouveau match</a>
{% endblock %}

{% block body %}
    <div class="data-table">
        <div class="data-table-header">
            <div class="toolbar">
                <div>
                    <h3>Liste des matchs</h3>
                    <p class="muted">{{ matchs|length }} match(s)</p>
                </div>
                <form method="get" action="{{ path('app_matchs_index') }}" class="d-flex gap-2">
                    <button type="submit" name="order" value="asc" class="btn btn-outline-secondary">Croissant</button>
                    <button type="submit" name="order" value="desc" class="btn btn-outline-secondary">Decroissant</button>
                </form>
            </div>
        </div>

        <div style="padding: 18px 24px; border-bottom: 1px solid var(--border-color);">
            <form method="GET" action="{{ path('app_matchs_index') }}" class="d-flex gap-2 align-items-end flex-wrap">
                <div style="min-width: 260px; flex: 1 1 auto;">
                    <label for="search" class="form-label">Recherche</label>
                    <input type="text" name="search" id="search" value="{{ search }}" placeholder="Rechercher par lieu..." class="form-control">
                </div>
                <button type="submit" class="btn btn-primary">Rechercher</button>
                <a href="{{ path('app_matchs_index') }}" class="btn btn-secondary">Reinitialiser</a>
            </form>
        </div>

        {% if matchs %}
            <div style="overflow-x: auto;">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Match</th>
                            <th>Date et heure</th>
                            <th>Lieu</th>
                            <th>Score</th>
                            <th>Type</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for match in matchs %}
                        <tr>
                            <td>#{{ match.id }}</td>
                            <td>{{ match.equipeDomicile.nom }} vs {{ match.equipeExterieur.nom }}</td>
                            <td>
                                {{ match.dateMatch ? match.dateMatch|date('d/m/Y') : '-' }}
                                <br>
                                <span class="muted-soft">{{ match.heureDebut ? match.heureDebut|date('H:i') : '-' }}</span>
                            </td>
                            <td>{{ match.lieu ?: '-' }}</td>
                            <td>
                                <span class="badge-info">{{ match.scoreEquipeDomicile ?? 0 }} - {{ match.scoreEquipeExterieur ?? 0 }}</span>
                            </td>
                            <td>{{ match.type ?: '-' }}</td>
                            <td>
                                {% set status = match.statut ?: 'Inconnu' %}
                                {% set statusClass = 'badge-warning' %}
                                {% if status|lower in ['en cours', 'programmee', 'programme'] %}
                                    {% set statusClass = 'badge-info' %}
                                {% elseif status|lower in ['termine', 'terminee'] %}
                                    {% set statusClass = 'badge-success' %}
                                {% elseif status|lower in ['annule', 'annulee'] %}
                                    {% set statusClass = 'badge-danger' %}
                                {% endif %}
                                <span class="{{ statusClass }}">{{ status }}</span>
                            </td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a href="{{ path('app_matchs_show', {'id': match.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                                    <a href="{{ path('app_matchs_edit', {'id': match.id}) }}" class="btn btn-sm btn-outline-secondary">Editer</a>
                                    <form method="post" action="{{ path('app_matchs_delete', {'id': match.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer ce match ?');">
                                        <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="text-center p-5">
                <p class="muted-soft mb-3">Aucun match pour le moment.</p>
                <a href="{{ path('app_matchs_new') }}" class="btn btn-primary">Creer le premier match</a>
            </div>
        {% endif %}
    </div>
{% endblock %}
