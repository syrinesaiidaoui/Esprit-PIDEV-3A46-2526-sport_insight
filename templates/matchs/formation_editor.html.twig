{% extends 'back_office/base.html.twig' %}

{% block title %}Éditeur de Formation - {{ match.equipeDomicile.nom }} vs {{ match.equipeExterieur.nom }}{% endblock %}

{% block body %}
    <style>
        .formation-editor {
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px 24px;
        }

        .editor-header {
            margin-bottom: 40px;
        }

        .editor-header h1 {
            font-size: 32px;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 24px;
        }

        .formation-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-bottom: 40px;
        }

        .team-formation {
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            border: 1px solid #e5e7eb;
        }

        .team-formation h2 {
            font-size: 24px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .team-formation-logo {
            width: 40px;
            height: 40px;
            object-fit: contain;
        }

        .football-field-editor {
            background: linear-gradient(135deg, #1d4d2d 0%, #2d6b3d 100%);
            border: 3px solid #e5e7eb;
            border-radius: 8px;
            min-height: 600px;
            position: relative;
            margin-bottom: 24px;
            aspect-ratio: 5 / 8;
            overflow: hidden;
        }

        .team-formation.team-away .football-field-editor {
            background: linear-gradient(135deg, #1d2d4d 0%, #2d3d6b 100%);
        }

        .field-lines {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        .field-line {
            position: absolute;
            border: 2px solid rgba(255, 255, 255, 0.3);
        }

        .field-center-line {
            width: 2px;
            height: 100%;
            left: 50%;
            top: 0;
            transform: translateX(-1px);
        }

        .field-center-circle {
            width: 20%;
            height: 20%;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            top: 40%;
            left: 40%;
            transform: translate(-50%, -50%);
        }

        .field-center-dot {
            width: 6px;
            height: 6px;
            background: rgba(255, 255, 255, 0.5);
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .field-penalty-area {
            width: 20%;
            height: 50%;
            border: 2px solid rgba(255, 255, 255, 0.3);
        }

        .field-penalty-area-domicile {
            top: 25%;
            left: 0;
        }

        .field-penalty-area-away {
            top: 25%;
            right: 0;
        }

        .field-goal-box {
            width: 30%;
            height: 35%;
            border: 2px solid rgba(255, 255, 255, 0.3);
        }

        .field-goal-box-domicile {
            top: 32.5%;
            left: 0;
        }

        .field-goal-box-away {
            top: 32.5%;
            right: 0;
        }

        .joueurs-container {
            position: relative;
            width: 100%;
            height: 600px;
        }

        .joueur-draggable {
            position: absolute;
            display: flex;
            flex-direction: column;
            align-items: center;
            cursor: grab;
            transform: translate(-50%, -50%);
            user-select: none;
            transition: filter 0.2s;
        }

        .joueur-draggable:hover {
            filter: brightness(1.1);
        }

        .joueur-draggable.dragging {
            cursor: grabbing;
            opacity: 0.8;
            z-index: 1000;
        }

        .joueur-photo {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid white;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
            margin-bottom: 4px;
        }

        .joueur-numero-badge {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #ef4444;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 12px;
            position: absolute;
            bottom: -2px;
            right: -2px;
            border: 2px solid white;
        }

        .team-away .joueur-numero-badge {
            background: #3b82f6;
        }

        .joueur-nom {
            font-size: 11px;
            font-weight: 600;
            color: white;
            text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
            text-align: center;
            max-width: 60px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .joueurs-list {
            margin-top: 24px;
            padding-top: 24px;
            border-top: 1px solid #e5e7eb;
        }

        .joueurs-list h3 {
            font-size: 16px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 12px;
        }

        .joueur-list-item {
            background: #f9fafb;
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
            color: #1f2937;
        }

        .joueur-list-item img {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
        }

        .action-buttons {
            display: flex;
            gap: 12px;
            margin-bottom: 32px;
        }

        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-primary {
            background: #10b981;
            color: white;
        }

        .btn-primary:hover {
            background: #059669;
        }

        .btn-secondary {
            background: #f3f4f6;
            color: #1f2937;
            border: 1px solid #e5e7eb;
        }

        .btn-secondary:hover {
            background: #e5e7eb;
        }

        .hint {
            background: #fef3c7;
            border-left: 4px solid #f59e0b;
            padding: 12px;
            border-radius: 6px;
            font-size: 13px;
            color: #92400e;
            margin-bottom: 24px;
        }
    </style>

    <div class="formation-editor">
        <div class="editor-header">
            <h1>⚽ Éditeur de Formation</h1>
            <p style="color: #6b7280;">Glissez-déposez les joueurs sur le terrain pour les positionner</p>
        </div>

        <div class="hint">
            💡 Conseil : Cliquez et glissez les joueurs sur le terrain de football pour les positionner. Les positions seront sauvegardées automatiquement.
        </div>

        <div class="formation-container">
            <!-- ÉQUIPE DOMICILE -->
            <div class="team-formation">
                <h2>
                    {% if match.equipeDomicile.image %}
                            <img src="{{ media_url(match.equipeDomicile.image, 'equipes') }}" alt="{{ match.equipeDomicile.nom }}" class="team-formation-logo">
                    {% endif %}
                    {{ match.equipeDomicile.nom }}
                </h2>

                <div class="football-field-editor">
                    <div class="field-lines">
                        <div class="field-line field-center-line"></div>
                        <div class="field-line field-center-circle"></div>
                        <div class="field-line field-center-dot"></div>
                        <div class="field-line field-penalty-area field-penalty-area-domicile"></div>
                        <div class="field-line field-goal-box field-goal-box-domicile"></div>
                        <div class="field-line field-penalty-area field-penalty-area-away"></div>
                        <div class="field-line field-goal-box field-goal-box-away"></div>
                    </div>
                    <div class="joueurs-container" data-team="domicile">
                        {% for lineup in domicileLineups %}
                            <div class="joueur-draggable" data-lineup-id="{{ lineup.id }}" style="left: {% if lineup.positionX %}{{ lineup.positionX }}%{% else %}50%{% endif %}; top: {% if lineup.positionY %}{{ lineup.positionY }}%{% else %}{{ 30 + loop.index0 * 10 }}%{% endif %};">
                                <div style="position: relative;">
                                    {% if lineup.joueur.image %}
                                        <img src="{{ media_url(lineup.joueur.image, 'joueurs') }}" alt="{{ lineup.joueur.prenom }} {{ lineup.joueur.nom }}" class="joueur-photo">
                                    {% else %}
                                        <div style="width: 50px; height: 50px; border-radius: 50%; background: rgba(255, 255, 255, 0.2); display: flex; align-items: center; justify-content: center; font-size: 24px;">👤</div>
                                    {% endif %}
                                    <div class="joueur-numero-badge">{{ lineup.joueur.numero }}</div>
                                </div>
                                <div class="joueur-nom">{{ lineup.joueur.nom }}</div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="joueurs-list">
                    <h3>Joueurs ({{ domicileLineups|length }})</h3>
                    {% for lineup in domicileLineups %}
                        <div class="joueur-list-item">
                            {% if lineup.joueur.image %}
                                        <img src="{{ media_url(lineup.joueur.image, 'joueurs') }}" alt="">
                            {% endif %}
                            <div>
                                <strong>{{ lineup.joueur.numero }}</strong> - {{ lineup.joueur.nom }} {{ lineup.joueur.prenom }}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <!-- ÉQUIPE EXTÉRIEURE -->
            <div class="team-formation team-away">
                <h2>
                    {% if match.equipeExterieur.image %}
                            <img src="{{ media_url(match.equipeExterieur.image, 'equipes') }}" alt="{{ match.equipeExterieur.nom }}" class="team-formation-logo">
                    {% endif %}
                    {{ match.equipeExterieur.nom }}
                </h2>

                <div class="football-field-editor">
                    <div class="field-lines">
                        <div class="field-line field-center-line"></div>
                        <div class="field-line field-center-circle"></div>
                        <div class="field-line field-center-dot"></div>
                        <div class="field-line field-penalty-area field-penalty-area-domicile"></div>
                        <div class="field-line field-goal-box field-goal-box-domicile"></div>
                        <div class="field-line field-penalty-area field-penalty-area-away"></div>
                        <div class="field-line field-goal-box field-goal-box-away"></div>
                    </div>
                    <div class="joueurs-container" data-team="exterieur">
                        {% for lineup in exterieurLineups %}
                            <div class="joueur-draggable" data-lineup-id="{{ lineup.id }}" style="left: {% if lineup.positionX %}{{ lineup.positionX }}%{% else %}{{ 50 + (7 - loop.index0) * 5 }}%{% endif %}; top: {% if lineup.positionY %}{{ lineup.positionY }}%{% else %}{{ 30 + loop.index0 * 10 }}%{% endif %};">
                                <div style="position: relative;">
                                    {% if lineup.joueur.image %}
                                        <img src="{{ media_url(lineup.joueur.image, 'joueurs') }}" alt="{{ lineup.joueur.prenom }} {{ lineup.joueur.nom }}" class="joueur-photo">
                                    {% else %}
                                        <div style="width: 50px; height: 50px; border-radius: 50%; background: rgba(255, 255, 255, 0.2); display: flex; align-items: center; justify-content: center; font-size: 24px;">👤</div>
                                    {% endif %}
                                    <div class="joueur-numero-badge">{{ lineup.joueur.numero }}</div>
                                </div>
                                <div class="joueur-nom">{{ lineup.joueur.nom }}</div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="joueurs-list">
                    <h3>Joueurs ({{ exterieurLineups|length }})</h3>
                    {% for lineup in exterieurLineups %}
                        <div class="joueur-list-item">
                            {% if lineup.joueur.image %}
                                        <img src="{{ media_url(lineup.joueur.image, 'joueurs') }}" alt="">
                            {% endif %}
                            <div>
                                <strong>{{ lineup.joueur.numero }}</strong> - {{ lineup.joueur.nom }} {{ lineup.joueur.prenom }}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="action-buttons">
            <button class="btn btn-primary" onclick="savePositions()">💾 Sauvegarder les positions</button>
            <a href="{{ path('app_matchs_show', {'id': match.id}) }}" class="btn btn-secondary">← Retour au match</a>
        </div>
    </div>

    <script>
        let draggedElement = null;
        let offsetX = 0;
        let offsetY = 0;

        document.querySelectorAll('.joueur-draggable').forEach(joueur => {
            joueur.addEventListener('mousedown', function(e) {
                draggedElement = this;
                const rect = this.parentElement.getBoundingClientRect();
                offsetX = e.clientX - rect.left - (parseFloat(this.style.left) * rect.width / 100);
                offsetY = e.clientY - rect.top - (parseFloat(this.style.top) * rect.height / 100);
                this.classList.add('dragging');
            });
        });

        document.addEventListener('mousemove', function(e) {
            if (draggedElement) {
                const container = draggedElement.parentElement;
                const rect = container.getBoundingClientRect();
                
                let x = e.clientX - rect.left - offsetX;
                let y = e.clientY - rect.top - offsetY;
                
                // Limiter aux limites du terrain
                x = Math.max(0, Math.min(x, rect.width));
                y = Math.max(0, Math.min(y, rect.height));
                
                const xPercent = (x / rect.width) * 100;
                const yPercent = (y / rect.height) * 100;
                
                draggedElement.style.left = xPercent + '%';
                draggedElement.style.top = yPercent + '%';
            }
        });

        document.addEventListener('mouseup', function() {
            if (draggedElement) {
                draggedElement.classList.remove('dragging');
                draggedElement = null;
            }
        });

        function savePositions() {
            const positions = {};

            document.querySelectorAll('.joueur-draggable').forEach(joueur => {
                const lineupId = joueur.getAttribute('data-lineup-id');
                const x = parseFloat(joueur.style.left);
                const y = parseFloat(joueur.style.top);
                
                positions[lineupId] = { x, y };
            });

            fetch('{{ path('app_match_save_positions', {'id': match.id}) }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ positions })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('✅ Positions sauvegardées avec succès!');
                } else {
                    alert('❌ Erreur : ' + data.error);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('❌ Erreur lors de la sauvegarde');
            });
        }
    </script>
{% endblock %}
