{{ form_start(form, {'attr': {'id': 'match-form', 'data-match-id': match.id|default('new')}}) }}
    <div class="mb-3">
        {{ form_label(form.dateMatch, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.dateMatch, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.dateMatch) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.heureDebut, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.heureDebut, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.heureDebut) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.lieu, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.lieu, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.lieu) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.type, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.type, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.type) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.statut, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.statut, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.statut) }}
    </div>
    
    <div class="mb-3">
        {{ form_label(form.equipeDomicile, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.equipeDomicile, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.equipeDomicile) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.equipeExterieur, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.equipeExterieur, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.equipeExterieur) }}
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                {{ form_label(form.scoreEquipeDomicile, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.scoreEquipeDomicile, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.scoreEquipeDomicile) }}
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                {{ form_label(form.scoreEquipeExterieur, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.scoreEquipeExterieur, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.scoreEquipeExterieur) }}
            </div>
        </div>
